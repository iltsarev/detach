#!/bin/bash

set -euo pipefail

ROOT="$(cd -P "$(dirname "$0")/.." && pwd)"
POLICY_VERSION=2
MODE=change
BASE_REF=""
PLAN_ONLY=0
DIAGNOSTIC_STAGE=""
OUTPUT_FORMAT=text
EXPLAIN=0
KEEP_GOING=0
RESUME_DIR=""
TEST_MODE="${DETACH_QUALITY_GATE_TEST_MODE:-0}"
RESULT_ROOT="${DETACH_QUALITY_GATE_RESULT_ROOT:-$ROOT/app/build/quality-gates}"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$"
RUN_DIR="$RESULT_ROOT/$RUN_ID"
SUMMARY="$RUN_DIR/summary.tsv"
MANIFEST="$RUN_DIR/manifest.tsv"
JUNIT="$RUN_DIR/junit.xml"
CURRENT_STAGE=""
CURRENT_CHILD=""
OVERALL_STATUS=0

ALL_STAGES=(static gate-contract swift app codex claude distribution tmux-runtime release-preflight publish-preflight release-workflow)
RELEASE_STAGES=(static gate-contract swift app codex claude distribution tmux-runtime release-preflight publish-preflight)
SELECTED=()
EXPLANATIONS=()

usage() {
  cat <<'EOF'
usage: scripts/quality-gate [--mode change|repository|release] [--base GIT_REF] [--plan]
                            [--format text|json] [--explain]
                            [--resume RUN_DIR] [--keep-going]
       scripts/quality-gate --stage NAME

The normal modes are readiness evidence. --stage is a diagnostic rerun only.
EOF
}

die() {
  printf 'quality-gate: %s\n' "$*" >&2
  exit 2
}

contains_stage() {
  local wanted="$1" stage
  for stage in "${SELECTED[@]:-}"; do
    [ "$stage" = "$wanted" ] && return 0
  done
  return 1
}

add_stage() {
  local stage="$1" reason="${2:-${IMPACT_REASON:-}}"
  contains_stage "$stage" || SELECTED+=("$stage")
  [ -z "$reason" ] || EXPLANATIONS+=("$reason -> $stage")
}

select_all() {
  local reason="${1:-full repository policy}" stage
  SELECTED=("${ALL_STAGES[@]}")
  for stage in "${ALL_STAGES[@]}"; do
    EXPLANATIONS+=("$reason -> $stage")
  done
}

select_release() {
  SELECTED=("${RELEASE_STAGES[@]}")
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode)
      [ "$#" -ge 2 ] || die '--mode requires a value'
      MODE="$2"
      shift 2
      ;;
    --base)
      [ "$#" -ge 2 ] || die '--base requires a ref'
      BASE_REF="$2"
      shift 2
      ;;
    --plan)
      PLAN_ONLY=1
      shift
      ;;
    --format)
      [ "$#" -ge 2 ] || die '--format requires a value'
      OUTPUT_FORMAT="$2"
      shift 2
      ;;
    --explain)
      EXPLAIN=1
      shift
      ;;
    --resume)
      [ "$#" -ge 2 ] || die '--resume requires a run directory'
      RESUME_DIR="$2"
      shift 2
      ;;
    --keep-going)
      KEEP_GOING=1
      shift
      ;;
    --stage)
      [ "$#" -ge 2 ] || die '--stage requires a name'
      DIAGNOSTIC_STAGE="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *) die "unknown argument: $1" ;;
  esac
done

case "$TEST_MODE" in 0|1) ;; *) die 'DETACH_QUALITY_GATE_TEST_MODE must be 0 or 1' ;; esac
case "$MODE" in change|repository|release) ;; *) die "invalid mode: $MODE" ;; esac
case "$OUTPUT_FORMAT" in text|json) ;; *) die "invalid format: $OUTPUT_FORMAT" ;; esac
[ -z "$DIAGNOSTIC_STAGE" ] || { [ "$MODE" = change ] && [ -z "$BASE_REF" ] || die '--stage cannot be combined with another selection'; }
[ "$OUTPUT_FORMAT" = text ] || [ "$PLAN_ONLY" = 1 ] || die '--format json requires --plan'
[ "$EXPLAIN" = 0 ] || { [ "$PLAN_ONLY" = 1 ] && [ "$OUTPUT_FORMAT" = text ]; } || die '--explain requires a text plan'
[ -z "$RESUME_DIR" ] || { [ "$PLAN_ONLY" = 0 ] && [ -z "$DIAGNOSTIC_STAGE" ]; } || die '--resume cannot be combined with --plan or --stage'

stage_exists() {
  local wanted="$1" stage
  for stage in "${ALL_STAGES[@]}"; do
    [ "$stage" = "$wanted" ] && return 0
  done
  return 1
}

changed_entries() {
  if [ -n "$BASE_REF" ]; then
    git -C "$ROOT" rev-parse --verify "$BASE_REF^{commit}" >/dev/null 2>&1 || die "invalid base ref: $BASE_REF"
    git -C "$ROOT" diff --name-status -z --find-renames "$BASE_REF"...HEAD
  fi
  git -C "$ROOT" diff --name-status -z --find-renames HEAD
  while IFS= read -r -d '' path; do
    printf 'A\0%s\0' "$path"
  done < <(git -C "$ROOT" ls-files -z --others --exclude-standard)
}

select_for_path() {
  local path="$1" change="${2:-changed}"
  IMPACT_REASON="$change $path"
  add_stage static
  case "$path" in
    .github/workflows/quality-gates.yml|docs/quality-gates.md|scripts/quality-gate|tests/quality-gate.sh)
      select_all "$change gate policy file $path"
      ;;
    *.md|docs/assets/*|agents.md|CLAUDE.md)
      ;;
    app/Sources/*|app/Tests/*)
      add_stage swift
      ;;
    app/Package.swift|app/Package.resolved)
      add_stage swift; add_stage app; add_stage tmux-runtime
      ;;
    app/Resources/*)
      add_stage swift; add_stage app; add_stage tmux-runtime
      ;;
    bin/*)
      add_stage app; add_stage codex; add_stage claude; add_stage distribution; add_stage tmux-runtime
      ;;
    install.sh|scripts/install.sh)
      add_stage app; add_stage distribution; add_stage tmux-runtime
      ;;
    scripts/build-tmux.sh)
      add_stage app; add_stage codex; add_stage claude; add_stage tmux-runtime
      ;;
    app/scripts/release.sh|app/scripts/publish-release.sh|app/scripts/make-dmg.sh|app/scripts/verify-appcast.sh|scripts/release-version|scripts/release-lid-probe|VERSION|BUILD)
      add_stage app; add_stage release-preflight; add_stage publish-preflight; add_stage release-workflow
      ;;
    app/scripts/*)
      add_stage app; add_stage tmux-runtime; add_stage release-preflight
      ;;
    tests/run.sh|tests/fake-codex)
      add_stage app; add_stage codex
      ;;
    tests/run-claude.sh|tests/fake-claude)
      add_stage app; add_stage claude
      ;;
    tests/distribution.sh)
      add_stage app; add_stage distribution
      ;;
    tests/tmux-runtime.sh|tests/power-smoke.sh)
      add_stage app; add_stage tmux-runtime
      ;;
    tests/release-preflight.sh)
      add_stage release-preflight
      ;;
    tests/publish-preflight.sh)
      add_stage publish-preflight
      ;;
    tests/release-workflow.sh)
      add_stage release-workflow
      ;;
    .gitignore|.gitattributes)
      ;;
    *)
      printf 'quality-gate: unknown impact for %s; selecting repository gate\n' "$path" >&2
      select_all "$change unclassified path $path"
      ;;
  esac
}

if [ -n "$DIAGNOSTIC_STAGE" ]; then
  stage_exists "$DIAGNOSTIC_STAGE" || die "unknown stage: $DIAGNOSTIC_STAGE"
  SELECTED=("$DIAGNOSTIC_STAGE")
elif [ "$MODE" = repository ]; then
  select_all
elif [ "$MODE" = release ]; then
  select_release
else
  while IFS= read -r -d '' status && IFS= read -r -d '' path; do
    case "$status" in
      R*|C*)
        IFS= read -r -d '' new_path || die 'malformed rename/copy entry from Git'
        select_for_path "$path" "$status old"
        select_for_path "$new_path" "$status new"
        ;;
      *) select_for_path "$path" "$status" ;;
    esac
  done < <(changed_entries)
  if [ "${#SELECTED[@]}" -eq 0 ]; then
    printf 'quality-gate: no diff to classify; selecting repository gate\n' >&2
    select_all 'empty diff fail-safe policy'
  fi
fi

# Preserve the canonical cheap-to-expensive order after taking the union.
ordered=()
for stage in "${ALL_STAGES[@]}"; do
  contains_stage "$stage" && ordered+=("$stage")
done
SELECTED=("${ordered[@]}")

EFFECTIVE_MODE="$([ -n "$DIAGNOSTIC_STAGE" ] && printf diagnostic || printf '%s' "$MODE")"
STAGE_LIST="$(IFS=,; printf '%s' "${SELECTED[*]}")"

compute_fingerprint() {
  {
    printf 'policy=%s\nmode=%s\nbase=%s\nstages=%s\n' "$POLICY_VERSION" "$EFFECTIVE_MODE" "$BASE_REF" "$STAGE_LIST"
    if [ -n "$BASE_REF" ]; then
      git -C "$ROOT" diff --binary "$BASE_REF"...HEAD
    fi
    git -C "$ROOT" diff --binary HEAD
    while IFS= read -r -d '' path; do
      printf 'untracked\0%s\0' "$path"
      git -C "$ROOT" hash-object -- "$path"
    done < <(git -C "$ROOT" ls-files -z --others --exclude-standard)
  } | shasum -a 256 | awk '{print $1}'
}

FINGERPRINT="$(compute_fingerprint)"

if [ "$OUTPUT_FORMAT" = json ]; then
  printf '{"policy":%s,"mode":"%s","fingerprint":"%s","stages":[' "$POLICY_VERSION" "$EFFECTIVE_MODE" "$FINGERPRINT"
  separator=""
  for stage in "${SELECTED[@]}"; do
    printf '%s"%s"' "$separator" "$stage"
    separator=,
  done
  printf ']}\n'
else
  printf 'quality-gate policy=%s mode=%s fingerprint=%s stages=%s\n' \
    "$POLICY_VERSION" "$EFFECTIVE_MODE" "$FINGERPRINT" "$STAGE_LIST"
  if [ "$EXPLAIN" = 1 ]; then
    for explanation in "${EXPLANATIONS[@]}"; do
      printf 'quality-gate: reason %s\n' "$explanation"
    done
  fi
fi
if [ "$PLAN_ONLY" = 1 ]; then
  exit 0
fi

mkdir -p "$RUN_DIR"
chmod 0700 "$RESULT_ROOT" "$RUN_DIR" 2>/dev/null || true
printf 'policy\tmode\tstage\tstatus\tduration_seconds\tlog\n' >"$SUMMARY"

manifest_value() {
  local file="$1" key="$2"
  awk -F '\t' -v wanted="$key" '$1 == wanted {print $2; found=1; exit} END {if (!found) exit 1}' "$file"
}

write_manifest() {
  local result="$1" temporary="$RUN_DIR/.manifest.$$"
  {
    printf 'schema\t1\n'
    printf 'policy\t%s\n' "$POLICY_VERSION"
    printf 'mode\t%s\n' "$EFFECTIVE_MODE"
    printf 'source_commit\t%s\n' "$(git -C "$ROOT" rev-parse --verify HEAD)"
    printf 'fingerprint\t%s\n' "$FINGERPRINT"
    printf 'stages\t%s\n' "$STAGE_LIST"
    printf 'result\t%s\n' "$result"
  } >"$temporary"
  chmod 0600 "$temporary"
  mv -f "$temporary" "$MANIFEST"
}

resume_stage_passed() {
  local stage="$1"
  [ -n "$RESUME_DIR" ] || return 1
  awk -F '\t' -v wanted="$stage" \
    '$3 == wanted && ($4 == "passed" || $4 == "reused") {found=1} END {exit !found}' \
    "$RESUME_DIR/summary.tsv"
}

validate_resume() {
  [ -n "$RESUME_DIR" ] || return 0
  [ -d "$RESUME_DIR" ] && [ ! -L "$RESUME_DIR" ] || die 'resume path must be a non-symlink run directory'
  [ -f "$RESUME_DIR/manifest.tsv" ] && [ ! -L "$RESUME_DIR/manifest.tsv" ] || die 'resume manifest is missing or unsafe'
  [ -f "$RESUME_DIR/summary.tsv" ] && [ ! -L "$RESUME_DIR/summary.tsv" ] || die 'resume summary is missing or unsafe'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" schema)" = 1 ] || die 'resume evidence schema is unsupported'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" policy)" = "$POLICY_VERSION" ] || die 'resume evidence uses another policy version'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" mode)" = "$EFFECTIVE_MODE" ] || die 'resume evidence uses another mode'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" stages)" = "$STAGE_LIST" ] || die 'resume evidence has another stage plan'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" fingerprint)" = "$FINGERPRINT" ] || die 'resume evidence does not match the current diff'
}

write_junit() {
  local tests=0 failures=0 skipped=0 stage status duration log
  while IFS=$'\t' read -r _ _ stage status duration log; do
    [ "$stage" = stage ] && continue
    tests=$((tests + 1))
    case "$status" in failed|timeout|interrupted) failures=$((failures + 1)) ;; reused) skipped=$((skipped + 1)) ;; esac
  done <"$SUMMARY"
  {
    printf '<?xml version="1.0" encoding="UTF-8"?>\n'
    printf '<testsuite name="detach-quality-gate" tests="%s" failures="%s" skipped="%s">\n' "$tests" "$failures" "$skipped"
    while IFS=$'\t' read -r _ _ stage status duration log; do
      [ "$stage" = stage ] && continue
      printf '  <testcase classname="quality-gate" name="%s" time="%s">' "$stage" "$duration"
      case "$status" in
        failed|timeout|interrupted) printf '<failure message="%s">See %s</failure>' "$status" "$log" ;;
        reused) printf '<skipped message="reused matching passed evidence"/>' ;;
      esac
      printf '</testcase>\n'
    done <"$SUMMARY"
    printf '</testsuite>\n'
  } >"$JUNIT"
}

validate_resume
write_manifest running

on_signal() {
  if [ -n "$CURRENT_CHILD" ]; then
    kill -TERM "$CURRENT_CHILD" 2>/dev/null || true
    wait "$CURRENT_CHILD" 2>/dev/null || true
  fi
  if [ -n "$CURRENT_STAGE" ]; then
    printf '%s\t%s\t%s\tinterrupted\t-\t%s.log\n' "$POLICY_VERSION" "$MODE" "$CURRENT_STAGE" "$CURRENT_STAGE" >>"$SUMMARY"
  fi
  write_manifest interrupted
  write_junit
  printf 'quality-gate: interrupted; evidence is incomplete (%s)\n' "$SUMMARY" >&2
  exit 130
}
trap on_signal INT TERM HUP

timeout_for_stage() {
  case "$1" in
    static) printf 120 ;;
    gate-contract) printf 120 ;;
    swift) printf 1200 ;;
    app) printf 2400 ;;
    codex|claude|distribution|tmux-runtime) printf 1200 ;;
    release-preflight|publish-preflight|release-workflow) printf 900 ;;
  esac
}

run_bounded() {
  local timeout="$1"
  shift
  /usr/bin/perl -MPOSIX -e '
    my $timeout = shift @ARGV;
    defined(my $pid = fork()) or die "fork failed: $!\n";
    if (!$pid) {
      POSIX::setsid() >= 0 or die "setsid failed: $!\n";
      $ENV{DETACH_RELEASE_TESTS_DETACHED} = 1;
      exec @ARGV or die "exec failed: $!\n";
    }
    my $timed_out = 0;
    local $SIG{ALRM} = sub { $timed_out = 1; kill "TERM", -$pid; };
    local $SIG{INT} = sub { kill "INT", -$pid; };
    local $SIG{TERM} = sub { kill "TERM", -$pid; };
    alarm $timeout;
    while (waitpid($pid, 0) < 0) { next if $!{EINTR}; die "waitpid failed: $!\n"; }
    alarm 0;
    exit 124 if $timed_out;
    exit(($? & 127) ? 128 + ($? & 127) : $? >> 8);
  ' "$timeout" "$@"
}

run_static() {
  local file
  while IFS= read -r -d '' file; do
    [ -f "$ROOT/$file" ] || continue
    case "$file" in
      *.sh|bin/detach|bin/detach-core|scripts/quality-gate|scripts/release-version|scripts/release-lid-probe)
        /bin/bash -n "$ROOT/$file"
        ;;
    esac
  done < <(git -C "$ROOT" ls-files -z --cached --others --exclude-standard)
  if [ -n "$BASE_REF" ]; then
    git -C "$ROOT" diff --check "$BASE_REF"...HEAD
  fi
  git -C "$ROOT" diff --check HEAD
}

run_stage_command() {
  local stage="$1" tmux_bin="$ROOT/app/build/Detach.app/Contents/Resources/DetachCLI/tmux"
  mkdir -p "$ROOT/app/.build/module-cache"
  export CLANG_MODULE_CACHE_PATH="$ROOT/app/.build/module-cache"
  export SWIFTPM_MODULECACHE_OVERRIDE="$ROOT/app/.build/module-cache"
  if [ "$TEST_MODE" = 1 ]; then
    [ -x "$ROOT/tests/quality-gate-fixtures/$stage" ] || die "missing test fixture for $stage"
    env -u DETACH_VERSION -u DETACH_BUILD_VERSION -u DETACH_BUILD_ARCHS \
      -u DETACH_CODESIGN_IDENTITY -u DETACH_RELEASE_BUILD -u DETACH_SPARKLE_VERSION \
      -u DETACH_SPARKLE_FEED_URL -u DETACH_SPARKLE_PUBLIC_ED_KEY -u DETACH_DOWNLOAD_URL \
      "$ROOT/tests/quality-gate-fixtures/$stage"
    return
  fi
  case "$stage" in
    static) run_static ;;
    gate-contract) "$ROOT/tests/quality-gate.sh" ;;
    swift)
      (
        cd -P "$ROOT/app"
        swift test --disable-sandbox
      )
      ;;
    app)
      env -u DETACH_VERSION -u DETACH_BUILD_VERSION -u DETACH_BUILD_ARCHS \
        -u DETACH_CODESIGN_IDENTITY -u DETACH_RELEASE_BUILD -u DETACH_SPARKLE_VERSION \
        -u DETACH_SPARKLE_FEED_URL -u DETACH_SPARKLE_PUBLIC_ED_KEY -u DETACH_DOWNLOAD_URL \
        "$ROOT/app/scripts/make-app.sh"
      "$ROOT/app/scripts/verify-app.sh"
      ;;
    codex)
      [ -x "$tmux_bin" ] || die 'codex gate requires the app stage bundled tmux'
      DETACH_TEST_TMUX_BIN="$tmux_bin" "$ROOT/tests/run.sh"
      ;;
    claude)
      [ -x "$tmux_bin" ] || die 'claude gate requires the app stage bundled tmux'
      DETACH_TEST_TMUX_BIN="$tmux_bin" "$ROOT/tests/run-claude.sh"
      ;;
    distribution) "$ROOT/tests/distribution.sh" ;;
    tmux-runtime) "$ROOT/tests/tmux-runtime.sh" ;;
    release-preflight) "$ROOT/tests/release-preflight.sh" ;;
    publish-preflight) "$ROOT/tests/publish-preflight.sh" ;;
    release-workflow) "$ROOT/tests/release-workflow.sh" ;;
  esac
}

export ROOT BASE_REF TEST_MODE
export -f die run_static run_stage_command

for stage in "${SELECTED[@]}"; do
  CURRENT_STAGE="$stage"
  log="$RUN_DIR/$stage.log"
  if resume_stage_passed "$stage"; then
    printf 'quality-gate: reusing %s from matching evidence %s\n' "$stage" "$RESUME_DIR"
    printf '%s\t%s\t%s\treused\t0\t-\n' "$POLICY_VERSION" "$MODE" "$stage" >>"$SUMMARY"
    continue
  fi
  started="$(date +%s)"
  timeout="${DETACH_QUALITY_GATE_TIMEOUT:-$(timeout_for_stage "$stage")}"
  printf 'quality-gate: running %s (timeout %ss)\n' "$stage" "$timeout"
  set +e
  run_bounded "$timeout" /bin/bash -c 'run_stage_command "$1"' _ "$stage" >"$log" 2>&1 &
  CURRENT_CHILD=$!
  wait "$CURRENT_CHILD"
  status=$?
  CURRENT_CHILD=""
  set -e
  /bin/cat "$log"
  duration=$(($(date +%s) - started))
  if [ "$status" -ne 0 ]; then
    result=failed
    [ "$status" -eq 124 ] && result=timeout
    printf '%s\t%s\t%s\t%s\t%s\t%s.log\n' "$POLICY_VERSION" "$MODE" "$stage" "$result" "$duration" "$stage" >>"$SUMMARY"
    printf 'quality-gate: %s %s; diagnostic rerun: scripts/quality-gate --stage %s\n' "$stage" "$result" "$stage" >&2
    printf 'quality-gate: readiness evidence is incomplete; log: %s\n' "$log" >&2
    OVERALL_STATUS="$status"
    [ "$KEEP_GOING" = 1 ] || break
    continue
  fi
  printf '%s\t%s\t%s\tpassed\t%s\t%s.log\n' "$POLICY_VERSION" "$MODE" "$stage" "$duration" "$stage" >>"$SUMMARY"
done
CURRENT_STAGE=""
write_junit

if [ "$OVERALL_STATUS" -ne 0 ]; then
  write_manifest failed
  printf 'quality-gate: FAIL policy=%s fingerprint=%s evidence=%s junit=%s\n' "$POLICY_VERSION" "$FINGERPRINT" "$SUMMARY" "$JUNIT" >&2
  exit "$OVERALL_STATUS"
elif [ -n "$DIAGNOSTIC_STAGE" ]; then
  write_manifest diagnostic
  printf 'quality-gate: diagnostic stage passed; this is not readiness evidence\n'
else
  write_manifest passed
  printf 'quality-gate: PASS policy=%s fingerprint=%s evidence=%s junit=%s\n' "$POLICY_VERSION" "$FINGERPRINT" "$SUMMARY" "$JUNIT"
fi
