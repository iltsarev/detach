#!/bin/bash

set -euo pipefail

ROOT="$(cd -P "$(dirname "$0")/.." && pwd)"
POLICY_VERSION=8
MODE=change
BASE_REF=""
PLAN_ONLY=0
DIAGNOSTIC_STAGE=""
OUTPUT_FORMAT=text
EXPLAIN=0
KEEP_GOING=0
RESUME_DIR=""
RESUME_LATEST=0
WITHOUT_RELEASE_BUDGET=0
TEST_MODE="${DETACH_QUALITY_GATE_TEST_MODE:-0}"
TEST_REAL_STATIC="${DETACH_QUALITY_GATE_TEST_REAL_STATIC:-0}"
RESULT_ROOT="${DETACH_QUALITY_GATE_RESULT_ROOT:-$ROOT/app/build/quality-gates}"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$"
RUN_DIR="$RESULT_ROOT/$RUN_ID"
SUMMARY="$RUN_DIR/summary.tsv"
MANIFEST="$RUN_DIR/manifest.tsv"
JUNIT="$RUN_DIR/junit.xml"
MARKDOWN="$RUN_DIR/summary.md"
ENVIRONMENT="$RUN_DIR/environment.tsv"
ARTIFACTS="$RUN_DIR/artifacts.tsv"
OVERALL_STATUS=0
FAILURE_COUNT=0
EFFECTIVE_TIMING_WALL=0
RUN_STARTED_EPOCH="$(date +%s)"
RUN_STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
RESOLVED_BASE=""
SOURCE_COMMIT="$(git -C "$ROOT" rev-parse --verify HEAD)"
INPUT_FINGERPRINT=""
RELEASE_BUDGET="$ROOT/tests/release-budget.tsv"

ALL_STAGES=(static gate-contract swift quality-contracts app ui-e2e codex claude distribution tmux-runtime release-preflight publish-preflight release-workflow release-budget)
RELEASE_STAGES=(static gate-contract swift quality-contracts app ui-e2e codex claude distribution tmux-runtime release-preflight publish-preflight release-budget)
SELECTED=()
EXPLANATIONS=()

usage() {
  cat <<'EOF'
usage: scripts/quality-gate [--mode change|repository|release] [--base GIT_REF] [--plan]
                            [--format text|json] [--explain]
                            [--resume RUN_DIR|latest] [--keep-going]
                            [--without-release-budget]
       scripts/quality-gate --list-stages
       scripts/quality-gate --stage NAME

The normal modes are readiness evidence. --stage is a diagnostic rerun only.
EOF
}

LIST_STAGES=0

die() {
  printf 'quality-gate: %s\n' "$*" >&2
  exit 2
}

contains_stage() {
  local wanted="$1" stage
  for stage in "${SELECTED[@]:-}"; do
    [ "$stage" = "$wanted" ] && return 0
  done
  return 1
}

add_stage() {
  local stage="$1" reason="${2:-${IMPACT_REASON:-}}"
  contains_stage "$stage" || SELECTED+=("$stage")
  [ -z "$reason" ] || EXPLANATIONS+=("$reason -> $stage")
}

select_all() {
  local reason="${1:-full repository policy}" stage
  SELECTED=("${ALL_STAGES[@]}")
  for stage in "${ALL_STAGES[@]}"; do
    EXPLANATIONS+=("$reason -> $stage")
  done
}

select_release() {
  SELECTED=("${RELEASE_STAGES[@]}")
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode)
      [ "$#" -ge 2 ] || die '--mode requires a value'
      MODE="$2"
      shift 2
      ;;
    --base)
      [ "$#" -ge 2 ] || die '--base requires a ref'
      BASE_REF="$2"
      shift 2
      ;;
    --plan)
      PLAN_ONLY=1
      shift
      ;;
    --format)
      [ "$#" -ge 2 ] || die '--format requires a value'
      OUTPUT_FORMAT="$2"
      shift 2
      ;;
    --explain)
      EXPLAIN=1
      shift
      ;;
    --resume)
      [ "$#" -ge 2 ] || die '--resume requires a run directory'
      if [ "$2" = latest ]; then
        RESUME_LATEST=1
      else
        RESUME_DIR="$2"
      fi
      shift 2
      ;;
    --keep-going)
      KEEP_GOING=1
      shift
      ;;
    --without-release-budget)
      WITHOUT_RELEASE_BUDGET=1
      shift
      ;;
    --list-stages)
      LIST_STAGES=1
      shift
      ;;
    --stage)
      [ "$#" -ge 2 ] || die '--stage requires a name'
      DIAGNOSTIC_STAGE="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *) die "unknown argument: $1" ;;
  esac
done

case "$TEST_MODE" in 0|1) ;; *) die 'DETACH_QUALITY_GATE_TEST_MODE must be 0 or 1' ;; esac
case "$TEST_REAL_STATIC" in 0|1) ;; *) die 'DETACH_QUALITY_GATE_TEST_REAL_STATIC must be 0 or 1' ;; esac
[ "$TEST_MODE" = 1 ] || [ "$TEST_REAL_STATIC" = 0 ] || die 'real static fixture mode is test-only'
[ "$WITHOUT_RELEASE_BUDGET" = 0 ] || [ "${GITHUB_ACTIONS:-}" = true ] || [ "$TEST_MODE" = 1 ] || \
  die '--without-release-budget is restricted to GitHub Actions'
if [ "$TEST_MODE" != 1 ]; then
  [ -z "${DETACH_QUALITY_GATE_TEST_WALL_SECONDS:-}" ] || die 'quality-gate clock overrides are test-only'
  [ -z "${DETACH_QUALITY_GATE_TEST_CODEX_SECONDS:-}" ] || die 'quality-gate clock overrides are test-only'
  for test_stage in "${ALL_STAGES[@]}"; do
    test_suffix="$(printf '%s' "$test_stage" | tr '[:lower:]-' '[:upper:]_')"
    test_variable="DETACH_QUALITY_GATE_TEST_STAGE_SECONDS_$test_suffix"
    [ -z "${!test_variable:-}" ] || die 'quality-gate clock overrides are test-only'
  done
fi
case "$MODE" in change|repository|release) ;; *) die "invalid mode: $MODE" ;; esac
case "$OUTPUT_FORMAT" in text|json) ;; *) die "invalid format: $OUTPUT_FORMAT" ;; esac
[ -z "$DIAGNOSTIC_STAGE" ] || { [ "$MODE" = change ] && [ -z "$BASE_REF" ] || die '--stage cannot be combined with another selection'; }
[ "$OUTPUT_FORMAT" = text ] || [ "$PLAN_ONLY" = 1 ] || die '--format json requires --plan'
[ "$EXPLAIN" = 0 ] || { [ "$PLAN_ONLY" = 1 ] && [ "$OUTPUT_FORMAT" = text ]; } || die '--explain requires a text plan'
[ -z "$RESUME_DIR" ] || { [ "$PLAN_ONLY" = 0 ] && [ -z "$DIAGNOSTIC_STAGE" ]; } || die '--resume cannot be combined with --plan or --stage'
[ "$RESUME_LATEST" = 0 ] || { [ "$PLAN_ONLY" = 0 ] && [ -z "$DIAGNOSTIC_STAGE" ]; } || die '--resume latest cannot be combined with --plan or --stage'
[ "$LIST_STAGES" = 0 ] || { [ "$PLAN_ONLY" = 0 ] && [ -z "$DIAGNOSTIC_STAGE" ] && [ -z "$BASE_REF" ] && [ "$MODE" = change ] && [ "$KEEP_GOING" = 0 ] && [ -z "$RESUME_DIR" ] && [ "$RESUME_LATEST" = 0 ] && [ "$OUTPUT_FORMAT" = text ] && [ "$EXPLAIN" = 0 ]; } || die '--list-stages cannot be combined with another option'

stage_exists() {
  local wanted="$1" stage
  for stage in "${ALL_STAGES[@]}"; do
    [ "$stage" = "$wanted" ] && return 0
  done
  return 1
}

if [ "$LIST_STAGES" = 1 ]; then
  printf '%s\n' "${ALL_STAGES[@]}"
  exit 0
fi

changed_entries() {
  if [ -n "$RESOLVED_BASE" ]; then
    git -C "$ROOT" diff --name-status -z --find-renames "$RESOLVED_BASE"...HEAD
  fi
  git -C "$ROOT" diff --name-status -z --find-renames HEAD
  while IFS= read -r -d '' path; do
    printf 'A\0%s\0' "$path"
  done < <(git -C "$ROOT" ls-files -z --others --exclude-standard)
}

if [ -n "$BASE_REF" ]; then
  RESOLVED_BASE="$(git -C "$ROOT" rev-parse --verify "$BASE_REF^{commit}")"
fi

select_for_path() {
  local path="$1" change="${2:-changed}"
  IMPACT_REASON="$change $path"
  add_stage static
  case "$path" in
    .github/workflows/quality-gates.yml|docs/quality-gates.md|scripts/quality-gate|scripts/quality-history|tests/quality-gate.sh|tests/quality-contracts.sh|tests/quality-baseline.tsv|tests/quality-ratchet.sh|tests/quality-ratchet-contract.sh|tests/release-budget.tsv|tests/release-budget-ratchet.sh|tests/release-budget-ratchet-contract.sh|tests/shell-safety.sh|tests/shell-safety-contract.sh|tests/quality-history-contract.sh)
      select_all "$change gate policy file $path"
      ;;
    tests/docs-contract.sh)
      ;;
    *.md|docs/assets/*|AGENTS.md|CLAUDE.md)
      ;;
    app/Sources/DetachKit/DetachState*.swift|app/Sources/DetachKit/Session*.swift|app/Sources/DetachKit/Storage*.swift|app/Sources/DetachState/*.swift)
      add_stage swift; add_stage quality-contracts; add_stage app; add_stage codex; add_stage claude
      add_stage distribution; add_stage tmux-runtime; add_stage release-budget
      ;;
    app/Sources/DetachKit/DetachPower*.swift|app/Sources/DetachKit/Power*.swift|app/Sources/DetachPower/*.swift|app/Sources/DetachPowerHelper/*.swift)
      add_stage swift; add_stage quality-contracts; add_stage app; add_stage distribution
      add_stage tmux-runtime; add_stage release-budget
      ;;
    app/Sources/*)
      add_stage swift; add_stage quality-contracts; add_stage app; add_stage release-budget
      ;;
    app/Tests/*)
      add_stage swift; add_stage quality-contracts; add_stage release-budget
      ;;
    app/Package.swift|app/Package.resolved)
      add_stage swift; add_stage quality-contracts; add_stage app; add_stage tmux-runtime; add_stage release-budget
      ;;
    app/Resources/*)
      add_stage swift; add_stage quality-contracts; add_stage app; add_stage tmux-runtime; add_stage release-budget
      ;;
    bin/*)
      add_stage app; add_stage codex; add_stage claude; add_stage distribution; add_stage tmux-runtime; add_stage release-budget
      ;;
    install.sh|scripts/install.sh)
      add_stage app; add_stage distribution; add_stage tmux-runtime; add_stage release-budget
      ;;
    scripts/build-tmux.sh)
      add_stage app; add_stage codex; add_stage claude; add_stage tmux-runtime; add_stage release-budget
      ;;
    app/scripts/release.sh|app/scripts/publish-release.sh|app/scripts/make-dmg.sh|app/scripts/verify-appcast.sh|scripts/release-version|scripts/release-lid-probe|VERSION|BUILD)
      add_stage app; add_stage release-preflight; add_stage publish-preflight; add_stage release-workflow; add_stage release-budget
      ;;
    app/scripts/*)
      add_stage app; add_stage tmux-runtime; add_stage release-preflight; add_stage release-budget
      ;;
    tests/run.sh|tests/fake-codex)
      add_stage app; add_stage codex; add_stage release-budget
      ;;
    tests/run-claude.sh|tests/fake-claude)
      add_stage app; add_stage claude; add_stage release-budget
      ;;
    tests/distribution.sh)
      add_stage app; add_stage distribution; add_stage release-budget
      ;;
    tests/tmux-runtime.sh|tests/power-smoke.sh)
      add_stage app; add_stage tmux-runtime; add_stage release-budget
      ;;
    tests/ui-e2e.sh|tests/ui-e2e-contract.sh|tests/fake-ui-cli)
      add_stage app; add_stage release-budget
      ;;
    tests/release-preflight.sh)
      add_stage release-preflight; add_stage release-budget
      ;;
    tests/publish-preflight.sh)
      add_stage publish-preflight; add_stage release-budget
      ;;
    tests/release-workflow.sh)
      add_stage release-workflow; add_stage release-budget
      ;;
    .gitignore|.gitattributes)
      ;;
    *)
      printf 'quality-gate: unknown impact for %s; selecting repository gate\n' "$path" >&2
      select_all "$change unclassified path $path"
      ;;
  esac
}

if [ -n "$DIAGNOSTIC_STAGE" ]; then
  stage_exists "$DIAGNOSTIC_STAGE" || die "unknown stage: $DIAGNOSTIC_STAGE"
  SELECTED=("$DIAGNOSTIC_STAGE")
elif [ "$MODE" = repository ]; then
  select_all
elif [ "$MODE" = release ]; then
  select_release
else
  while IFS= read -r -d '' status && IFS= read -r -d '' path; do
    case "$status" in
      R*|C*)
        IFS= read -r -d '' new_path || die 'malformed rename/copy entry from Git'
        select_for_path "$path" "$status old"
        select_for_path "$new_path" "$status new"
        ;;
      *) select_for_path "$path" "$status" ;;
    esac
  done < <(changed_entries)
  if [ "${#SELECTED[@]}" -eq 0 ]; then
    printf 'quality-gate: no diff to classify; selecting repository gate\n' >&2
    select_all 'empty diff fail-safe policy'
  fi
fi

# A selected packaged-app build is never readiness evidence by itself. Its
# hermetic accessibility smoke must exercise that exact fresh executable.
if contains_stage app && [ -z "$DIAGNOSTIC_STAGE" ]; then
  add_stage ui-e2e 'mandatory packaged-app prerequisite'
fi

# Preserve the canonical cheap-to-expensive order after taking the union.
ordered=()
for stage in "${ALL_STAGES[@]}"; do
  contains_stage "$stage" && ordered+=("$stage")
done
SELECTED=("${ordered[@]}")
if [ "$WITHOUT_RELEASE_BUDGET" = 1 ]; then
  ordered=()
  for stage in "${SELECTED[@]}"; do
    [ "$stage" = release-budget ] || ordered+=("$stage")
  done
  SELECTED=("${ordered[@]}")
fi

EFFECTIVE_MODE="$([ -n "$DIAGNOSTIC_STAGE" ] && printf diagnostic || printf '%s' "$MODE")"
STAGE_LIST="$(IFS=,; printf '%s' "${SELECTED[*]}")"

compute_input_fingerprint() {
  {
    printf 'policy=%s\nsource_commit=%s\nbase_commit=%s\n' "$POLICY_VERSION" "$SOURCE_COMMIT" "$RESOLVED_BASE"
    if [ -n "$RESOLVED_BASE" ]; then
      git -C "$ROOT" diff --binary "$RESOLVED_BASE"...HEAD
    fi
    git -C "$ROOT" diff --binary HEAD
    while IFS= read -r -d '' path; do
      printf 'untracked\0%s\0' "$path"
      git -C "$ROOT" hash-object -- "$path"
    done < <(git -C "$ROOT" ls-files -z --others --exclude-standard)
  } | shasum -a 256 | awk '{print $1}'
}

INPUT_FINGERPRINT="$(compute_input_fingerprint)"
FINGERPRINT="$(printf 'input=%s\nmode=%s\nstages=%s\n' "$INPUT_FINGERPRINT" "$EFFECTIVE_MODE" "$STAGE_LIST" | shasum -a 256 | awk '{print $1}')"

if [ "$OUTPUT_FORMAT" = json ]; then
  printf '{"policy":%s,"mode":"%s","source_commit":"%s","base_commit":"%s","input_fingerprint":"%s","fingerprint":"%s","stages":[' \
    "$POLICY_VERSION" "$EFFECTIVE_MODE" "$SOURCE_COMMIT" "$RESOLVED_BASE" "$INPUT_FINGERPRINT" "$FINGERPRINT"
  separator=""
  for stage in "${SELECTED[@]}"; do
    printf '%s"%s"' "$separator" "$stage"
    separator=,
  done
  printf ']}\n'
else
  printf 'quality-gate policy=%s mode=%s fingerprint=%s stages=%s\n' \
    "$POLICY_VERSION" "$EFFECTIVE_MODE" "$FINGERPRINT" "$STAGE_LIST"
  if [ "$EXPLAIN" = 1 ]; then
    for explanation in "${EXPLANATIONS[@]}"; do
      printf 'quality-gate: reason %s\n' "$explanation"
    done
  fi
fi
if [ "$PLAN_ONLY" = 1 ]; then
  exit 0
fi

[ ! -e "$RESULT_ROOT" ] || [ -d "$RESULT_ROOT" ] && [ ! -L "$RESULT_ROOT" ] || die 'result root must be a non-symlink directory'
mkdir -p "$RUN_DIR"
[ -d "$RUN_DIR" ] && [ ! -L "$RUN_DIR" ] || die 'run path must be a non-symlink directory'
chmod 0700 "$RESULT_ROOT" "$RUN_DIR" 2>/dev/null || true
printf 'policy\tmode\tstage\tstatus\tduration_seconds\tlog\tlog_sha256\torigin_run\n' >"$SUMMARY"
chmod 0600 "$SUMMARY"
if [ "$TEST_MODE" = 1 ]; then
  {
    printf 'schema\t1\n'
    printf 'os_product_version\ttest\n'
    printf 'os_build_version\ttest\n'
    printf 'architecture\ttest\n'
    printf 'xcode\ttest\n'
    printf 'swift\ttest\n'
    printf 'github_actions\tfalse\n'
    printf 'managed_sandbox_declared\tfalse\n'
  } >"$ENVIRONMENT"
else
  {
    printf 'schema\t1\n'
    printf 'os_product_version\t%s\n' "$(sw_vers -productVersion 2>/dev/null || printf unknown)"
    printf 'os_build_version\t%s\n' "$(sw_vers -buildVersion 2>/dev/null || printf unknown)"
    printf 'architecture\t%s\n' "$(uname -m)"
    printf 'xcode\t%s\n' "$(xcodebuild -version 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//' || printf unavailable)"
    printf 'swift\t%s\n' "$(swift --version 2>/dev/null | head -1 || printf unavailable)"
    printf 'github_actions\t%s\n' "${GITHUB_ACTIONS:-false}"
    if [ -n "${CODEX_SANDBOX:-}" ]; then
      printf 'managed_sandbox_declared\ttrue\n'
    else
      printf 'managed_sandbox_declared\tfalse\n'
    fi
  } >"$ENVIRONMENT"
fi
chmod 0600 "$ENVIRONMENT"
printf 'schema\t1\n' >"$ARTIFACTS"
chmod 0600 "$ARTIFACTS"

manifest_value() {
  local file="$1" key="$2"
  awk -F '\t' -v wanted="$key" '$1 == wanted {count++; value=$2} END {if (count != 1) exit 1; print value}' "$file"
}

write_artifact_inventory() {
  local file relative digest temporary="$RUN_DIR/.artifacts.$$"
  printf 'schema\t1\n' >"$temporary"
  while IFS= read -r file; do
    [ -f "$file" ] && [ ! -L "$file" ] || die 'diagnostic artifact is missing or unsafe'
    relative="${file#"$RUN_DIR/"}"
    case "$relative" in *$'\t'*|*$'\n'*|/*|../*|*/../*) die 'diagnostic artifact path is unsafe' ;; esac
    digest="$(shasum -a 256 "$file" | awk '{print $1}')"
    printf 'file\t%s\t%s\n' "$relative" "$digest" >>"$temporary"
  done < <(find "$RUN_DIR" -mindepth 2 -maxdepth 2 -type f \
    \( -path '*/ui-e2e-artifacts/*' -o -path '*/codex-artifacts/*' -o -path '*/claude-artifacts/*' \) \
    -print | LC_ALL=C sort)
  chmod 0600 "$temporary"
  mv -f "$temporary" "$ARTIFACTS"
}

write_manifest() {
  local result="$1" temporary="$RUN_DIR/.manifest.$$" finished_at="" duration="" summary_sha256=""
  local resumed_from_run="" resumed_from_manifest_sha256="" timing_wall_seconds="" environment_sha256 artifacts_sha256
  [ "$result" = running ] || write_artifact_inventory
  environment_sha256="$(shasum -a 256 "$ENVIRONMENT" | awk '{print $1}')"
  artifacts_sha256="$(shasum -a 256 "$ARTIFACTS" | awk '{print $1}')"
  if [ -n "$RESUME_DIR" ]; then
    resumed_from_run="$(basename "$RESUME_DIR")"
    resumed_from_manifest_sha256="$(shasum -a 256 "$RESUME_DIR/manifest.tsv" | awk '{print $1}')"
  fi
  if [ "$result" != running ]; then
    finished_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    duration="$(($(date +%s) - RUN_STARTED_EPOCH))"
    summary_sha256="$(shasum -a 256 "$SUMMARY" | awk '{print $1}')"
    timing_wall_seconds="${EFFECTIVE_TIMING_WALL:-$duration}"
    [ "$timing_wall_seconds" -gt 0 ] || timing_wall_seconds="$duration"
  fi
  {
    printf 'schema\t3\n'
    printf 'policy\t%s\n' "$POLICY_VERSION"
    printf 'mode\t%s\n' "$EFFECTIVE_MODE"
    printf 'source_commit\t%s\n' "$SOURCE_COMMIT"
    printf 'base_commit\t%s\n' "$RESOLVED_BASE"
    printf 'input_fingerprint\t%s\n' "$INPUT_FINGERPRINT"
    printf 'fingerprint\t%s\n' "$FINGERPRINT"
    printf 'stages\t%s\n' "$STAGE_LIST"
    printf 'started_at\t%s\n' "$RUN_STARTED_AT"
    printf 'finished_at\t%s\n' "$finished_at"
    printf 'duration_seconds\t%s\n' "$duration"
    printf 'timing_wall_seconds\t%s\n' "$timing_wall_seconds"
    printf 'resumed_from_run\t%s\n' "$resumed_from_run"
    printf 'resumed_from_manifest_sha256\t%s\n' "$resumed_from_manifest_sha256"
    printf 'environment_sha256\t%s\n' "$environment_sha256"
    printf 'artifacts_sha256\t%s\n' "$artifacts_sha256"
    printf 'summary_sha256\t%s\n' "$summary_sha256"
    printf 'result\t%s\n' "$result"
  } >"$temporary"
  chmod 0600 "$temporary"
  mv -f "$temporary" "$MANIFEST"
}

resume_stage_passed() {
  local stage="$1"
  [ -n "$RESUME_DIR" ] || return 1
  awk -F '\t' -v wanted="$stage" \
    'NR == 1 {next} $3 == wanted {count++; valid=($4 == "passed" || $4 == "reused")} END {exit !(count == 1 && valid)}' \
    "$RESUME_DIR/summary.tsv"
}

resume_stage_value() {
  local stage="$1" column="$2"
  awk -F '\t' -v wanted="$stage" -v column="$column" \
    'NR > 1 && $3 == wanted {count++; value=$column} END {if (count != 1) exit 1; print value}' \
    "$RESUME_DIR/summary.tsv"
}

stage_in_list() {
  local wanted="$1" list="$2" item
  IFS=, read -r -a items <<<"$list"
  for item in "${items[@]:-}"; do
    [ "$item" = "$wanted" ] && return 0
  done
  return 1
}

resolve_latest_resume() {
  local candidate manifest candidate_result candidate_stages stage covered
  [ "$RESUME_LATEST" = 1 ] || return 0
  [ -d "$RESULT_ROOT" ] || die 'no previous quality-gate evidence exists'
  while IFS= read -r candidate; do
    manifest="$candidate/manifest.tsv"
    [ -f "$manifest" ] && [ ! -L "$manifest" ] || continue
    [ "$(manifest_value "$manifest" schema 2>/dev/null || true)" = 3 ] || continue
    [ "$(manifest_value "$manifest" policy 2>/dev/null || true)" = "$POLICY_VERSION" ] || continue
    [ "$(manifest_value "$manifest" source_commit 2>/dev/null || true)" = "$SOURCE_COMMIT" ] || continue
    [ "$(manifest_value "$manifest" base_commit 2>/dev/null || true)" = "$RESOLVED_BASE" ] || continue
    [ "$(manifest_value "$manifest" input_fingerprint 2>/dev/null || true)" = "$INPUT_FINGERPRINT" ] || continue
    candidate_result="$(manifest_value "$manifest" result 2>/dev/null || true)"
    case "$candidate_result" in passed|failed|interrupted) ;; *) continue ;; esac
    candidate_stages="$(manifest_value "$manifest" stages 2>/dev/null || true)"
    covered=1
    for stage in "${SELECTED[@]}"; do
      if ! stage_in_list "$stage" "$candidate_stages"; then
        covered=0
        break
      fi
    done
    [ "$covered" = 1 ] || continue
    RESUME_DIR="$candidate"
    printf 'quality-gate: selected latest compatible evidence %s\n' "$RESUME_DIR"
    return 0
  done < <(find "$RESULT_ROOT" -mindepth 1 -maxdepth 1 -type d -not -path "$RUN_DIR" -print | LC_ALL=C sort -r)
  die 'no compatible previous quality-gate evidence exists'
}

validate_summary() {
  local file="$1" prior_stages="$2" prior_mode="$3" stage status duration log log_sha256 origin_run actual_sha256
  [ "$(head -n 1 "$file")" = $'policy\tmode\tstage\tstatus\tduration_seconds\tlog\tlog_sha256\torigin_run' ] || die 'resume summary has an invalid schema'
  awk -F '\t' -v policy="$POLICY_VERSION" -v mode="$prior_mode" \
    'NR > 1 {if (NF != 8 || $1 != policy || $2 != mode) exit 1; seen[$3]++; if (seen[$3] > 1) exit 1}' \
    "$file" || die 'resume summary contains invalid or duplicate stage records'
  while IFS=$'\t' read -r _ _ stage status duration log log_sha256 origin_run; do
    [ "$stage" = stage ] && continue
    stage_exists "$stage" || die "resume summary contains unknown stage: $stage"
    stage_in_list "$stage" "$prior_stages" || die "resume summary contains unplanned stage: $stage"
    case "$status" in passed|reused|failed|environment-failed|timeout|interrupted|blocked) ;; *) die "resume summary contains invalid status: $status" ;; esac
    [[ "$duration" =~ ^[0-9]+$ ]] || die "resume summary contains invalid duration: $stage"
    case "$log" in
      -)
        [ "$log_sha256" = - ] || die "resume summary has a digest without a log: $stage"
        case "$status" in passed|reused) die "resume summary has no log for reusable stage: $stage" ;; esac
        ;;
      */*|.|..) die "resume summary contains an unsafe log path: $stage" ;;
      *)
        [ -f "$(dirname "$file")/$log" ] && [ ! -L "$(dirname "$file")/$log" ] || \
          die "resume summary log is missing or unsafe: $stage"
        actual_sha256="$(shasum -a 256 "$(dirname "$file")/$log" | awk '{print $1}')"
        [ "$actual_sha256" = "$log_sha256" ] || die "resume summary log digest does not match: $stage"
        ;;
    esac
    [ "$origin_run" = - ] || [[ "$origin_run" =~ ^[A-Za-z0-9._-]+$ ]] || \
      die "resume summary contains an unsafe origin: $stage"
  done <"$file"
}

validate_resume() {
  local resume_timing_wall resume_parent_run resume_parent_digest resume_parent_manifest actual_parent_digest
  local expected_environment_sha256 actual_environment_sha256 expected_artifacts_sha256 actual_artifacts_sha256
  local artifact_kind artifact_path artifact_sha256 actual_artifact_sha256
  local chain_dir chain_manifest chain_seen
  resolve_latest_resume
  [ -n "$RESUME_DIR" ] || return 0
  [ -d "$RESUME_DIR" ] && [ ! -L "$RESUME_DIR" ] || die 'resume path must be a non-symlink run directory'
  [ -f "$RESUME_DIR/manifest.tsv" ] && [ ! -L "$RESUME_DIR/manifest.tsv" ] || die 'resume manifest is missing or unsafe'
  [ -f "$RESUME_DIR/summary.tsv" ] && [ ! -L "$RESUME_DIR/summary.tsv" ] || die 'resume summary is missing or unsafe'
  [ -f "$RESUME_DIR/environment.tsv" ] && [ ! -L "$RESUME_DIR/environment.tsv" ] || die 'resume environment evidence is missing or unsafe'
  [ -f "$RESUME_DIR/artifacts.tsv" ] && [ ! -L "$RESUME_DIR/artifacts.tsv" ] || die 'resume artifact evidence is missing or unsafe'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" schema)" = 3 ] || die 'resume evidence schema is unsupported'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" policy)" = "$POLICY_VERSION" ] || die 'resume evidence uses another policy version'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" source_commit)" = "$SOURCE_COMMIT" ] || die 'resume evidence uses another source commit'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" base_commit)" = "$RESOLVED_BASE" ] || die 'resume evidence uses another base commit'
  [ "$(manifest_value "$RESUME_DIR/manifest.tsv" input_fingerprint)" = "$INPUT_FINGERPRINT" ] || die 'resume evidence does not match the current input'
  expected_environment_sha256="$(manifest_value "$RESUME_DIR/manifest.tsv" environment_sha256)"
  actual_environment_sha256="$(shasum -a 256 "$RESUME_DIR/environment.tsv" | awk '{print $1}')"
  [ "$actual_environment_sha256" = "$expected_environment_sha256" ] || die 'resume environment digest does not match its manifest'
  expected_artifacts_sha256="$(manifest_value "$RESUME_DIR/manifest.tsv" artifacts_sha256)"
  actual_artifacts_sha256="$(shasum -a 256 "$RESUME_DIR/artifacts.tsv" | awk '{print $1}')"
  [ "$actual_artifacts_sha256" = "$expected_artifacts_sha256" ] || die 'resume artifact inventory digest does not match its manifest'
  [ "$(head -n 1 "$RESUME_DIR/artifacts.tsv")" = $'schema\t1' ] || die 'resume artifact inventory schema is invalid'
  while IFS=$'\t' read -r artifact_kind artifact_path artifact_sha256; do
    [ "$artifact_kind" = schema ] && continue
    [ "$artifact_kind" = file ] || die 'resume artifact inventory contains an unknown record'
    case "$artifact_path" in /*|../*|*/../*|*$'\n'*|*$'\t'*) die 'resume artifact inventory path is unsafe' ;; esac
    case "$artifact_path" in ui-e2e-artifacts/*|codex-artifacts/*|claude-artifacts/*) ;; *) die 'resume artifact inventory path is unapproved' ;; esac
    [[ "$artifact_sha256" =~ ^[0-9a-f]{64}$ ]] || die 'resume artifact inventory digest is invalid'
    [ -f "$RESUME_DIR/$artifact_path" ] && [ ! -L "$RESUME_DIR/$artifact_path" ] || die 'resume diagnostic artifact is missing or unsafe'
    actual_artifact_sha256="$(shasum -a 256 "$RESUME_DIR/$artifact_path" | awk '{print $1}')"
    [ "$actual_artifact_sha256" = "$artifact_sha256" ] || die 'resume diagnostic artifact digest does not match'
  done <"$RESUME_DIR/artifacts.tsv"
  resume_timing_wall="$(manifest_value "$RESUME_DIR/manifest.tsv" timing_wall_seconds)"
  [[ "$resume_timing_wall" =~ ^[0-9]+$ ]] || die 'resume evidence timing wall duration is invalid'
  chain_dir="$RESUME_DIR"
  chain_seen=",$(basename "$chain_dir"),"
  while :; do
    chain_manifest="$chain_dir/manifest.tsv"
    resume_parent_run="$(manifest_value "$chain_manifest" resumed_from_run)"
    resume_parent_digest="$(manifest_value "$chain_manifest" resumed_from_manifest_sha256)"
    [ -n "$resume_parent_run" ] || {
      [ -z "$resume_parent_digest" ] || die 'resume evidence has a parent digest without a parent run'
      break
    }
    [[ "$resume_parent_run" =~ ^[A-Za-z0-9._-]+$ ]] || die 'resume evidence parent run is unsafe'
    [[ "$resume_parent_digest" =~ ^[0-9a-f]{64}$ ]] || die 'resume evidence parent digest is invalid'
    case "$chain_seen" in *",$resume_parent_run,"*) die 'resume evidence parent chain contains a cycle' ;; esac
    resume_parent_manifest="$(dirname "$chain_dir")/$resume_parent_run/manifest.tsv"
    [ -f "$resume_parent_manifest" ] && [ ! -L "$resume_parent_manifest" ] || die 'resume evidence parent manifest is missing or unsafe'
    actual_parent_digest="$(shasum -a 256 "$resume_parent_manifest" | awk '{print $1}')"
    [ "$actual_parent_digest" = "$resume_parent_digest" ] || die 'resume evidence parent manifest digest does not match'
    [ "$(manifest_value "$resume_parent_manifest" schema)" = 3 ] || die 'resume evidence parent schema is unsupported'
    [ "$(manifest_value "$resume_parent_manifest" policy)" = "$POLICY_VERSION" ] || die 'resume evidence parent policy does not match'
    [ "$(manifest_value "$resume_parent_manifest" source_commit)" = "$SOURCE_COMMIT" ] || die 'resume evidence parent source commit does not match'
    [ "$(manifest_value "$resume_parent_manifest" base_commit)" = "$RESOLVED_BASE" ] || die 'resume evidence parent base commit does not match'
    [ "$(manifest_value "$resume_parent_manifest" input_fingerprint)" = "$INPUT_FINGERPRINT" ] || die 'resume evidence parent input does not match'
    chain_seen="$chain_seen$resume_parent_run,"
    chain_dir="$(dirname "$chain_dir")/$resume_parent_run"
  done
  prior_result="$(manifest_value "$RESUME_DIR/manifest.tsv" result)"
  case "$prior_result" in passed|failed|interrupted) ;; *) die 'resume evidence is not from a completed run' ;; esac
  prior_stages="$(manifest_value "$RESUME_DIR/manifest.tsv" stages)"
  prior_mode="$(manifest_value "$RESUME_DIR/manifest.tsv" mode)"
  expected_summary_sha256="$(manifest_value "$RESUME_DIR/manifest.tsv" summary_sha256)"
  actual_summary_sha256="$(shasum -a 256 "$RESUME_DIR/summary.tsv" | awk '{print $1}')"
  [ "$actual_summary_sha256" = "$expected_summary_sha256" ] || die 'resume summary digest does not match its manifest'
  for stage in "${SELECTED[@]}"; do
    stage_in_list "$stage" "$prior_stages" || die "resume evidence does not cover selected stage: $stage"
  done
  validate_summary "$RESUME_DIR/summary.tsv" "$prior_stages" "$prior_mode"
}

write_junit() {
  local tests=0 failures=0 skipped=0 stage status duration log
  while IFS=$'\t' read -r _ _ stage status duration log _ _; do
    [ "$stage" = stage ] && continue
    tests=$((tests + 1))
    case "$status" in failed|environment-failed|timeout|interrupted) failures=$((failures + 1)) ;; reused|blocked) skipped=$((skipped + 1)) ;; esac
  done <"$SUMMARY"
  {
    printf '<?xml version="1.0" encoding="UTF-8"?>\n'
    printf '<testsuite name="detach-quality-gate" tests="%s" failures="%s" skipped="%s">\n' "$tests" "$failures" "$skipped"
    while IFS=$'\t' read -r _ _ stage status duration log _ _; do
      [ "$stage" = stage ] && continue
      printf '  <testcase classname="quality-gate" name="%s" time="%s">' "$(xml_escape "$stage")" "$(xml_escape "$duration")"
      case "$status" in
        failed|environment-failed|timeout|interrupted) printf '<failure message="%s">See %s</failure>' "$(xml_escape "$status")" "$(xml_escape "$log")" ;;
        reused) printf '<skipped message="reused matching passed evidence"/>' ;;
        blocked) printf '<skipped message="prerequisite failed"/>' ;;
      esac
      printf '</testcase>\n'
    done <"$SUMMARY"
    printf '</testsuite>\n'
  } >"$JUNIT"
}

xml_escape() {
  printf '%s' "$1" | /usr/bin/perl -pe 's/&/&amp;/g; s/</&lt;/g; s/>/&gt;/g; s/"/&quot;/g; s/'"'"'/&apos;/g'
}

write_markdown() {
  local stage status duration log origin_run
  {
    printf '# Quality gate\n\n'
    printf -- '- Policy: `%s`\n' "$POLICY_VERSION"
    printf -- '- Mode: `%s`\n' "$EFFECTIVE_MODE"
    printf -- '- Source: `%s`\n' "$SOURCE_COMMIT"
    printf -- '- Fingerprint: `%s`\n\n' "$FINGERPRINT"
    printf '| Stage | Status | Seconds | Log | Origin |\n'
    printf '| --- | --- | ---: | --- | --- |\n'
    while IFS=$'\t' read -r _ _ stage status duration log _ origin_run; do
      [ "$stage" = stage ] && continue
      printf '| `%s` | %s | %s | `%s` | `%s` |\n' "$stage" "$status" "$duration" "$log" "$origin_run"
    done <"$SUMMARY"
  } >"$MARKDOWN"
  chmod 0600 "$MARKDOWN"
}

validate_resume
write_manifest running

on_signal() {
  local pid_file pid stage result_file
  for pid_file in "$RUN_DIR"/.stage-*.pid; do
    [ -f "$pid_file" ] || continue
    pid="$(cat "$pid_file")"
    kill -TERM "$pid" 2>/dev/null || true
  done
  for pid_file in "$RUN_DIR"/.stage-*.pid; do
    [ -f "$pid_file" ] || continue
    pid="$(cat "$pid_file")"
    wait "$pid" 2>/dev/null || true
    stage="$(basename "$pid_file")"
    stage="${stage#.stage-}"
    stage="${stage%.pid}"
    result_file="$RUN_DIR/.stage-$stage.result"
    [ -f "$result_file" ] || write_stage_result "$stage" interrupted 0 "$stage.log" 130
  done
  assemble_summary
  write_manifest interrupted
  write_junit
  write_markdown
  printf 'quality-gate: interrupted; evidence is incomplete (%s)\n' "$SUMMARY" >&2
  exit 130
}
trap on_signal INT TERM HUP

timeout_for_stage() {
  case "$1" in
    static) printf 120 ;;
    gate-contract) printf 300 ;;
    swift|quality-contracts) printf 1200 ;;
    app) printf 2400 ;;
    ui-e2e) printf 40 ;;
    codex|claude|distribution|tmux-runtime) printf 1200 ;;
    release-preflight|publish-preflight|release-workflow) printf 900 ;;
  esac
}

effective_timeout_for_stage() {
  local stage="$1" suffix variable_name override timeout
  suffix="$(printf '%s' "$stage" | tr '[:lower:]-' '[:upper:]_')"
  variable_name="DETACH_QUALITY_GATE_TIMEOUT_$suffix"
  override="${!variable_name:-}"
  timeout="${override:-${DETACH_QUALITY_GATE_TIMEOUT:-$(timeout_for_stage "$stage")}}"
  [[ "$timeout" =~ ^[1-9][0-9]*$ ]] || die "timeout for $stage must be a positive integer"
  printf '%s' "$timeout"
}

run_bounded() {
  local timeout="$1"
  shift
  /usr/bin/perl -MPOSIX -e '
    my $timeout = shift @ARGV;
    defined(my $pid = fork()) or die "fork failed: $!\n";
    if (!$pid) {
      POSIX::setsid() >= 0 or die "setsid failed: $!\n";
      $ENV{DETACH_RELEASE_TESTS_DETACHED} = 1;
      exec @ARGV or die "exec failed: $!\n";
    }
    my $timed_out = 0;
    local $SIG{ALRM} = sub { $timed_out = 1; kill "TERM", -$pid; };
    local $SIG{INT} = sub { kill "INT", -$pid; };
    local $SIG{TERM} = sub { kill "TERM", -$pid; };
    alarm $timeout;
    while (waitpid($pid, 0) < 0) { next if $!{EINTR}; die "waitpid failed: $!\n"; }
    alarm 0;
    exit 124 if $timed_out;
    exit(($? & 127) ? 128 + ($? & 127) : $? >> 8);
  ' "$timeout" "$@"
}

static_shell_files() {
  if [ "$MODE" != change ] || [ -n "$DIAGNOSTIC_STAGE" ]; then
    git -C "$ROOT" ls-files -z --cached --others --exclude-standard
    return
  fi
  while IFS= read -r -d '' status && IFS= read -r -d '' path; do
    case "$status" in
      R*|C*)
        IFS= read -r -d '' new_path || die 'malformed rename/copy entry from Git'
        printf '%s\0%s\0' "$path" "$new_path"
        ;;
      *) printf '%s\0' "$path" ;;
    esac
  done < <(changed_entries)
}

run_static() {
  local file
  while IFS= read -r -d '' file; do
    [ -f "$ROOT/$file" ] || continue
    case "$file" in
      *.sh|bin/detach|bin/detach-core|scripts/quality-gate|scripts/release-version|scripts/release-lid-probe)
        /bin/bash -n "$ROOT/$file"
        ;;
    esac
  done < <(static_shell_files)
  if [ -n "$RESOLVED_BASE" ]; then
    git -C "$ROOT" diff --check "$RESOLVED_BASE"...HEAD
  fi
  git -C "$ROOT" diff --check HEAD
  "$ROOT/tests/docs-contract.sh"
  "$ROOT/tests/quality-ratchet.sh"
  "$ROOT/tests/release-budget-ratchet.sh"
  "$ROOT/tests/shell-safety.sh"
}

run_tmux_socket_preflight() {
  local tmux_bin="$1" preflight_root socket status=0
  preflight_root="$(mktemp -d /private/tmp/detach-quality-tmux-preflight.XXXXXX)"
  socket="$preflight_root/tmux.sock"
  "$tmux_bin" -S "$socket" new-session -d -s detach-quality-preflight /bin/sleep 1 || status=$?
  if [ "$status" -eq 0 ]; then
    "$tmux_bin" -S "$socket" kill-server >/dev/null 2>&1 || true
  else
    printf 'quality-gate environment preflight: bundled tmux could not create a private socket\n' >&2
  fi
  case "$preflight_root" in /private/tmp/detach-quality-tmux-preflight.*) rm -rf "$preflight_root" ;; esac
  return "$status"
}

run_stage_command() {
  local stage="$1" payload_root="$ROOT/app/build/Detach.app/Contents/Resources/DetachCLI"
  local tmux_bin="$payload_root/tmux" state_bin="$payload_root/detach-state"
  mkdir -p "$ROOT/app/.build/module-cache"
  export CLANG_MODULE_CACHE_PATH="$ROOT/app/.build/module-cache"
  export SWIFTPM_MODULECACHE_OVERRIDE="$ROOT/app/.build/module-cache"
  if [ "$TEST_MODE" = 1 ] && { [ "$stage" != static ] || [ "$TEST_REAL_STATIC" != 1 ]; }; then
    [ -x "$ROOT/tests/quality-gate-fixtures/$stage" ] || die "missing test fixture for $stage"
    env -u DETACH_VERSION -u DETACH_BUILD_VERSION -u DETACH_BUILD_ARCHS \
      -u DETACH_CODESIGN_IDENTITY -u DETACH_RELEASE_BUILD -u DETACH_SPARKLE_VERSION \
      -u DETACH_SPARKLE_FEED_URL -u DETACH_SPARKLE_PUBLIC_ED_KEY -u DETACH_DOWNLOAD_URL \
      "$ROOT/tests/quality-gate-fixtures/$stage"
    return
  fi
  case "$stage" in
    static) run_static ;;
    gate-contract)
      "$ROOT/tests/quality-gate.sh" | grep -Fx 'Quality gate orchestrator tests passed'
      "$ROOT/tests/quality-ratchet-contract.sh" | grep -Fx 'Quality ratchet contract tests passed'
      "$ROOT/tests/release-budget-ratchet-contract.sh" | \
        grep -Fx 'Release budget ratchet contract tests passed'
      "$ROOT/tests/shell-safety-contract.sh" | grep -Fx 'Shell safety contract tests passed'
      "$ROOT/tests/quality-history-contract.sh" | grep -Fx 'Quality history contract tests passed'
      ;;
    swift)
      (
        cd -P "$ROOT/app"
        mkdir -p .build/quality-codecov
        LLVM_PROFILE_FILE="$ROOT/app/.build/quality-codecov/%p-%m.profraw" \
          swift test --enable-code-coverage --disable-sandbox
      )
      ;;
    quality-contracts) DETACH_SWIFT_TEST_LOG="$RUN_DIR/swift.log" "$ROOT/tests/quality-contracts.sh" ;;
    app)
      env -u DETACH_VERSION -u DETACH_BUILD_VERSION -u DETACH_BUILD_ARCHS \
        -u DETACH_CODESIGN_IDENTITY -u DETACH_RELEASE_BUILD -u DETACH_SPARKLE_VERSION \
        -u DETACH_SPARKLE_FEED_URL -u DETACH_SPARKLE_PUBLIC_ED_KEY -u DETACH_DOWNLOAD_URL \
        "$ROOT/app/scripts/make-app.sh"
      ;;
    ui-e2e)
      "$ROOT/tests/ui-e2e-contract.sh"
      DETACH_UI_E2E_ARTIFACT_DIR="$RUN_DIR/ui-e2e-artifacts" "$ROOT/tests/ui-e2e.sh"
      ;;
    codex)
      [ -x "$tmux_bin" ] || die 'codex gate requires the app stage bundled tmux'
      [ -x "$state_bin" ] || die 'codex gate requires the app stage bundled state helper'
      run_tmux_socket_preflight "$tmux_bin" || return $?
      DETACH_TEST_TMUX_BIN="$tmux_bin" DETACH_TEST_STATE_BIN="$state_bin" \
        DETACH_PROVIDER_TEST_ARTIFACT_DIR="$RUN_DIR/codex-artifacts" "$ROOT/tests/run.sh"
      ;;
    claude)
      [ -x "$tmux_bin" ] || die 'claude gate requires the app stage bundled tmux'
      [ -x "$state_bin" ] || die 'claude gate requires the app stage bundled state helper'
      run_tmux_socket_preflight "$tmux_bin" || return $?
      DETACH_TEST_TMUX_BIN="$tmux_bin" DETACH_TEST_STATE_BIN="$state_bin" \
        DETACH_PROVIDER_TEST_ARTIFACT_DIR="$RUN_DIR/claude-artifacts" "$ROOT/tests/run-claude.sh"
      ;;
    distribution) "$ROOT/tests/distribution.sh" ;;
    tmux-runtime) "$ROOT/tests/tmux-runtime.sh" ;;
    release-preflight) "$ROOT/tests/release-preflight.sh" ;;
    publish-preflight) "$ROOT/tests/publish-preflight.sh" ;;
    release-workflow) "$ROOT/tests/release-workflow.sh" ;;
  esac
}

export ROOT BASE_REF RESOLVED_BASE MODE DIAGNOSTIC_STAGE TEST_MODE TEST_REAL_STATIC RUN_DIR
export -f die changed_entries static_shell_files run_static run_tmux_socket_preflight run_stage_command

stage_result_file() {
  printf '%s/.stage-%s.result' "$RUN_DIR" "$1"
}

write_stage_result() {
  local stage="$1" result="$2" duration="$3" log="$4" exit_status="$5" origin_run="${6:--}"
  printf '%s\t%s\t%s\t%s\t%s\n' "$result" "$duration" "$log" "$exit_status" "$origin_run" \
    >"$(stage_result_file "$stage")"
  chmod 0600 "$(stage_result_file "$stage")"
}

result_status() {
  local result_file
  result_file="$(stage_result_file "$1")"
  [ -f "$result_file" ] || return 1
  cut -f1 "$result_file"
}

prerequisite_failed() {
  local stage="$1" prerequisite="" status
  case "$stage" in
    quality-contracts) prerequisite=swift ;;
    ui-e2e|codex|claude|tmux-runtime) prerequisite=app ;;
  esac
  [ -n "$prerequisite" ] || return 1
  status="$(result_status "$prerequisite" 2>/dev/null || true)"
  case "$status" in failed|environment-failed|timeout|interrupted|blocked) return 0 ;; esac
  return 1
}

launch_stage() {
  local stage="$1" log timeout started prior_duration prior_log prior_origin reused_log
  contains_stage "$stage" || return 0
  [ ! -f "$(stage_result_file "$stage")" ] || return 0
  [ ! -f "$RUN_DIR/.stage-$stage.pid" ] || return 0
  if resume_stage_passed "$stage"; then
    printf 'quality-gate: reusing %s from matching evidence %s\n' "$stage" "$RESUME_DIR"
    prior_duration="$(resume_stage_value "$stage" 5)"
    prior_log="$(resume_stage_value "$stage" 6)"
    prior_origin="$(resume_stage_value "$stage" 8)"
    [ "$prior_origin" != - ] || prior_origin="$(basename "$RESUME_DIR")"
    if [ "$prior_log" = - ]; then
      reused_log=-
    else
      reused_log="$stage.reused.log"
      cp "$RESUME_DIR/$prior_log" "$RUN_DIR/$reused_log"
      chmod 0600 "$RUN_DIR/$reused_log"
    fi
    write_stage_result "$stage" reused "$prior_duration" "$reused_log" 0 "$prior_origin"
    return 0
  fi
  if prerequisite_failed "$stage"; then
    printf 'quality-gate: blocking %s because its prerequisite failed\n' "$stage" >&2
    write_stage_result "$stage" blocked 0 - 0
    return 0
  fi
  log="$RUN_DIR/$stage.log"
  started="$(date +%s)"
  timeout="$(effective_timeout_for_stage "$stage")"
  printf 'quality-gate: running %s (timeout %ss)\n' "$stage" "$timeout"
  printf '%s\n' "$started" >"$RUN_DIR/.stage-$stage.started"
  execute_stage "$stage" "$timeout" "$log" "$started" &
  printf '%s\n' "$!" >"$RUN_DIR/.stage-$stage.pid"
}

execute_stage() {
  local stage="$1" timeout="$2" log="$3" started="$4" bounded_pid status duration result interrupted=0
  set +e
  run_bounded "$timeout" /bin/bash -c 'set -euo pipefail; run_stage_command "$1"' _ "$stage" \
    >"$log" 2>&1 &
  bounded_pid=$!
  trap 'interrupted=1; kill -TERM "$bounded_pid" 2>/dev/null || true' INT TERM HUP
  wait "$bounded_pid"
  status=$?
  trap - INT TERM HUP
  duration=$(($(date +%s) - started))
  result=passed
  if [ "$interrupted" -eq 1 ]; then
    result=interrupted
    status=130
  elif [ "$status" -eq 124 ]; then
    result=timeout
  elif [ "$status" -ne 0 ]; then
    result=failed
    if grep -Eq 'error creating .+\.sock \(Operation not permitted\)|sandbox[^[:space:]]* denied|deny\(1\)' "$log"; then
      result=environment-failed
    fi
  fi
  write_stage_result "$stage" "$result" "$duration" "$stage.log" "$status"
  exit "$status"
}

wait_stage() {
  local stage="$1" pid_file result_file pid status result duration log origin_run
  contains_stage "$stage" || return 0
  result_file="$(stage_result_file "$stage")"
  pid_file="$RUN_DIR/.stage-$stage.pid"
  if [ -f "$pid_file" ]; then
    pid="$(cat "$pid_file")"
    set +e
    wait "$pid"
    status=$?
    set -e
    [ -f "$result_file" ] || write_stage_result "$stage" interrupted 0 "$stage.log" 130
    rm -f "$pid_file"
  elif [ ! -f "$result_file" ]; then
    die "stage was not scheduled: $stage"
  fi
  [ -f "$RUN_DIR/.stage-$stage.reported" ] && return 0
  IFS=$'\t' read -r result duration log status origin_run <"$result_file"
  enforce_stage_budget "$stage" "$result" "$duration" "$log" "$status" "$origin_run"
  IFS=$'\t' read -r result duration log status origin_run <"$result_file"
  if [ "$result" = failed ] || [ "$result" = environment-failed ] || [ "$result" = timeout ]; then
    [ "$log" = - ] || /bin/cat "$RUN_DIR/$log"
    printf 'quality-gate: %s %s; diagnostic rerun: scripts/quality-gate --stage %s\n' "$stage" "$result" "$stage" >&2
    printf 'quality-gate: readiness evidence is incomplete; log: %s\n' "$RUN_DIR/$log" >&2
    OVERALL_STATUS="$status"
    FAILURE_COUNT=$((FAILURE_COUNT + 1))
  else
    printf 'quality-gate: %s %s (%ss; log=%s)\n' "$stage" "$result" "$duration" "$log"
  fi
  : >"$RUN_DIR/.stage-$stage.reported"
}

budget_value() {
  local key="$1"
  awk -F '\t' -v wanted="$key" \
    '$1 == wanted {count++; value=$2} END {if (count != 1) exit 1; print value}' "$RELEASE_BUDGET"
}

stage_budget_override() {
  local stage="$1" suffix variable_name value
  suffix="$(printf '%s' "$stage" | tr '[:lower:]-' '[:upper:]_')"
  variable_name="DETACH_QUALITY_GATE_TEST_STAGE_SECONDS_$suffix"
  value="${!variable_name:-}"
  if [ -z "$value" ] && [ "$stage" = codex ]; then
    value="${DETACH_QUALITY_GATE_TEST_CODEX_SECONDS:-}"
  fi
  printf '%s' "$value"
}

enforce_stage_budget() {
  local stage="$1" result="$2" duration="$3" log="$4" status="$5" origin_run="$6"
  local override key maximum measured="$duration"
  [ "$stage" != release-budget ] || return 0
  contains_stage release-budget && return 0
  case "$result" in passed|reused) ;; *) return 0 ;; esac
  override="$(stage_budget_override "$stage")"
  if [ "$TEST_MODE" = 1 ] && [ -z "$override" ]; then
    return 0
  fi
  [ -z "$override" ] || measured="$override"
  [[ "$measured" =~ ^[0-9]+$ ]] || die "stage duration must be a non-negative integer: $stage"
  key="stage_$(printf '%s' "$stage" | tr '-' '_')_seconds_max"
  maximum="$(budget_value "$key")" || die "release stage budget is missing or duplicated: $stage"
  [[ "$maximum" =~ ^[1-9][0-9]*$ ]] || die "release stage budget must be a positive integer: $stage"
  [ "$measured" -le "$maximum" ] || {
    if [ "$log" = - ]; then
      log="$stage.log"
      : >"$RUN_DIR/$log"
    fi
    printf 'stage budget: %s regressed: %ss > %ss\n' "$stage" "$measured" "$maximum" >>"$RUN_DIR/$log"
    write_stage_result "$stage" failed "$measured" "$log" 1 "$origin_run"
  }
}

evaluate_release_budget() {
  local stage status duration key maximum elapsed inherited_wall=0 result=passed exit_status=0 log override
  contains_stage release-budget || return 0
  for stage in "${SELECTED[@]}"; do
    [ "$stage" = release-budget ] && continue
    status="$(result_status "$stage" 2>/dev/null || true)"
    case "$status" in
      passed|reused) ;;
      *)
        printf 'quality-gate: blocking release-budget because %s is not passed\n' "$stage" >&2
        write_stage_result release-budget blocked 0 - 0
        return 0
        ;;
    esac
  done
  [ -f "$RELEASE_BUDGET" ] && [ ! -L "$RELEASE_BUDGET" ] || die 'release budget is missing or unsafe'
  [ "$(budget_value schema)" = 2 ] || die 'release budget schema is unsupported'
  log="$RUN_DIR/release-budget.log"
  elapsed="${DETACH_QUALITY_GATE_TEST_WALL_SECONDS:-$(($(date +%s) - RUN_STARTED_EPOCH))}"
  [[ "$elapsed" =~ ^[0-9]+$ ]] || die 'test wall duration must be a non-negative integer'
  if [ -n "$RESUME_DIR" ]; then
    inherited_wall="$(manifest_value "$RESUME_DIR/manifest.tsv" timing_wall_seconds)"
    [[ "$inherited_wall" =~ ^[0-9]+$ ]] || die 'resume timing wall duration is invalid'
  fi
  EFFECTIVE_TIMING_WALL="$elapsed"
  [ "$inherited_wall" -le "$EFFECTIVE_TIMING_WALL" ] || EFFECTIVE_TIMING_WALL="$inherited_wall"
  maximum="$(budget_value wall_seconds_max)" || die 'release wall budget is missing or duplicated'
  [[ "$maximum" =~ ^[1-9][0-9]*$ ]] || die 'release wall budget must be a positive integer'
  printf 'invocation_wall_seconds\t%s\n' "$elapsed" >"$log"
  printf 'inherited_wall_seconds\t%s\n' "$inherited_wall" >>"$log"
  printf 'effective_wall_seconds\t%s\tmax\t%s\n' "$EFFECTIVE_TIMING_WALL" "$maximum" >>"$log"
  if [ "$EFFECTIVE_TIMING_WALL" -gt "$maximum" ]; then
    printf 'release budget: wall time regressed: %ss > %ss\n' "$EFFECTIVE_TIMING_WALL" "$maximum" >>"$log"
    result=failed
    exit_status=1
  fi
  for stage in "${SELECTED[@]}"; do
    [ "$stage" = release-budget ] && continue
    IFS=$'\t' read -r status duration _ _ _ <"$(stage_result_file "$stage")"
    override="$(stage_budget_override "$stage")"
    [ -z "$override" ] || duration="$override"
    [[ "$duration" =~ ^[0-9]+$ ]] || die "stage duration must be a non-negative integer: $stage"
    key="stage_$(printf '%s' "$stage" | tr '-' '_')_seconds_max"
    maximum="$(budget_value "$key")" || die "release stage budget is missing or duplicated: $stage"
    [[ "$maximum" =~ ^[1-9][0-9]*$ ]] || die "release stage budget must be a positive integer: $stage"
    printf '%s_seconds\t%s\tmax\t%s\n' "$stage" "$duration" "$maximum" >>"$log"
    if [ "$TEST_MODE" = 1 ] && [ -z "$override" ]; then
      continue
    fi
    if [ "$duration" -gt "$maximum" ]; then
      printf 'release budget: %s regressed: %ss > %ss\n' "$stage" "$duration" "$maximum" >>"$log"
      result=failed
      exit_status=1
    fi
  done
  if [ "$result" = passed ]; then
    printf 'Release budget passed: wall=%ss max=%ss\n' "$EFFECTIVE_TIMING_WALL" "$(budget_value wall_seconds_max)" >>"$log"
  fi
  write_stage_result release-budget "$result" 0 release-budget.log "$exit_status"
}

assemble_summary() {
  local stage result duration log status origin_run log_sha256 result_file digest_file
  local -a log_files=()
  printf 'policy\tmode\tstage\tstatus\tduration_seconds\tlog\tlog_sha256\torigin_run\n' >"$SUMMARY"
  for stage in "${SELECTED[@]}"; do
    result_file="$(stage_result_file "$stage")"
    if [ ! -f "$result_file" ]; then
      write_stage_result "$stage" interrupted 0 "$stage.log" 130
    fi
    IFS=$'\t' read -r result duration log status origin_run <"$result_file"
    if [ "$log" != - ]; then
      if [ "$result" = interrupted ] && [ ! -e "$RUN_DIR/$log" ]; then
        : >"$RUN_DIR/$log"
        chmod 0600 "$RUN_DIR/$log"
      fi
      [ -f "$RUN_DIR/$log" ] && [ ! -L "$RUN_DIR/$log" ] || die "stage log is missing or unsafe: $stage"
      log_files+=("$log")
    fi
  done
  digest_file="$RUN_DIR/.log-digests"
  : >"$digest_file"
  if [ "${#log_files[@]}" -gt 0 ]; then
    (cd -P "$RUN_DIR" && shasum -a 256 -- "${log_files[@]}") >"$digest_file"
  fi
  for stage in "${SELECTED[@]}"; do
    IFS=$'\t' read -r result duration log status origin_run <"$(stage_result_file "$stage")"
    log_sha256=-
    if [ "$log" != - ]; then
      log_sha256="$(awk -v wanted="$log" '$2 == wanted {count++; digest=$1} END {if (count != 1) exit 1; print digest}' "$digest_file")" || \
        die "stage log digest is missing or duplicated: $stage"
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$POLICY_VERSION" "$MODE" "$stage" "$result" "$duration" "$log" "$log_sha256" "$origin_run" >>"$SUMMARY"
  done
  rm -f "$digest_file"
}

# Keep SwiftPM's shared build directory exclusive. Cheap hermetic release and
# distribution contracts run beside it. Once the app is verified, the two
# provider suites use private state/socket roots and the bundled state helper,
# so they can run concurrently with each other and the orchestrator contract.
for stage in "${SELECTED[@]}"; do
  case "$stage" in app|quality-contracts|ui-e2e|codex|claude|tmux-runtime|gate-contract|release-budget) ;;
    *) launch_stage "$stage" ;;
  esac
done
wait_stage swift
launch_stage quality-contracts
launch_stage app
wait_stage app
launch_stage ui-e2e
launch_stage codex
launch_stage claude
launch_stage tmux-runtime
launch_stage gate-contract
for stage in "${SELECTED[@]}"; do
  [ "$stage" = release-budget ] && continue
  wait_stage "$stage"
done
evaluate_release_budget
wait_stage release-budget
assemble_summary
write_junit
write_markdown

if [ "$OVERALL_STATUS" -ne 0 ]; then
  write_manifest failed
  printf 'quality-gate: FAIL policy=%s fingerprint=%s failures=%s evidence=%s junit=%s markdown=%s\n' "$POLICY_VERSION" "$FINGERPRINT" "$FAILURE_COUNT" "$SUMMARY" "$JUNIT" "$MARKDOWN" >&2
  exit "$OVERALL_STATUS"
elif [ -n "$DIAGNOSTIC_STAGE" ]; then
  write_manifest diagnostic
  printf 'quality-gate: diagnostic stage passed; this is not readiness evidence\n'
else
  write_manifest passed
  printf 'quality-gate: PASS policy=%s fingerprint=%s evidence=%s junit=%s markdown=%s\n' "$POLICY_VERSION" "$FINGERPRINT" "$SUMMARY" "$JUNIT" "$MARKDOWN"
fi
