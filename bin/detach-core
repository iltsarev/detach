#!/bin/bash

set -u
set -o pipefail

umask 077

if [ "${DETACH_CORE_ENTRYPOINT:-}" != "1" ]; then
  printf 'detach-core: internal executable; use detach instead\n' >&2
  exit 2
fi

PROVIDER="${DETACH_PROVIDER:-codex}"
case "$PROVIDER" in
  codex|claude) ;;
  *)
    printf 'detach-core: unsupported provider: %s\n' "$PROVIDER" >&2
    exit 2
    ;;
esac

PROVIDER_LABEL="Codex"
PROVIDER_ARGS_LABEL="CODEX_ARGS"
if [ "$PROVIDER" = "claude" ]; then
  PROVIDER_LABEL="Claude"
  PROVIDER_ARGS_LABEL="CLAUDE_ARGS"
fi
PROGRAM="${DETACH_PROGRAM:-detach}"
DEFAULT_CHECKPOINT_INTERVAL=300
DEFAULT_HISTORY_LIMIT=50000

error() {
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
}

die() {
  error "$*"
  exit 1
}

resolve_self() {
  local source_path="$0"
  local source_dir
  local link_target

  while [ -h "$source_path" ]; do
    source_dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)" || exit 1
    link_target="$(readlink "$source_path")" || exit 1
    case "$link_target" in
      /*) source_path="$link_target" ;;
      *) source_path="$source_dir/$link_target" ;;
    esac
  done

  source_dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)" || exit 1
  printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

SELF="$(resolve_self)"
SELF_DIR="$(dirname "$SELF")"
VERSION_FILE="$SELF_DIR/VERSION"
[ -f "$VERSION_FILE" ] || VERSION_FILE="$SELF_DIR/../VERSION"

release_version() {
  local version
  [ -f "$VERSION_FILE" ] || return 1
  IFS= read -r version <"$VERSION_FILE" || return 1
  [[ "$version" =~ ^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(-([0-9A-Za-z-]+\.)*[0-9A-Za-z-]+)?(\+[0-9A-Za-z.-]+)?$ ]] || return 1
  printf '%s\n' "$version"
}

STATE_BASE_ROOT="${DETACH_STATE_ROOT:-${XDG_STATE_HOME:-$HOME/.local/state}/detach}"
CONFIG_ROOT="${DETACH_CONFIG_ROOT:-${XDG_CONFIG_HOME:-$HOME/.config}/detach}"
CONFIG_FILE="$CONFIG_ROOT/config"
INSTALL_STATE_ROOT="${DETACH_INSTALL_STATE_ROOT:-$STATE_BASE_ROOT}"
INSTALL_LOCK="$INSTALL_STATE_ROOT/install.lock"

config_value() {
  local key="$1"
  local line
  [ -f "$CONFIG_FILE" ] && [ ! -L "$CONFIG_FILE" ] || return 1
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      "$key="*) printf '%s\n' "${line#*=}"; return 0 ;;
    esac
  done <"$CONFIG_FILE"
  return 1
}

CONFIG_TMUX_STYLE="$(config_value TMUX_STYLE 2>/dev/null || true)"
case "$CONFIG_TMUX_STYLE" in 0|1|'') ;; *) CONFIG_TMUX_STYLE="" ;; esac
CONFIG_TMUX_MOUSE="$(config_value TMUX_MOUSE 2>/dev/null || true)"
case "$CONFIG_TMUX_MOUSE" in 0|1|'') ;; *) CONFIG_TMUX_MOUSE="" ;; esac
if [ "$PROVIDER" = "codex" ]; then
  STATE_ROOT="${DETACH_CODEX_STATE_ROOT:-$STATE_BASE_ROOT/codex}"
  CHECKPOINT_INTERVAL="${DETACH_CODEX_CHECKPOINT_INTERVAL:-$DEFAULT_CHECKPOINT_INTERVAL}"
  HISTORY_LIMIT="${DETACH_CODEX_HISTORY_LIMIT:-$DEFAULT_HISTORY_LIMIT}"
  SYNC_ENABLED="${DETACH_CODEX_SYNC:-1}"
else
  STATE_ROOT="${DETACH_CLAUDE_STATE_ROOT:-$STATE_BASE_ROOT/claude}"
  CHECKPOINT_INTERVAL="${DETACH_CLAUDE_CHECKPOINT_INTERVAL:-$DEFAULT_CHECKPOINT_INTERVAL}"
  HISTORY_LIMIT="${DETACH_CLAUDE_HISTORY_LIMIT:-$DEFAULT_HISTORY_LIMIT}"
  SYNC_ENABLED="${DETACH_CLAUDE_SYNC:-1}"
fi
TMUX_STYLE_ENABLED="${DETACH_TMUX_STYLE:-${CONFIG_TMUX_STYLE:-1}}"
case "$TMUX_STYLE_ENABLED" in
  0|1) ;;
  *) die "DETACH_TMUX_STYLE must be 0 or 1" ;;
esac
TMUX_MOUSE_ENABLED="${DETACH_TMUX_MOUSE:-${CONFIG_TMUX_MOUSE:-1}}"
case "$TMUX_MOUSE_ENABLED" in
  0|1) ;;
  *) die "DETACH_TMUX_MOUSE must be 0 or 1" ;;
esac
DEFAULT_TMUX_SOCKET_PATH="$INSTALL_STATE_ROOT/tmux/tmux.sock"
TMUX_SOCKET_PATH="${DETACH_TMUX_SOCKET_PATH:-$DEFAULT_TMUX_SOCKET_PATH}"
TMUX_CONFIG="${DETACH_TMUX_CONFIG:-}"
SESSIONS_ROOT="$STATE_ROOT/sessions"
LOCKS_ROOT="${DETACH_LOCKS_ROOT:-$STATE_BASE_ROOT/locks}"
INSIDE_TMUX="${TMUX:-}"
DETACH_CONFIG_ROOT="$CONFIG_ROOT"
DETACH_STATE_ROOT="$STATE_BASE_ROOT"
export DETACH_CONFIG_ROOT DETACH_STATE_ROOT DETACH_INSTALL_STATE_ROOT

STATE_BIN="${DETACH_STATE_BIN:-$SELF_DIR/detach-state}"
POWER_BIN="${DETACH_POWER_BIN:-$SELF_DIR/detach-power}"
DETACH_STATE_BIN="$STATE_BIN"
DETACH_POWER_BIN="$POWER_BIN"
export DETACH_STATE_BIN DETACH_POWER_BIN
TMUX_BIN="${DETACH_TMUX_BIN:-$SELF_DIR/tmux}"
SQLITE_BIN="${DETACH_SQLITE_BIN:-$(command -v sqlite3 2>/dev/null || true)}"
TAR_BIN="${DETACH_TAR_BIN:-/usr/bin/tar}"
CODEX_BIN_DEFAULT="${DETACH_CODEX_BIN:-$(command -v codex 2>/dev/null || true)}"
CLAUDE_BIN_DEFAULT="${DETACH_CLAUDE_BIN:-$(command -v claude 2>/dev/null || true)}"
AGENT_BIN_DEFAULT="$CODEX_BIN_DEFAULT"
[ "$PROVIDER" = "codex" ] || AGENT_BIN_DEFAULT="$CLAUDE_BIN_DEFAULT"
ENV_BIN="${DETACH_ENV_BIN:-/usr/bin/env}"
LOCKF_BIN="${DETACH_LOCKF_BIN:-/usr/bin/lockf}"

TMUX_CMD=("$TMUX_BIN" -S "$TMUX_SOCKET_PATH")
if [ -n "$TMUX_CONFIG" ]; then
  TMUX_CMD+=( -f "$TMUX_CONFIG" )
fi

usage() {
  printf '%s\n' \
    'Usage:' \
    "  $PROGRAM [start] [--name NAME] [--detach] [--] [$PROVIDER_ARGS_LABEL...]" \
    "  $PROGRAM resume [--name NAME] [--detach] SESSION_ID [$PROVIDER_ARGS_LABEL...]" \
    "  $PROGRAM attach [NAME]" \
    "  $PROGRAM list [--json]" \
    "  $PROGRAM config tmux-style [detach|inherit]" \
    "  $PROGRAM config tmux-mouse [on|off]" \
    "  $PROGRAM status [NAME]" \
    "  $PROGRAM logs [--ansi] [NAME]" \
    "  $PROGRAM stop [NAME]" \
    "  $PROGRAM recover [NAME]" \
    "  $PROGRAM delete [--force] [NAME]" \
    '' \
    'With no NAME, the session is derived from the current Git repository (or cwd).' \
    "A default start creates a new $PROVIDER_LABEL session; use attach or resume explicitly."

  if [ "$PROVIDER" = "codex" ]; then
    printf '%s\n' \
      '' \
      'Codex defaults to:' \
      '  --sandbox workspace-write --no-alt-screen' \
      '  approval=never, unless managed policy requires its configured reviewer' \
      '' \
      'Pass explicit Codex flags to override approval or sandbox defaults.'
  else
    printf '%s\n' \
      '' \
      'Claude defaults to --permission-mode auto unless explicitly overridden.' \
      'The harness owns --session-id/--resume/--background and disables the alternate screen.'
  fi
}

require_file_or_command() {
  local path="$1"
  local label="$2"
  [ -n "$path" ] && [ -x "$path" ] || die "$label is required"
}

validate_runtime_config() {
  case "$CHECKPOINT_INTERVAL" in
    ''|*[!0-9]*) die "checkpoint interval must be a positive integer" ;;
  esac
  [ "$CHECKPOINT_INTERVAL" -gt 0 ] || die "checkpoint interval must be greater than zero"

  case "$HISTORY_LIMIT" in
    ''|*[!0-9]*) die "history limit must be a positive integer" ;;
  esac
  [ "$HISTORY_LIMIT" -gt 0 ] || die "history limit must be greater than zero"
}

managed_requirements_toml() {
  local override="${DETACH_CODEX_REQUIREMENTS_FILE:-}"
  local managed_user="${USER:-}"
  local plist
  local encoded

  if [ -n "$override" ]; then
    [ -f "$override" ] || return 1
    cat "$override"
    return
  fi
  [ -n "$managed_user" ] || managed_user="$(id -un 2>/dev/null || true)"
  for plist in \
    "/Library/Managed Preferences/$managed_user/com.openai.codex.plist" \
    "/Library/Managed Preferences/com.openai.codex.plist"; do
    [ -r "$plist" ] || continue
    encoded="$(/usr/bin/plutil -extract requirements_toml_base64 raw -o - "$plist" 2>/dev/null || true)"
    [ -n "$encoded" ] || continue
    printf '%s' "$encoded" | /usr/bin/base64 -D 2>/dev/null && return
  done
  return 1
}

managed_policy_disallows_never() {
  local requirements
  local allowed_block

  requirements="$(managed_requirements_toml)" || return 1
  allowed_block="$(printf '%s\n' "$requirements" | awk '
    /^[[:space:]]*allowed_approval_policies[[:space:]]*=/ { capture = 1 }
    capture { print }
    capture && /]/ { exit }
  ')"
  [ -n "$allowed_block" ] || return 1
  ! printf '%s\n' "$allowed_block" | grep -Eq '"never"'
}

require_common_dependencies() {
  require_file_or_command "$TMUX_BIN" "tmux"
  require_file_or_command "$STATE_BIN" "detach-state"
}

require_start_dependencies() {
  require_common_dependencies
  if [ "$PROVIDER" = "codex" ]; then
    require_file_or_command "$SQLITE_BIN" "sqlite3"
  else
    require_file_or_command "$TAR_BIN" "tar"
  fi
  require_file_or_command "$AGENT_BIN_DEFAULT" "$PROVIDER"
  require_file_or_command "$POWER_BIN" "detach-power"
  power_start_preflight
  require_file_or_command "$ENV_BIN" "env"
  "$ENV_BIN" -C / "$ENV_BIN" >/dev/null 2>&1 || die "env with -C support is required"
  require_file_or_command "$LOCKF_BIN" "lockf"
}

validate_tmux_socket_path() {
  local path="$TMUX_SOCKET_PATH"
  local expected_parent="$INSTALL_STATE_ROOT/tmux"
  local byte_count

  case "$INSTALL_STATE_ROOT" in
    /*) ;;
    *) die "install state root must be absolute: $INSTALL_STATE_ROOT" ;;
  esac
  [ ! -L "$INSTALL_STATE_ROOT" ] || \
    die "install state root must not be a symlink: $INSTALL_STATE_ROOT"
  case "$path" in
    /*) ;;
    *) die "tmux socket path must be absolute: $path" ;;
  esac
  case "$path" in
    *$'\n'*|*$'\r'*) die "tmux socket path contains a newline" ;;
  esac
  case "$path" in
    */|*/./*|*/../*) die "tmux socket path is unsafe: $path" ;;
  esac
  [ "$(dirname "$path")" = "$expected_parent" ] || \
    die "tmux socket must live in the Detach-owned directory: $expected_parent"
  byte_count="$(LC_ALL=C printf '%s' "$path" | /usr/bin/wc -c | /usr/bin/tr -d '[:space:]')"
  [ -n "$byte_count" ] && [ "$byte_count" -le 103 ] || \
    die "tmux socket path is too long for macOS: $path"
}

ensure_tmux_socket_dir() {
  local parent

  validate_tmux_socket_path
  parent="$(dirname "$TMUX_SOCKET_PATH")"
  if [ ! -e "$parent" ] && [ ! -L "$parent" ]; then
    mkdir "$parent" || {
      [ -d "$parent" ] && [ ! -L "$parent" ] || \
        die "cannot create tmux socket directory: $parent"
    }
  fi
  [ -d "$parent" ] && [ ! -L "$parent" ] || \
    die "tmux socket directory is unsafe: $parent"
  chmod 0700 "$parent" || die "cannot secure tmux socket directory: $parent"
  [ ! -L "$TMUX_SOCKET_PATH" ] || die "tmux socket path is a symlink: $TMUX_SOCKET_PATH"
  if [ -e "$TMUX_SOCKET_PATH" ] && [ ! -S "$TMUX_SOCKET_PATH" ]; then
    die "tmux socket path is occupied by a non-socket: $TMUX_SOCKET_PATH"
  fi
}

ensure_state_dirs() {
  # This check is intentionally first: a hostile install-state symlink must
  # not receive session directories, locks, chmods, or socket files.
  validate_tmux_socket_path
  mkdir -p "$SESSIONS_ROOT" "$LOCKS_ROOT" "$INSTALL_STATE_ROOT" || \
    die "cannot create state directory: $STATE_ROOT"
  ensure_tmux_socket_dir
}

now_iso() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

now_ms() {
  printf '%s000\n' "$(date '+%s')"
}

new_run_token() {
  uuidgen | tr '[:upper:]' '[:lower:]'
}

canonical_project_dir_for() {
  local input_dir="$1"
  local canonical_input
  local candidate

  [ -d "$input_dir" ] || return 1
  canonical_input="$(cd -P "$input_dir" >/dev/null 2>&1 && pwd)" || return 1
  candidate="$canonical_input"
  while :; do
    if { [ -d "$candidate/.git" ] || [ -f "$candidate/.git" ]; } && \
       [ ! -L "$candidate/.git" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
    [ "$candidate" != / ] || break
    candidate="$(dirname "$candidate")"
  done
  printf '%s\n' "$canonical_input"
}

canonical_project_dir() {
  canonical_project_dir_for "$PWD"
}

validate_short_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_-]{0,47}$ ]] || \
    die "invalid name '$name' (use 1-48 letters, digits, underscores, or hyphens)"
}

default_session_name() {
  local cwd="$1"
  local slug
  local digest

  slug="$(basename "$cwd" | LC_ALL=C tr -cs 'A-Za-z0-9_-' '-' | sed 's/^-*//; s/-*$//')"
  [ -n "$slug" ] || slug="project"
  slug="${slug:0:24}"
  digest="$(printf '%s' "$cwd" | shasum -a 256 | awk '{print substr($1, 1, 8)}')"
  printf 'detach-%s-%s-%s\n' "$PROVIDER" "$slug" "$digest"
}

project_lock_path() {
  local cwd="$1"
  local digest

  digest="$(printf '%s' "$cwd" | shasum -a 256 | awk '{print substr($1, 1, 16)}')"
  printf '%s/project-%s.lock\n' "$LOCKS_ROOT" "$digest"
}

normalize_session_name() {
  local name="$1"

  if [ -z "$name" ]; then
    default_session_name "$(canonical_project_dir)"
    return
  fi

  case "$name" in
    detach-"$PROVIDER"-*)
      name="${name#"detach-$PROVIDER-"}"
      validate_short_name "$name"
      printf 'detach-%s-%s\n' "$PROVIDER" "$name"
      ;;
    *)
      validate_short_name "$name"
      printf 'detach-%s-%s\n' "$PROVIDER" "$name"
      ;;
  esac
}

session_dir() {
  printf '%s/%s\n' "$SESSIONS_ROOT" "$1"
}

session_meta() {
  printf '%s/meta.json\n' "$(session_dir "$1")"
}

usable_meta_path() {
  local session="$1"
  local primary
  local checkpoint
  local candidate

  primary="$(session_meta "$session")"
  checkpoint="$(session_dir "$session")/checkpoint/meta.json"
  for candidate in "$primary" "$checkpoint"; do
    [ -f "$candidate" ] || continue
    if "$STATE_BIN" meta usable "$candidate" "$session" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

tmux_has_session() {
  "${TMUX_CMD[@]}" has-session -t "=$1" 2>/dev/null
}

tmux_is_any_managed() {
  [ "$(tmux_option "$1" '@detach')" = "1" ]
}

tmux_is_managed() {
  local stored_provider

  tmux_is_any_managed "$1" || return 1
  stored_provider="$(tmux_option "$1" '@detach_provider')"
  [ "$stored_provider" = "$PROVIDER" ]
}

tmux_pane_id() {
  local pane

  pane="$(tmux_option "$1" '@detach_pane_id')"
  if [ -n "$pane" ]; then
    printf '%s\n' "$pane"
  else
    "${TMUX_CMD[@]}" display-message -p -t "=$1" '#{pane_id}' 2>/dev/null
  fi
}

tmux_pane_dead() {
  local pane

  pane="$(tmux_pane_id "$1" 2>/dev/null || true)"
  [ -n "$pane" ] || {
    printf '1\n'
    return
  }
  "${TMUX_CMD[@]}" display-message -p -t "$pane" '#{pane_dead}' 2>/dev/null || printf '1\n'
}

tmux_session_running() {
  tmux_has_session "$1" && [ "$(tmux_pane_dead "$1")" = "0" ]
}

tmux_option() {
  "${TMUX_CMD[@]}" show-options -qv -t "=$1:" "$2" 2>/dev/null || true
}

session_color_for() {
  local provider="$1"
  local cwd="$2"
  local digest
  local index
  # Eight hues spaced evenly around the wheel; pure red is reserved for the
  # FAILED strip so an identity color can never read as an alarm.
  local palette=(
    '#C2410C'
    '#4D7C0F'
    '#15803D'
    '#0D9488'
    '#0369A1'
    '#1D4ED8'
    '#6D28D9'
    '#A21CAF'
  )

  digest="$(printf '%s\0%s' "$provider" "$cwd" | shasum -a 256 | awk '{print substr($1, 1, 8)}')" || return 1
  [[ "$digest" =~ ^[0-9a-fA-F]{8}$ ]] || return 1
  index=$((16#$digest % ${#palette[@]}))
  printf '%s\n' "${palette[$index]}"
}

# Mix the identity color with the neutral strip anchor (#20202B), keeping the
# hue. Every derived surface (dense tint, faded tint, muted edge) comes from
# this one formula rather than a hand-picked pair per palette entry.
blend_session_color() {
  local color="$1"
  local percent="$2"
  local red green blue

  [[ "$color" =~ ^#[0-9A-Fa-f]{6}$ ]] || return 1
  [[ "$percent" =~ ^[0-9]+$ ]] && [ "$percent" -le 100 ] || return 1
  red=$(((16#${color:1:2} * percent + 32 * (100 - percent)) / 100))
  green=$(((16#${color:3:2} * percent + 32 * (100 - percent)) / 100))
  blue=$(((16#${color:5:2} * percent + 43 * (100 - percent)) / 100))
  printf '#%02X%02X%02X\n' "$red" "$green" "$blue"
}

tmux_status_literal() {
  local value="$1"
  local result=""
  local character
  local index

  for ((index = 0; index < ${#value} && index < 48; index++)); do
    character="${value:index:1}"
    if [[ "$character" == [[:cntrl:]] ]]; then
      result+='?'
    elif [ "$character" = '#' ]; then
      # A doubled hash is a literal hash in a tmux format string.
      result+='##'
    else
      result+="$character"
    fi
  done
  printf '%s' "$result"
}

tmux_forget_session_style_snapshot() {
  local session="$1"
  local option

  for option in \
    @detach_saved_status \
    @detach_saved_status_style \
    @detach_saved_status_left \
    @detach_saved_status_left_length \
    @detach_saved_status_right \
    @detach_saved_status_right_length \
    @detach_style_snapshot_right \
    @detach_style_snapshot; do
    "${TMUX_CMD[@]}" set-option -qu -t "=$session:" "$option" 2>/dev/null || true
  done
}

tmux_snapshot_session_style() {
  local session="$1"
  local saved_status saved_status_style saved_status_left saved_status_left_length
  local saved_status_right saved_status_right_length

  [ "$(tmux_option "$session" '@detach_style_snapshot')" != "1" ] || return 0
  saved_status="$("${TMUX_CMD[@]}" show-options -Aqv -t "=$session:" status 2>/dev/null)" || return 1
  saved_status_style="$("${TMUX_CMD[@]}" show-options -Aqv -t "=$session:" status-style 2>/dev/null)" || return 1
  saved_status_left="$("${TMUX_CMD[@]}" show-options -Aqv -t "=$session:" status-left 2>/dev/null)" || return 1
  saved_status_left_length="$("${TMUX_CMD[@]}" show-options -Aqv -t "=$session:" status-left-length 2>/dev/null)" || return 1
  saved_status_right="$("${TMUX_CMD[@]}" show-options -Aqv -t "=$session:" status-right 2>/dev/null)" || return 1
  saved_status_right_length="$("${TMUX_CMD[@]}" show-options -Aqv -t "=$session:" status-right-length 2>/dev/null)" || return 1

  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_saved_status "$saved_status" && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_saved_status_style "$saved_status_style" && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_saved_status_left "$saved_status_left" && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_saved_status_left_length "$saved_status_left_length" && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_saved_status_right "$saved_status_right" && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_saved_status_right_length "$saved_status_right_length" && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_style_snapshot_right 1 && \
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_style_snapshot 1 && return 0
  tmux_forget_session_style_snapshot "$session"
  return 1
}

tmux_restore_session_style() {
  local session="$1"
  local saved_status saved_status_style saved_status_left saved_status_left_length
  local saved_status_right saved_status_right_length

  [ "$(tmux_option "$session" '@detach_style_snapshot')" = "1" ] || return 0
  saved_status="$(tmux_option "$session" '@detach_saved_status')"
  saved_status_style="$(tmux_option "$session" '@detach_saved_status_style')"
  saved_status_left="$(tmux_option "$session" '@detach_saved_status_left')"
  saved_status_left_length="$(tmux_option "$session" '@detach_saved_status_left_length')"

  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-style "$saved_status_style" || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-left "$saved_status_left" || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-left-length "$saved_status_left_length" || return 1
  # A snapshot written by an older Detach never saved the right side; restore
  # it only when this snapshot proves it captured one.
  if [ "$(tmux_option "$session" '@detach_style_snapshot_right')" = "1" ]; then
    saved_status_right="$(tmux_option "$session" '@detach_saved_status_right')"
    saved_status_right_length="$(tmux_option "$session" '@detach_saved_status_right_length')"
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-right "$saved_status_right" || return 1
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-right-length "$saved_status_right_length" || return 1
  fi
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status "$saved_status" || return 1
  tmux_forget_session_style_snapshot "$session"
}

tmux_apply_session_style() {
  local session="$1"
  local status="$2"
  local provider cwd project color provider_label state_label status_left status_right power_state power_label
  local strip_bg text_fg dim_fg edge_color project_color state_color state_attr power_color power_attr

  [ "$(tmux_option "$session" '@detach_tmux_style')" = "1" ] || {
    tmux_restore_session_style "$session"
    return 0
  }

  provider="$(tmux_option "$session" '@detach_provider')"
  cwd="$(tmux_option "$session" '@detach_cwd')"
  color="$(tmux_option "$session" '@detach_color')"
  if ! [[ "$color" =~ ^#[0-9A-Fa-f]{6}$ ]]; then
    color="$(session_color_for "${provider:-$PROVIDER}" "${cwd:-?}")" || return 1
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_color "$color" || return 1
  fi
  case "$provider" in
    codex) provider_label='Codex' ;;
    claude) provider_label='Claude' ;;
    *) provider_label='Agent' ;;
  esac
  project="$(basename "${cwd:-project}")"
  [ -n "$project" ] || project='project'
  # Truncate before escaping so the cut cannot split a doubled hash; the
  # power label and state never truncate.
  [ "${#project}" -le 28 ] || project="${project:0:27}…"
  project="$(tmux_status_literal "$project")"

  # The session identity tints the whole strip: a dense blend of the session
  # color behind light readable text, plus a solid painted-space edge (not a
  # font-dependent partial block). Finished sessions keep a faint tint of the
  # same hue, failures tint the strip red, and the plain-text labels remain
  # the primary signal in any terminal theme.
  strip_bg="$(blend_session_color "$color" 55)" || return 1
  text_fg='#E4E7F2'
  dim_fg='#A8AECB'
  edge_color="$color"
  project_color='#FFFFFF'
  state_label="$(printf '%s' "$status" | LC_ALL=C tr '[:lower:]' '[:upper:]')"
  state_label="${state_label:-UNKNOWN}"
  state_color='#F5F6FC'
  state_attr='bold'
  case "$status" in
    completed|interrupted|stopped)
      strip_bg="$(blend_session_color "$color" 25)" || return 1
      edge_color="$(blend_session_color "$color" 45)" || edge_color="$color"
      text_fg='#8A90B0'
      dim_fg='#5F6483'
      project_color='#B9BED6'
      state_color='#8A90B0'
      state_attr='nobold'
      ;;
    failed|start_failed)
      strip_bg="$(blend_session_color '#B91C1C' 55)" || return 1
      edge_color='#B91C1C'
      dim_fg='#B0A2A8'
      state_color='#FFB3B6'
      ;;
  esac

  power_state="$(tmux_option "$session" '@detach_power_state')"
  case "$power_state" in
    protected|allowed|transitioning|low_battery|unavailable|unknown) ;;
    *) power_state="$(power_protection_state)" ;;
  esac
  power_label="$(power_protection_label "$power_state")"
  power_color="$dim_fg"
  power_attr='nobold'
  case "$power_state" in
    protected) power_color='#4FE8C6'; power_attr='bold' ;;
    low_battery) power_color='#FFC24D'; power_attr='bold' ;;
    transitioning) power_color='#FFC24D' ;;
    unavailable|unknown) power_color='#FF8A8E' ;;
  esac

  status_left="#[bg=$edge_color]  #[bg=$strip_bg]#[fg=$text_fg] Detach #[fg=$dim_fg]· #[fg=$text_fg]$provider_label #[fg=$dim_fg]· #[fg=$project_color,bold]$project #[nobold]#[fg=$dim_fg]· #[fg=$state_color,$state_attr]$state_label#[nobold] "
  status_right="#[fg=$power_color,$power_attr]$power_label#[nobold] #[fg=$dim_fg]%H:%M "

  tmux_snapshot_session_style "$session" || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status on || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-style "fg=$text_fg,bg=$strip_bg" || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-left-length 120 || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-left "$status_left" || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-right-length 40 || return 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" status-right "$status_right" || return 1
}

tmux_update_session_status() {
  local session="$1"
  local status="$2"

  tmux_has_session "$session" || return 0
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_status "$status" || return 1
  tmux_apply_session_style "$session" "$status"
}

tmux_refresh_managed_styles() {
  local enabled="$1"
  local session status pane_status owned

  [ -n "$TMUX_BIN" ] && [ -x "$TMUX_BIN" ] || return 0
  while IFS= read -r session; do
    [ -n "$session" ] || continue
    tmux_is_any_managed "$session" || continue
    owned="$(tmux_option "$session" '@detach_tmux_style')"
    case "$owned" in 0|1) ;; *) continue ;; esac
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_tmux_style "$enabled" || continue
    if [ "$enabled" = "0" ]; then
      tmux_restore_session_style "$session" || true
      continue
    fi
    status="$(tmux_option "$session" '@detach_status')"
    if [ -z "$status" ]; then
      if [ "$(tmux_option "$session" '@detach_running')" = "1" ]; then
        status='running'
      else
        pane_status="$("${TMUX_CMD[@]}" display-message -p -t "$(tmux_pane_id "$session")" '#{pane_dead_status}' 2>/dev/null || true)"
        if [ "$pane_status" = "0" ]; then status='completed'; else status='failed'; fi
      fi
      "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_status "$status" || continue
    fi
    if ! tmux_apply_session_style "$session" "$status"; then
      "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_tmux_style 0 2>/dev/null || true
      tmux_restore_session_style "$session" || true
    fi
  done < <("${TMUX_CMD[@]}" list-sessions -F '#{session_name}' 2>/dev/null || true)
}

# One-line wheel steps in copy mode and mouse selections that land in the
# macOS clipboard. These are options and key bindings on the private
# Detach-owned tmux server only; the user's own tmux server is never touched.
tmux_configure_copy_input() {
  local table

  "${TMUX_CMD[@]}" set-option -q -s copy-command '/usr/bin/pbcopy' || return 1
  "${TMUX_CMD[@]}" set-option -q -s set-clipboard on || return 1
  for table in copy-mode copy-mode-vi; do
    "${TMUX_CMD[@]}" bind-key -T "$table" WheelUpPane send-keys -X -N 1 scroll-up || return 1
    "${TMUX_CMD[@]}" bind-key -T "$table" WheelDownPane send-keys -X -N 1 scroll-down || return 1
    "${TMUX_CMD[@]}" bind-key -T "$table" MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel || return 1
  done
}

tmux_apply_mouse_input() {
  local session="$1"

  if [ "$TMUX_MOUSE_ENABLED" = "1" ]; then
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" mouse on || return 1
    tmux_configure_copy_input || return 1
  else
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" mouse off || return 1
  fi
}

tmux_refresh_managed_mouse() {
  local enabled="$1"
  local session

  [ -n "$TMUX_BIN" ] && [ -x "$TMUX_BIN" ] || return 0
  [ "$enabled" != "1" ] || tmux_configure_copy_input || true
  while IFS= read -r session; do
    [ -n "$session" ] || continue
    tmux_is_any_managed "$session" || continue
    if [ "$enabled" = "1" ]; then
      "${TMUX_CMD[@]}" set-option -q -t "=$session:" mouse on || true
    else
      "${TMUX_CMD[@]}" set-option -q -t "=$session:" mouse off || true
    fi
  done < <("${TMUX_CMD[@]}" list-sessions -F '#{session_name}' 2>/dev/null || true)
}

ensure_config_root() {
  [ -n "$CONFIG_ROOT" ] && [ "$CONFIG_ROOT" != "/" ] || die "unsafe Detach config directory: $CONFIG_ROOT"
  if [ -e "$CONFIG_ROOT" ] || [ -L "$CONFIG_ROOT" ]; then
    [ -d "$CONFIG_ROOT" ] && [ ! -L "$CONFIG_ROOT" ] || \
      die "Detach config directory is not a regular directory: $CONFIG_ROOT"
  else
    mkdir -p "$CONFIG_ROOT" || die "cannot create Detach config directory: $CONFIG_ROOT"
  fi
  chmod 0700 "$CONFIG_ROOT" || die "cannot protect Detach config directory: $CONFIG_ROOT"
}

write_config_key_locked() {
  local key="$1"
  local value="$2"
  local tmp="$CONFIG_FILE.tmp.$$"
  local line
  local found=0

  case "$key" in TMUX_STYLE|TMUX_MOUSE) ;; *) die "invalid internal config key" ;; esac
  case "$value" in 0|1) ;; *) die "invalid internal config value" ;; esac
  ensure_config_root
  if [ -e "$CONFIG_FILE" ] || [ -L "$CONFIG_FILE" ]; then
    [ -f "$CONFIG_FILE" ] && [ ! -L "$CONFIG_FILE" ] || \
      die "Detach config is not a regular file: $CONFIG_FILE"
  fi
  [ ! -e "$tmp" ] && [ ! -L "$tmp" ] || die "temporary config path already exists: $tmp"

  if [ -f "$CONFIG_FILE" ]; then
    : >"$tmp" || die "cannot create temporary Detach config"
    while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in
        "$key="*)
          if [ "$found" -eq 0 ]; then
            printf '%s=%s\n' "$key" "$value" >>"$tmp" || {
              rm -f "$tmp"
              die "cannot update Detach config"
            }
            found=1
          fi
          ;;
        *)
          printf '%s\n' "$line" >>"$tmp" || {
            rm -f "$tmp"
            die "cannot update Detach config"
          }
          ;;
      esac
    done <"$CONFIG_FILE"
    if [ "$found" -eq 0 ]; then
      printf '%s=%s\n' "$key" "$value" >>"$tmp" || {
        rm -f "$tmp"
        die "cannot update Detach config"
      }
    fi
  else
    printf '%s\n' \
      '# Detach settings. Environment variables override these values.' \
      "$key=$value" >"$tmp" || die "cannot create Detach config"
  fi
  chmod 0600 "$tmp" || {
    rm -f "$tmp"
    die "cannot protect Detach config"
  }
  mv -f "$tmp" "$CONFIG_FILE" || {
    rm -f "$tmp"
    die "cannot replace Detach config"
  }
  case "$key" in
    TMUX_STYLE) tmux_refresh_managed_styles "$value" ;;
    TMUX_MOUSE) tmux_refresh_managed_mouse "$value" ;;
  esac
}

write_config_key_under_lock() {
  local key="$1"
  local value="$2"
  local label="$3"

  require_file_or_command "$LOCKF_BIN" "lockf"
  if [ -e "$INSTALL_STATE_ROOT" ] || [ -L "$INSTALL_STATE_ROOT" ]; then
    [ -d "$INSTALL_STATE_ROOT" ] && [ ! -L "$INSTALL_STATE_ROOT" ] || \
      die "install state root is not a regular directory: $INSTALL_STATE_ROOT"
  else
    mkdir -p "$INSTALL_STATE_ROOT" || die "cannot create install lock directory"
  fi
  "$LOCKF_BIN" -k -t 30 "$INSTALL_LOCK" "$SELF" __write_config_key_locked "$key" "$value" || \
    die "could not update $label setting"
}

config_tmux_style() {
  local requested="${1:-}"
  local value

  if [ "$#" -eq 0 ]; then
    if [ "$TMUX_STYLE_ENABLED" = "1" ]; then printf 'detach\n'; else printf 'inherit\n'; fi
    return 0
  fi
  [ "$#" -eq 1 ] || die "config tmux-style accepts at most one value"
  [ "${DETACH_TMUX_STYLE+x}" != "x" ] || \
    die "cannot change tmux style while DETACH_TMUX_STYLE overrides the config"
  case "$requested" in
    detach) value=1 ;;
    inherit) value=0 ;;
    *) die "tmux style must be 'detach' or 'inherit'" ;;
  esac
  write_config_key_under_lock TMUX_STYLE "$value" "tmux style"
}

config_tmux_mouse() {
  local requested="${1:-}"
  local value

  if [ "$#" -eq 0 ]; then
    if [ "$TMUX_MOUSE_ENABLED" = "1" ]; then printf 'on\n'; else printf 'off\n'; fi
    return 0
  fi
  [ "$#" -eq 1 ] || die "config tmux-mouse accepts at most one value"
  [ "${DETACH_TMUX_MOUSE+x}" != "x" ] || \
    die "cannot change tmux mouse input while DETACH_TMUX_MOUSE overrides the config"
  case "$requested" in
    on) value=1 ;;
    off) value=0 ;;
    *) die "tmux mouse input must be 'on' or 'off'" ;;
  esac
  write_config_key_under_lock TMUX_MOUSE "$value" "tmux mouse input"
}

attach_session() {
  local session="$1"
  local current_socket target_socket

  tmux_has_session "$session" || die "tmux session '$session' is not running"
  tmux_is_managed "$session" || die "refusing to attach to unmanaged tmux session '$session'"
  if [ -n "$INSIDE_TMUX" ]; then
    current_socket="${INSIDE_TMUX%%,*}"
    target_socket="$("${TMUX_CMD[@]}" display-message -p -t "=$session:" '#{socket_path}' 2>/dev/null)" || \
      die "could not identify the detach tmux server"
    if [ -n "$current_socket" ] && [ "$current_socket" = "$target_socket" ]; then
      exec "${TMUX_CMD[@]}" switch-client -t "=$session"
    fi
    # tmux cannot switch a client across servers. Unset the outer server
    # identity so tmux deliberately opens a nested client for Detach's private
    # server instead of failing after the managed session has already started.
    exec "$ENV_BIN" -u TMUX -u TMUX_PANE \
      "${TMUX_CMD[@]}" attach-session -t "=$session"
  else
    exec "${TMUX_CMD[@]}" attach-session -t "=$session"
  fi
}

state_update_meta() {
  local session="$1"
  shift
  local meta

  meta="$(session_meta "$session")"
  [ -f "$meta" ] || return 1
  "$STATE_BIN" meta patch "$meta" "$@"
}

state_update_meta_for_run() {
  local session="$1"
  local run_token="$2"
  shift 2

  state_update_meta "$session" --run-token "$run_token" "$@"
}

write_initial_meta() {
  local session="$1"
  local cwd="$2"
  local start_ms="$3"
  local agent_bin="$4"
  local recovery_id="${5:-}"
  local recovery_transcript="${6:-}"
  local run_token="$7"
  local preserve_checkpoint="${8:-0}"
  local dir
  local meta
  local tmp
  local agent_version
  local session_color
  local create_args

  dir="$(session_dir "$session")"
  meta="$dir/meta.json"
  tmp="$meta.tmp.$$"
  mkdir -p "$dir/checkpoint"
  if [ "$preserve_checkpoint" != "1" ]; then
    rm -f \
      "$dir/checkpoint/meta.json" \
      "$dir/checkpoint/rollout.jsonl" \
      "$dir/checkpoint/transcript.jsonl" \
      "$dir/checkpoint/claude-session.tar" \
      "$dir/checkpoint/codex-state.sqlite" \
      "$dir/checkpoint/pane.txt" \
      "$dir/checkpoint/pane-ansi.txt" \
      "$dir/checkpoint/worktree-status.txt" \
      "$dir/exit-status"
    rm -rf \
      "$dir/checkpoint/claude-session" \
      "$dir/checkpoint/claude-file-history" \
      "$dir/checkpoint/claude-session-env"
    : >"$dir/checkpoint.log"
  fi
  agent_version="$("$agent_bin" --version 2>/dev/null || printf 'unknown')"
  session_color="$(session_color_for "$PROVIDER" "$cwd")" || return 1

  create_args=(
    --integer schema 1
    --string session_name "$session"
    --string project_dir "$cwd"
    --string created_at "$(now_iso)"
    --integer created_at_ms "$start_ms"
    --string status starting
    --string run_token "$run_token"
    --string provider "$PROVIDER"
    --string session_color "$session_color"
    --string agent_bin "$agent_bin"
    --string agent_version "$agent_version"
    --integer checkpoint_interval_seconds "$CHECKPOINT_INTERVAL"
    --null last_checkpoint_at
    --null exit_status
  )
  if [ -n "$recovery_id" ]; then
    create_args+=( --string agent_session_id "$recovery_id" )
  else
    create_args+=( --null agent_session_id )
  fi
  if [ -n "$recovery_transcript" ]; then
    create_args+=( --string transcript_path "$recovery_transcript" )
  else
    create_args+=( --null transcript_path )
  fi
  if [ "$PROVIDER" = "codex" ]; then
    create_args+=( --string codex_bin "$agent_bin" --string codex_version "$agent_version" )
    if [ -n "$recovery_id" ]; then
      create_args+=( --string codex_session_id "$recovery_id" )
    else
      create_args+=( --null codex_session_id )
    fi
    if [ -n "$recovery_transcript" ]; then
      create_args+=( --string rollout_path "$recovery_transcript" )
    else
      create_args+=( --null rollout_path )
    fi
  else
    create_args+=( --null codex_bin --null codex_version --null codex_session_id --null rollout_path )
  fi
  rm -f "$tmp"
  "$STATE_BIN" meta create "$tmp" "${create_args[@]}" || return 1
  mv -f "$tmp" "$meta"
}

claude_home() {
  printf '%s\n' "${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
}

canonical_claude_home() {
  local home

  home="$(claude_home)"
  [ -d "$home" ] || return 1
  cd -P "$home" >/dev/null 2>&1 && pwd
}

safe_claude_transcript_path() {
  local path="$1"
  local id="$2"
  local home_real
  local projects
  local relative
  local project_name
  local projects_real
  local parent_real
  local parent

  home_real="$(canonical_claude_home)" || return 1
  projects="$(claude_home)/projects"
  [ -d "$projects" ] && [ ! -L "$projects" ] && [ ! -L "$path" ] || return 1
  case "$path" in
    "$projects"/*/"$id.jsonl") ;;
    *) return 1 ;;
  esac
  relative="${path#"$projects"/}"
  project_name="${relative%/"$id.jsonl"}"
  [ -n "$project_name" ] || return 1
  case "$project_name" in */*) return 1 ;; esac
  projects_real="$(cd -P "$projects" >/dev/null 2>&1 && pwd)" || return 1
  [ "$projects_real" = "$home_real/projects" ] || return 1
  parent="$(dirname "$path")"
  [ ! -L "$parent" ] || return 1
  if [ -d "$parent" ]; then
    parent_real="$(cd -P "$parent" >/dev/null 2>&1 && pwd)" || return 1
    [ "$(dirname "$parent_real")" = "$projects_real" ]
  else
    [ ! -e "$parent" ] || return 1
    parent_real="$(cd -P "$(dirname "$parent")" >/dev/null 2>&1 && pwd)" || return 1
    [ "$parent_real" = "$projects_real" ]
  fi
}

canonical_claude_transcript_path() {
  local path="$1"
  local id="$2"
  local parent
  local parent_real
  local projects_real

  safe_claude_transcript_path "$path" "$id" || return 1
  parent="$(dirname "$path")"
  if [ -d "$parent" ]; then
    parent_real="$(cd -P "$parent" >/dev/null 2>&1 && pwd)" || return 1
  else
    projects_real="$(cd -P "$(claude_home)/projects" >/dev/null 2>&1 && pwd)" || \
      return 1
    parent_real="$projects_real/$(basename "$parent")"
  fi
  printf '%s/%s\n' "$parent_real" "$(basename "$path")"
}

safe_plain_directory_tree() {
  local root="$1"
  local unsafe

  [ -d "$root" ] && [ ! -L "$root" ] || return 1
  unsafe="$(find "$root" -mindepth 1 ! -type d ! -type f -print -quit 2>/dev/null)" || \
    return 1
  [ -z "$unsafe" ] || return 1
  unsafe="$(find "$root" -type f -links +1 -print -quit 2>/dev/null)" || return 1
  [ -z "$unsafe" ]
}

safe_plain_file() {
  local path="$1"

  [ -f "$path" ] && [ ! -L "$path" ] || return 1
  [ "$(stat -f '%l' "$path" 2>/dev/null)" = 1 ]
}

safe_claude_restore_destination() {
  local destination="$1"
  local home="$2"
  local relative
  local remaining
  local component
  local current="$home"

  case "$destination" in
    "$home"/*) relative="${destination#"$home"/}" ;;
    *) return 1 ;;
  esac
  case "$relative" in
    ''|*$'\n'*|*$'\r'*|*//*|*/|./*|../*|*/./*|*/../*) return 1 ;;
  esac
  remaining="$relative"
  while [ -n "$remaining" ]; do
    component="${remaining%%/*}"
    if [ "$remaining" = "$component" ]; then
      remaining=""
    else
      remaining="${remaining#*/}"
    fi
    case "$component" in ''|.|..) return 1 ;; esac
    current="$current/$component"
    [ ! -L "$current" ] || return 1
    if [ -e "$current" ]; then
      [ -d "$current" ] || return 1
    elif [ -n "$remaining" ]; then
      # Once an ancestor is absent, no deeper entry can exist yet. The later
      # mkdir creates that suffix beneath the already-canonical Claude root.
      break
    fi
  done
  [ ! -e "$destination" ] || safe_plain_directory_tree "$destination"
}

preflight_claude_restore_publish_state() {
  local destination="$1"
  local home="$2"
  local sibling

  safe_claude_restore_destination "$destination" "$home" || return 1
  for sibling in "$destination.detach.old" "$destination.detach.tmp"; do
    if [ -e "$sibling" ] || [ -L "$sibling" ]; then
      safe_claude_restore_destination "$sibling" "$home" || return 1
    fi
  done
}

claude_transcript_candidates() {
  local id="$1"
  local projects

  projects="$(claude_home)/projects"
  [ -d "$projects" ] || return 1
  find "$projects" -mindepth 2 -maxdepth 2 -type f -name "$id.jsonl" -print 2>/dev/null
}

claude_transcript_for_id() {
  local id="$1"
  local candidate
  local found=""

  while IFS= read -r candidate; do
    [ -f "$candidate" ] || continue
    safe_claude_transcript_path "$candidate" "$id" || continue
    valid_claude_transcript "$candidate" "$id" || continue
    [ -z "$found" ] || return 2
    found="$candidate"
  done < <(claude_transcript_candidates "$id" || true)
  [ -n "$found" ] || return 1
  printf '%s\n' "$found"
}

valid_claude_transcript_stream() {
  local expected_id="$1"

  "$STATE_BIN" jsonl validate claude /dev/stdin "$expected_id" >/dev/null 2>&1
}

valid_claude_transcript() {
  local path="$1"
  local expected_id="$2"

  [ -s "$path" ] && \
    "$STATE_BIN" jsonl validate claude "$path" "$expected_id" >/dev/null 2>&1
}

valid_claude_checkpoint_archive() {
  local archive="$1"
  local expected_id="$2"

  [ -s "$archive" ] || return 1
  "$TAR_BIN" -xOf "$archive" ./transcript.jsonl 2>/dev/null | \
    valid_claude_transcript_stream "$expected_id"
}

codex_home() {
  printf '%s\n' "${CODEX_HOME:-$HOME/.codex}"
}

safe_codex_rollout_path() {
  local path="$1"
  local sessions
  local sessions_real
  local parent_real
  local relative
  local ancestor

  sessions="$(codex_home)/sessions"
  [ -d "$sessions" ] && [ ! -L "$path" ] || return 1
  case "$path" in
    "$sessions"/*) ;;
    *) return 1 ;;
  esac
  relative="${path#"$sessions"/}"
  case "/$relative/" in
    */../*|*/./*) return 1 ;;
  esac
  sessions_real="$(cd -P "$sessions" >/dev/null 2>&1 && pwd)" || return 1
  ancestor="$(dirname "$path")"
  while [ ! -e "$ancestor" ]; do
    [ "$ancestor" != "/" ] || return 1
    ancestor="$(dirname "$ancestor")"
  done
  [ -d "$ancestor" ] && [ ! -L "$ancestor" ] || return 1
  parent_real="$(cd -P "$ancestor" >/dev/null 2>&1 && pwd)" || return 1
  case "$parent_real/" in
    "$sessions_real/"|"$sessions_real"/*) return 0 ;;
  esac
  return 1
}

codex_state_db() {
  local home
  local newest=""
  local candidate

  home="$(codex_home)"
  if [ -f "$home/state_5.sqlite" ]; then
    printf '%s\n' "$home/state_5.sqlite"
    return 0
  fi
  for candidate in "$home"/state_*.sqlite; do
    [ -f "$candidate" ] || continue
    if [ -z "$newest" ] || [ "$candidate" -nt "$newest" ]; then
      newest="$candidate"
    fi
  done
  printf '%s\n' "$newest"
}

sql_escape() {
  printf '%s' "${1//\'/\'\'}"
}

snapshot_known_threads() {
  local session="$1"
  local cwd="$2"
  local db
  local cwd_sql
  local output

  output="$(session_dir "$session")/known-thread-ids.txt"
  if [ "$PROVIDER" = "claude" ]; then
    : >"$output"
    return 0
  fi
  db="$(codex_state_db)"
  if [ -z "$db" ] || [ ! -f "$db" ]; then
    : >"$output"
    return 0
  fi
  cwd_sql="$(sql_escape "$cwd")"
  "$SQLITE_BIN" -noheader -cmd '.timeout 5000' "$db" \
    "SELECT id FROM threads
     WHERE source = 'cli'
       AND COALESCE(thread_source, 'user') = 'user'
       AND cwd = '$cwd_sql'
     ORDER BY id;" >"$output"
}

write_resume_args() {
  local session="$1"
  shift
  local output
  local tmp
  local arg

  output="$(session_dir "$session")/resume-args.bin"
  tmp="$output.tmp.$$"
  : >"$tmp"
  if [ "$PROVIDER" = "claude" ]; then
    while [ "$#" -gt 0 ]; do
      arg="$1"
      shift
      case "$arg" in
        --session-id|-r|--resume|-c|--continue|--fork-session|--bg|--background)
          case "$arg" in
            --session-id|-r|--resume) [ "$#" -eq 0 ] || shift ;;
          esac
          ;;
        --allowedTools|--allowed-tools|--betas|--disallowedTools|--disallowed-tools|\
        --file|--mcp-config|--tools|--add-dir)
          printf '%s\0' "$arg" >>"$tmp"
          while [ "$#" -gt 0 ]; do
            case "$1" in -*) break ;; esac
            printf '%s\0' "$1" >>"$tmp"
            shift
          done
          ;;
        --agent|--agents|--append-system-prompt|--debug-file|--effort|\
        --model|-n|--name|--permission-mode|--plugin-dir|\
        --plugin-url|--remote-control-session-name-prefix|--setting-sources|\
        --settings|--system-prompt)
          [ "$#" -gt 0 ] || continue
          printf '%s\0%s\0' "$arg" "$1" >>"$tmp"
          shift
          ;;
        --agent=*|--agents=*|--allowedTools=*|--allowed-tools=*|--betas=*|\
        --append-system-prompt=*|--disallowedTools=*|--disallowed-tools=*|\
        --debug=*|--debug-file=*|--effort=*|--file=*|--from-pr=*|\
        --mcp-config=*|--model=*|--name=*|--permission-mode=*|\
        --plugin-dir=*|--plugin-url=*|--prompt-suggestions=*|--remote-control=*|\
        --remote-control-session-name-prefix=*|--setting-sources=*|--settings=*|\
        --system-prompt=*|--tools=*|--add-dir=*)
          printf '%s\0' "$arg" >>"$tmp"
          ;;
        --allow-dangerously-skip-permissions|--dangerously-skip-permissions|\
        --bare|--brief|--chrome|--no-chrome|--disable-slash-commands|\
        --exclude-dynamic-system-prompt-sections|--ide|--safe-mode|\
        --strict-mcp-config|--verbose)
          printf '%s\0' "$arg" >>"$tmp"
          ;;
      esac
    done
    mv -f "$tmp" "$output"
    return
  fi
  while [ "$#" -gt 0 ]; do
    arg="$1"
    shift
    case "$arg" in
      -c|--config|-m|--model|-p|--profile|-s|--sandbox|-a|--ask-for-approval|\
      --add-dir|--enable|--disable|--local-provider|--remote|--remote-auth-token-env|\
      -i|--image)
        [ "$#" -gt 0 ] || continue
        printf '%s\0%s\0' "$arg" "$1" >>"$tmp"
        shift
        ;;
      --config=*|--model=*|--profile=*|--sandbox=*|--ask-for-approval=*|\
      --add-dir=*|--enable=*|--disable=*|--local-provider=*|--remote=*|\
      --remote-auth-token-env=*|--image=*)
        printf '%s\0' "$arg" >>"$tmp"
        ;;
      --search|--oss|--strict-config|--no-alt-screen|\
      --dangerously-bypass-approvals-and-sandbox|--dangerously-bypass-hook-trust)
        printf '%s\0' "$arg" >>"$tmp"
        ;;
    esac
  done
  mv -f "$tmp" "$output"
}

discover_codex_session() {
  local session="$1"
  local run_token="${2:-}"
  local meta
  local existing_id
  local cwd
  local db
  local cwd_sql
  local rows
  local known
  local candidate_ids
  local candidate_count
  local id
  local rollout
  local candidate
  local candidate_rollout
  local candidate_originator
  local expected_originator

  meta="$(session_meta "$session")"
  [ -f "$meta" ] || return 1
  if [ -n "$run_token" ] && [ "$("$STATE_BIN" meta get "$meta" run_token)" != "$run_token" ]; then
    return 1
  fi
  existing_id="$("$STATE_BIN" meta get "$meta" agent_session_id codex_session_id)"
  if [ "$PROVIDER" = "claude" ]; then
    [ -n "$existing_id" ] || return 1
    rollout="$("$STATE_BIN" meta get "$meta" transcript_path)"
    if [ -z "$rollout" ] || \
       ! safe_claude_transcript_path "$rollout" "$existing_id" || \
       ! valid_claude_transcript "$rollout" "$existing_id"; then
      rollout="$(claude_transcript_for_id "$existing_id" 2>/dev/null || true)"
    fi
    [ -n "$rollout" ] && valid_claude_transcript "$rollout" "$existing_id" || return 1
    if [ -n "$run_token" ]; then
      state_update_meta_for_run "$session" "$run_token" \
        --string agent_session_id "$existing_id" --string transcript_path "$rollout"
    else
      state_update_meta "$session" \
        --string agent_session_id "$existing_id" --string transcript_path "$rollout"
    fi
    return
  fi
  [ -z "$existing_id" ] || return 0

  cwd="$("$STATE_BIN" meta get "$meta" project_dir)"
  db="$(codex_state_db)"
  [ -n "$db" ] && [ -f "$db" ] || return 1
  known="$(session_dir "$session")/known-thread-ids.txt"
  [ -f "$known" ] || return 1

  cwd_sql="$(sql_escape "$cwd")"
  rows="$($SQLITE_BIN -noheader -separator $'\t' -cmd '.timeout 5000' "$db" \
    "SELECT id, rollout_path FROM threads
     WHERE source = 'cli'
       AND COALESCE(thread_source, 'user') = 'user'
       AND cwd = '$cwd_sql'
     ORDER BY created_at_ms ASC, id ASC;" 2>/dev/null || true)"

  [ -n "$run_token" ] || return 1
  expected_originator="detach_$run_token"
  candidate_ids="$(printf '%s\n' "$rows" | \
    while IFS=$'\t' read -r candidate candidate_rollout; do
      grep -Fqx "$candidate" "$known" && continue
      [ -f "$candidate_rollout" ] || continue
      candidate_originator="$("$STATE_BIN" jsonl first "$candidate_rollout" payload.originator 2>/dev/null || true)"
      [ "$candidate_originator" = "$expected_originator" ] && printf '%s\n' "$candidate"
    done)"
  candidate_count="$(printf '%s\n' "$candidate_ids" | sed '/^$/d' | wc -l | tr -d ' ')"
  [ "$candidate_count" = "1" ] || {
    [ "$candidate_count" -lt 2 ] || checkpoint_log "$session" "ambiguous Codex session discovery: $candidate_count new root threads"
    return 1
  }
  id="$(printf '%s\n' "$candidate_ids" | sed -n '1p')"
  rollout="$(printf '%s\n' "$rows" | \
    awk -F '\t' -v id="$id" '$1 == id { print substr($0, length($1) + 2); exit }')"
  [ -n "$id" ] && [ -n "$rollout" ] || return 1

  safe_codex_rollout_path "$rollout" || return 1
  valid_jsonl "$rollout" "$id" || return 1

  if [ -n "$run_token" ]; then
    state_update_meta_for_run "$session" "$run_token" \
      --string agent_session_id "$id" --string transcript_path "$rollout" \
      --string codex_session_id "$id" --string rollout_path "$rollout"
  else
    state_update_meta "$session" \
      --string agent_session_id "$id" --string transcript_path "$rollout" \
      --string codex_session_id "$id" --string rollout_path "$rollout"
  fi
}

valid_jsonl() {
  local path="$1"
  local expected_id="$2"

  [ -s "$path" ] && \
    "$STATE_BIN" jsonl validate codex "$path" "$expected_id" >/dev/null 2>&1
}

restore_matching_rollout_checkpoint() {
  local session="$1"
  local id="$2"
  local rollout="$3"
  local backup
  local tmp
  local restore=0

  safe_codex_rollout_path "$rollout" || return 1
  backup="$(session_dir "$session")/checkpoint/rollout.jsonl"
  [ -f "$backup" ] || return 0
  valid_jsonl "$backup" "$id" || return 0
  if ! valid_jsonl "$rollout" "$id"; then
    restore=1
  elif [ "$(stat -f '%z' "$rollout")" -lt "$(stat -f '%z' "$backup")" ]; then
    restore=1
  fi
  [ "$restore" -eq 1 ] || return 0

  mkdir -p "$(dirname "$rollout")"
  tmp="$rollout.detach.tmp.$$"
  cp -p "$backup" "$tmp" || return 1
  valid_jsonl "$tmp" "$id" || {
    rm -f "$tmp"
    return 1
  }
  mv -f "$tmp" "$rollout" || return 1
  [ "$SYNC_ENABLED" = "0" ] || /bin/sync
  error "restored Codex rollout from the matching checkpoint before resume"
}

restore_directory_checkpoint() {
  local backup="$1"
  local destination="$2"
  local home="$3"
  local tmp="$destination.detach.tmp"
  local old="$destination.detach.old"

  [ -d "$backup" ] || return 0
  safe_plain_directory_tree "$backup" || return 1
  safe_claude_restore_destination "$destination" "$home" || return 1
  mkdir -p "$(dirname "$destination")" || return 1
  safe_claude_restore_destination "$(dirname "$destination")" "$home" || return 1

  # Recover an interrupted publish before starting another one. `.old` is the
  # previous live directory; `.tmp` is never authoritative and is discarded
  # only after proving it is a plain, in-root directory tree.
  if [ -e "$old" ] || [ -L "$old" ]; then
    safe_claude_restore_destination "$old" "$home" || return 1
    if [ -e "$destination" ] || [ -L "$destination" ]; then
      safe_claude_restore_destination "$destination" "$home" || return 1
      rm -rf "$old" || return 1
    else
      mv "$old" "$destination" || return 1
    fi
  fi
  if [ -e "$tmp" ] || [ -L "$tmp" ]; then
    safe_claude_restore_destination "$tmp" "$home" || return 1
    rm -rf "$tmp" || return 1
  fi

  cp -R "$backup" "$tmp" || {
    if safe_claude_restore_destination "$tmp" "$home"; then rm -rf "$tmp"; fi
    return 1
  }
  safe_plain_directory_tree "$tmp" || return 1
  if [ -e "$destination" ] || [ -L "$destination" ]; then
    safe_claude_restore_destination "$destination" "$home" || return 1
    mv "$destination" "$old" || return 1
    if ! mv "$tmp" "$destination"; then
      mv "$old" "$destination" || return 1
      return 1
    fi
    safe_claude_restore_destination "$old" "$home" || return 1
    rm -rf "$old" || return 1
  else
    mv "$tmp" "$destination" || return 1
  fi
  safe_claude_restore_destination "$destination" "$home"
}

restore_missing_checkpoint_files() {
  local backup="$1"
  local destination="$2"
  local home="$3"
  local source
  local relative
  local target

  RESTORE_MISSING_CHANGED=0
  [ -d "$backup" ] || return 0
  safe_plain_directory_tree "$backup" || return 1
  safe_claude_restore_destination "$destination" "$home" || return 1
  mkdir -p "$destination" || return 1
  safe_claude_restore_destination "$destination" "$home" || return 1
  while IFS= read -r -d '' source; do
    relative="${source#"$backup"/}"
    target="$destination/$relative"
    if [ -d "$source" ]; then
      if [ -e "$target" ] || [ -L "$target" ]; then
        [ -d "$target" ] && [ ! -L "$target" ] || return 1
      else
        mkdir -p "$target" || return 1
        RESTORE_MISSING_CHANGED=1
      fi
    else
      if [ -e "$target" ] || [ -L "$target" ]; then
        [ -f "$target" ] && [ ! -L "$target" ] || return 1
      else
        mkdir -p "$(dirname "$target")" || return 1
        [ ! -L "$(dirname "$target")" ] || return 1
        cp -p "$source" "$target" || return 1
        RESTORE_MISSING_CHANGED=1
      fi
    fi
  done < <(find "$backup" -mindepth 1 -print0)
  safe_claude_restore_destination "$destination" "$home"
}

restore_matching_claude_checkpoint() {
  local session="$1"
  local id="$2"
  local transcript="$3"
  local force_checkpoint="${4:-0}"
  local checkpoint_dir
  local backup
  local tmp
  local restore=0
  local home
  local archive
  local stage=""
  local changed=0
  local force_directories=0
  local source
  local destination
  local item
  local index
  local live_valid=0
  local -a restore_sources=()
  local -a restore_destinations=()

  checkpoint_dir="$(session_dir "$session")/checkpoint"
  safe_claude_transcript_path "$transcript" "$id" || return 1
  if [ -n "$transcript" ] && valid_claude_transcript "$transcript" "$id"; then
    live_valid=1
  fi
  archive="$checkpoint_dir/claude-session.tar"
  if [ -e "$archive" ] || [ -L "$archive" ]; then
    safe_plain_file "$archive" || return 1
    stage="$checkpoint_dir/claude-restore.$$"
    rm -rf "$stage"
    mkdir -p "$stage" || return 1
    "$TAR_BIN" -tf "$archive" 2>/dev/null | \
      awk '
        /^\// { unsafe = 1 }
        /(^|\/)\.\.($|\/)/ { unsafe = 1 }
        END { exit(unsafe ? 1 : 0) }
      ' || {
      rm -rf "$stage"
      return 1
    }
    "$TAR_BIN" -tvf "$archive" 2>/dev/null | \
      awk '
        NF && substr($0, 1, 1) != "-" && substr($0, 1, 1) != "d" { unsafe = 1 }
        END { exit(unsafe ? 1 : 0) }
      ' || {
        rm -rf "$stage"
        return 1
      }
    "$TAR_BIN" -xf "$archive" -C "$stage" >/dev/null 2>&1 || {
      rm -rf "$stage"
      if [ "$live_valid" -eq 1 ]; then
        checkpoint_log "$session" "ignored unreadable Claude checkpoint for valid live session $id"
        return 0
      fi
      return 1
    }
    if ! safe_plain_directory_tree "$stage"; then
      rm -rf "$stage"
      return 1
    fi
    backup="$stage/transcript.jsonl"
  else
    backup="$checkpoint_dir/transcript.jsonl"
  fi
  if [ ! -e "$backup" ] && [ ! -L "$backup" ]; then
    [ -z "$stage" ] || rm -rf "$stage"
    [ -z "$stage" ] && return 0
    return 1
  fi
  safe_plain_file "$backup" || {
    [ -z "$stage" ] || rm -rf "$stage"
    return 1
  }
  valid_claude_transcript "$backup" "$id" || {
    [ -z "$stage" ] || rm -rf "$stage"
    if [ "$live_valid" -eq 1 ]; then
      checkpoint_log "$session" "ignored stale or mismatched Claude checkpoint for valid live session $id"
      return 0
    fi
    return 1
  }
  [ -n "$transcript" ] || {
    [ -z "$stage" ] || rm -rf "$stage"
    return 1
  }

  home="$(canonical_claude_home)" || {
    [ -z "$stage" ] || rm -rf "$stage"
    return 1
  }
  transcript="$(canonical_claude_transcript_path "$transcript" "$id")" || {
    [ -z "$stage" ] || rm -rf "$stage"
    return 1
  }
  [ ! -L "$transcript" ] && \
    { [ ! -e "$transcript" ] || safe_plain_file "$transcript"; } || {
    [ -z "$stage" ] || rm -rf "$stage"
    return 1
  }

  # Build and validate the complete restore plan before replacing even the
  # transcript. This prevents a later unsafe companion path from leaving a
  # partially restored Claude session.
  if [ -n "$stage" ]; then
    for source in \
      "$stage/project-session" \
      "$stage/file-history" \
      "$stage/session-env"; do
      case "$source" in
        "$stage/project-session") destination="${transcript%.jsonl}" ;;
        "$stage/file-history") destination="$home/file-history/$id" ;;
        *) destination="$home/session-env/$id" ;;
      esac
      [ -d "$source" ] || continue
      restore_sources+=( "$source" )
      restore_destinations+=( "$destination" )
    done
    for source in "$stage"/tasks/*; do
      [ -d "$source" ] || continue
      restore_sources+=( "$source" )
      restore_destinations+=( "$home/tasks/$(basename "$source")" )
    done
    for source in "$stage"/teams/*; do
      [ -d "$source" ] || continue
      restore_sources+=( "$source" )
      restore_destinations+=( "$home/teams/$(basename "$source")" )
    done
  else
    for item in \
      "claude-session|${transcript%.jsonl}" \
      "claude-file-history|$home/file-history/$id" \
      "claude-session-env|$home/session-env/$id"; do
      source="$checkpoint_dir/${item%%|*}"
      [ -d "$source" ] || continue
      restore_sources+=( "$source" )
      restore_destinations+=( "${item#*|}" )
    done
  fi
  for ((index = 0; index < ${#restore_sources[@]}; index++)); do
    safe_plain_directory_tree "${restore_sources[$index]}" && \
      preflight_claude_restore_publish_state \
        "${restore_destinations[$index]}" "$home" || {
        [ -z "$stage" ] || rm -rf "$stage"
        return 1
      }
  done

  if ! valid_claude_transcript "$transcript" "$id"; then
    restore=1
  elif [ "$(stat -f '%z' "$transcript")" -lt "$(stat -f '%z' "$backup")" ]; then
    restore=1
  fi
  [ "$force_checkpoint" -eq 0 ] || restore=1
  if [ "$restore" -eq 1 ]; then
    mkdir -p "$(dirname "$transcript")" || {
      [ -z "$stage" ] || rm -rf "$stage"
      return 1
    }
    tmp="$transcript.detach.tmp"
    if [ -e "$tmp" ] || [ -L "$tmp" ]; then
      safe_plain_file "$tmp" || {
        [ -z "$stage" ] || rm -rf "$stage"
        return 1
      }
      rm -f "$tmp" || {
        [ -z "$stage" ] || rm -rf "$stage"
        return 1
      }
    fi
    cp -p "$backup" "$tmp" || {
      [ -z "$stage" ] || rm -rf "$stage"
      return 1
    }
    valid_claude_transcript "$tmp" "$id" || {
      rm -f "$tmp"
      [ -z "$stage" ] || rm -rf "$stage"
      return 1
    }
    safe_plain_file "$tmp" || {
      [ -z "$stage" ] || rm -rf "$stage"
      return 1
    }
    mv -f "$tmp" "$transcript" || {
      [ -z "$stage" ] || rm -rf "$stage"
      return 1
    }
    changed=1
    force_directories=1
  fi

  if [ -n "$stage" ]; then
    for source in \
      "$stage/project-session" \
      "$stage/file-history" \
      "$stage/session-env"; do
      case "$source" in
        "$stage/project-session") destination="${transcript%.jsonl}" ;;
        "$stage/file-history") destination="$home/file-history/$id" ;;
        *) destination="$home/session-env/$id" ;;
      esac
      [ -d "$source" ] || continue
      if [ "$force_directories" -eq 1 ] || [ ! -d "$destination" ] || [ -L "$destination" ]; then
        restore_directory_checkpoint "$source" "$destination" "$home" || {
          rm -rf "$stage"
          return 1
        }
        changed=1
      else
        restore_missing_checkpoint_files "$source" "$destination" "$home" || {
          rm -rf "$stage"
          return 1
        }
        [ "$RESTORE_MISSING_CHANGED" -eq 0 ] || changed=1
      fi
    done
    for source in "$stage"/tasks/*; do
      [ -d "$source" ] || continue
      destination="$home/tasks/$(basename "$source")"
      if [ "$force_directories" -eq 1 ] || [ ! -d "$destination" ] || [ -L "$destination" ]; then
        restore_directory_checkpoint "$source" "$destination" "$home" || {
          rm -rf "$stage"
          return 1
        }
        changed=1
      else
        restore_missing_checkpoint_files "$source" "$destination" "$home" || {
          rm -rf "$stage"
          return 1
        }
        [ "$RESTORE_MISSING_CHANGED" -eq 0 ] || changed=1
      fi
    done
    for source in "$stage"/teams/*; do
      [ -d "$source" ] || continue
      destination="$home/teams/$(basename "$source")"
      if [ "$force_directories" -eq 1 ] || [ ! -d "$destination" ] || [ -L "$destination" ]; then
        restore_directory_checkpoint "$source" "$destination" "$home" || {
          rm -rf "$stage"
          return 1
        }
        changed=1
      else
        restore_missing_checkpoint_files "$source" "$destination" "$home" || {
          rm -rf "$stage"
          return 1
        }
        [ "$RESTORE_MISSING_CHANGED" -eq 0 ] || changed=1
      fi
    done
  else
    for item in \
      "claude-session|${transcript%.jsonl}" \
      "claude-file-history|$home/file-history/$id" \
      "claude-session-env|$home/session-env/$id"; do
      source="$checkpoint_dir/${item%%|*}"
      destination="${item#*|}"
      [ -d "$source" ] || continue
      if [ "$force_directories" -eq 1 ] || [ ! -d "$destination" ] || [ -L "$destination" ]; then
        restore_directory_checkpoint "$source" "$destination" "$home" || return 1
        changed=1
      else
        restore_missing_checkpoint_files "$source" "$destination" "$home" || return 1
        [ "$RESTORE_MISSING_CHANGED" -eq 0 ] || changed=1
      fi
    done
  fi
  [ -z "$stage" ] || rm -rf "$stage"
  if [ "$changed" -eq 1 ]; then
    [ "$SYNC_ENABLED" = "0" ] || /bin/sync
    error "restored Claude session artifacts from the matching checkpoint before resume"
  fi
}

checkpoint_log() {
  local session="$1"
  shift
  printf '%s %s\n' "$(now_iso)" "$*" >>"$(session_dir "$session")/checkpoint.log"
}

checkpoint_rollout() {
  local session="$1"
  local rollout="$2"
  local expected_id="$3"
  local checkpoint_dir
  local tmp
  local attempt

  [ -f "$rollout" ] && safe_codex_rollout_path "$rollout" || return 1
  checkpoint_dir="$(session_dir "$session")/checkpoint"
  tmp="$checkpoint_dir/rollout.jsonl.tmp.$$"

  for attempt in 1 2 3; do
    cp -p "$rollout" "$tmp" 2>/dev/null || true
    if valid_jsonl "$tmp" "$expected_id"; then
      mv -f "$tmp" "$checkpoint_dir/rollout.jsonl"
      return 0
    fi
    rm -f "$tmp"
    sleep 1
  done

  checkpoint_log "$session" "rollout snapshot skipped because the source was mid-write"
  return 1
}

copy_checkpoint_directory() {
  local source="$1"
  local destination="$2"

  [ -d "$source" ] || return 0
  safe_plain_directory_tree "$source" || return 1
  mkdir -p "$(dirname "$destination")" || return 1
  cp -R "$source" "$destination" || return 1
  safe_plain_directory_tree "$destination"
}

checkpoint_claude_artifacts() {
  local session="$1"
  local transcript="$2"
  local id="$3"
  local checkpoint_dir
  local tmp
  local home
  local stage
  local archive_tmp
  local task
  local config
  local team
  local short_id

  [ -f "$transcript" ] && safe_claude_transcript_path "$transcript" "$id" || return 1
  checkpoint_dir="$(session_dir "$session")/checkpoint"
  stage="$checkpoint_dir/claude-stage.$$"
  archive_tmp="$checkpoint_dir/claude-session.tar.tmp.$$"
  rm -rf "$stage"
  rm -f "$archive_tmp"
  mkdir -p "$stage" || return 1

  cp -p "$transcript" "$stage/transcript.jsonl" 2>/dev/null || {
    rm -rf "$stage"
    return 1
  }
  if ! valid_claude_transcript "$stage/transcript.jsonl" "$id"; then
    rm -rf "$stage"
    checkpoint_log "$session" "Claude transcript snapshot skipped because the source was mid-write"
    return 1
  fi

  home="$(canonical_claude_home)" || {
    rm -rf "$stage"
    return 1
  }
  short_id="${id:0:8}"
  copy_checkpoint_directory "${transcript%.jsonl}" "$stage/project-session" || {
    rm -rf "$stage"
    return 1
  }
  copy_checkpoint_directory "$home/file-history/$id" "$stage/file-history" || {
    rm -rf "$stage"
    return 1
  }
  copy_checkpoint_directory "$home/session-env/$id" "$stage/session-env" || {
    rm -rf "$stage"
    return 1
  }
  for task in "$home/tasks/$id" "$home/tasks/session-$short_id"; do
    [ -d "$task" ] || continue
    copy_checkpoint_directory "$task" "$stage/tasks/$(basename "$task")" || {
      rm -rf "$stage"
      return 1
    }
  done
  for config in "$home"/teams/*/config.json; do
    [ -f "$config" ] || continue
    [ "$("$STATE_BIN" meta get "$config" leadSessionId 2>/dev/null || true)" = "$id" ] || continue
    team="$(dirname "$config")"
    copy_checkpoint_directory "$team" "$stage/teams/$(basename "$team")" || {
      rm -rf "$stage"
      return 1
    }
  done

  if [ -n "$(find "$stage" -type l -print -quit 2>/dev/null)" ]; then
    rm -rf "$stage"
    checkpoint_log "$session" "Claude checkpoint skipped because a companion artifact is a symlink"
    return 1
  fi

  "$TAR_BIN" -cf "$archive_tmp" -C "$stage" . >/dev/null 2>&1 || {
    rm -rf "$stage"
    rm -f "$archive_tmp"
    return 1
  }
  "$TAR_BIN" -tf "$archive_tmp" >/dev/null 2>&1 || {
    rm -rf "$stage"
    rm -f "$archive_tmp"
    return 1
  }
  mv -f "$archive_tmp" "$checkpoint_dir/claude-session.tar" || {
    rm -rf "$stage"
    return 1
  }

  tmp="$checkpoint_dir/transcript.jsonl.tmp.$$"
  if ! cp -p "$stage/transcript.jsonl" "$tmp" || \
     ! mv -f "$tmp" "$checkpoint_dir/transcript.jsonl"; then
    checkpoint_log "$session" "standalone Claude transcript copy failed; atomic archive remains valid"
  fi
  rm -f "$tmp"
  rm -rf \
    "$checkpoint_dir/claude-session" \
    "$checkpoint_dir/claude-file-history" \
    "$checkpoint_dir/claude-session-env" \
    "$stage"
}

checkpoint_database() {
  local session="$1"
  local db
  local checkpoint_dir
  local tmp

  [ "$PROVIDER" = "codex" ] || return 0
  db="$(codex_state_db)"
  [ -n "$db" ] && [ -f "$db" ] || return 1
  checkpoint_dir="$(session_dir "$session")/checkpoint"
  tmp="$checkpoint_dir/codex-state.sqlite.tmp.$$"
  rm -f "$tmp"

  "$SQLITE_BIN" -cmd '.timeout 5000' "$db" ".backup \"$tmp\"" >/dev/null 2>&1 || {
    rm -f "$tmp"
    checkpoint_log "$session" "Codex SQLite backup failed"
    return 1
  }
  [ "$($SQLITE_BIN "$tmp" 'PRAGMA quick_check;' 2>/dev/null)" = "ok" ] || {
    rm -f "$tmp"
    checkpoint_log "$session" "Codex SQLite backup failed quick_check"
    return 1
  }
  mv -f "$tmp" "$checkpoint_dir/codex-state.sqlite"
}

checkpoint_pane() {
  local session="$1"
  local checkpoint_dir
  local tmp
  local pane

  tmux_has_session "$session" || return 1
  pane="$(tmux_pane_id "$session" 2>/dev/null || true)"
  [ -n "$pane" ] || {
    checkpoint_log "$session" "pane snapshot failed: pane id is unavailable (socket=$TMUX_SOCKET_PATH)"
    "${TMUX_CMD[@]}" list-sessions -F 'tmux session: #{session_name}' >>"$(session_dir "$session")/checkpoint.log" 2>&1 || true
    return 1
  }
  checkpoint_dir="$(session_dir "$session")/checkpoint"
  tmp="$checkpoint_dir/pane.txt.tmp.$$"
  "${TMUX_CMD[@]}" capture-pane -p -J -S "-$HISTORY_LIMIT" -t "$pane" >"$tmp" 2>>"$(session_dir "$session")/checkpoint.log" || {
    checkpoint_log "$session" "pane snapshot failed for $pane"
    rm -f "$tmp"
    return 1
  }
  mv -f "$tmp" "$checkpoint_dir/pane.txt"

  tmp="$checkpoint_dir/pane-ansi.txt.tmp.$$"
  if "${TMUX_CMD[@]}" capture-pane -p -e -J -S "-$HISTORY_LIMIT" -t "$pane" >"$tmp" 2>/dev/null; then
    mv -f "$tmp" "$checkpoint_dir/pane-ansi.txt"
  else
    rm -f "$tmp"
  fi
}

checkpoint_worktree() {
  local session="$1"
  local cwd="$2"
  local checkpoint_dir
  local tmp
  local repository_root
  local marker_type="absent"

  checkpoint_dir="$(session_dir "$session")/checkpoint"
  tmp="$checkpoint_dir/worktree-status.txt.tmp.$$"
  repository_root="$(canonical_project_dir_for "$cwd")" || repository_root="$cwd"
  [ ! -d "$repository_root/.git" ] || marker_type="directory"
  [ ! -f "$repository_root/.git" ] || marker_type="file"
  printf 'repository-root: %s\nrepository-marker: %s\n' \
    "$repository_root" "$marker_type" >"$tmp"
  mv -f "$tmp" "$checkpoint_dir/worktree-status.txt"
}

checkpoint_lock_path() {
  printf '%s/checkpoint-%s.lock\n' "$LOCKS_ROOT" "$1"
}

checkpoint_once() {
  local session="$1"

  ensure_state_dirs
  "$LOCKF_BIN" -k -t 30 "$(checkpoint_lock_path "$session")" \
    "$SELF" __checkpoint_once_locked "$@"
}

checkpoint_once_locked() {
  local session="$1"
  local run_token="${2:-}"
  local meta
  local cwd
  local id
  local rollout
  local checkpoint_dir
  local checkpoint_time
  local tmp
  local publish=0

  meta="$(session_meta "$session")"
  [ -f "$meta" ] || return 1
  if [ -n "$run_token" ] && [ "$("$STATE_BIN" meta get "$meta" run_token)" != "$run_token" ]; then
    return 1
  fi
  mkdir -p "$(session_dir "$session")/checkpoint"

  discover_codex_session "$session" "$run_token" >/dev/null 2>&1 || true
  cwd="$("$STATE_BIN" meta get "$meta" project_dir)"
  id="$("$STATE_BIN" meta get "$meta" agent_session_id codex_session_id)"
  rollout="$("$STATE_BIN" meta get "$meta" transcript_path rollout_path)"

  if [ -n "$id" ] && [ -n "$rollout" ]; then
    if [ "$PROVIDER" = "claude" ]; then
      checkpoint_claude_artifacts "$session" "$rollout" "$id" && publish=1
    elif checkpoint_rollout "$session" "$rollout" "$id"; then
      publish=1
    fi
  fi
  checkpoint_database "$session" || true
  checkpoint_pane "$session" || true
  checkpoint_worktree "$session" "$cwd"

  if [ "$publish" -eq 1 ]; then
    checkpoint_time="$(now_iso)"
    if [ -n "$run_token" ]; then
      state_update_meta_for_run "$session" "$run_token" \
        --string last_checkpoint_at "$checkpoint_time" || true
    else
      state_update_meta "$session" --string last_checkpoint_at "$checkpoint_time" || true
    fi
    checkpoint_dir="$(session_dir "$session")/checkpoint"
    tmp="$checkpoint_dir/meta.json.tmp.$$"
    cp -p "$meta" "$tmp" && mv -f "$tmp" "$checkpoint_dir/meta.json"
    rm -f "$tmp"
  fi

  if [ "$SYNC_ENABLED" != "0" ]; then
    /bin/sync
  fi
}

checkpoint_loop() {
  local session="$1"
  local run_token="$2"
  local worker_pid="$3"
  local attempts=0
  local sleep_pid=""

  checkpoint_loop_cleanup() {
    if [ -n "$sleep_pid" ]; then
      kill "$sleep_pid" 2>/dev/null || true
      wait "$sleep_pid" 2>/dev/null || true
    fi
  }
  trap checkpoint_loop_cleanup EXIT
  trap 'exit 0' HUP INT TERM

  while kill -0 "$worker_pid" 2>/dev/null && [ "$attempts" -lt 60 ]; do
    if discover_codex_session "$session" "$run_token" >/dev/null 2>&1; then
      break
    fi
    attempts=$((attempts + 1))
    sleep 1
  done

  checkpoint_once "$session" "$run_token" || true
  while kill -0 "$worker_pid" 2>/dev/null; do
    sleep "$CHECKPOINT_INTERVAL" &
    sleep_pid=$!
    wait "$sleep_pid" || exit 0
    sleep_pid=""
    kill -0 "$worker_pid" 2>/dev/null || break
    checkpoint_once "$session" "$run_token" || true
  done
}

power_protection_state() {
  local report
  local state

  if [ -z "$POWER_BIN" ] || [ ! -x "$POWER_BIN" ]; then
    printf 'unavailable\n'
    return 0
  fi
  report="$("$POWER_BIN" status --json 2>/dev/null || true)"
  if [ -z "$report" ]; then
    printf 'unavailable\n'
    return 0
  fi
  state="$(printf '%s' "$report" | "$STATE_BIN" meta get /dev/stdin state 2>/dev/null || true)"
  case "$state" in
    protected|allowed|transitioning|low_battery|unavailable|unknown)
      printf '%s\n' "$state"
      ;;
    *)
      printf 'unknown\n'
      ;;
  esac
}

power_start_preflight() {
  local report
  local helper_reachable
  local state

  report="$("$POWER_BIN" status --json 2>/dev/null || true)"
  [ -n "$report" ] || \
    die "Mac sleep protection is unavailable; open Detach and approve its power helper"
  helper_reachable="$(printf '%s' "$report" | \
    "$STATE_BIN" meta get /dev/stdin helper_reachable 2>/dev/null || true)"
  state="$(printf '%s' "$report" | \
    "$STATE_BIN" meta get /dev/stdin state 2>/dev/null || true)"
  [ "$helper_reachable" = "true" ] || \
    die "Mac sleep protection is unavailable; open Detach and approve its power helper"
  case "$state" in
    allowed|protected)
      return 0
      ;;
    low_battery)
      die "Mac sleep protection is disabled at low battery; charge the Mac before starting a new session"
      ;;
    transitioning)
      die "Mac sleep protection is still transitioning; retry in a moment"
      ;;
    unavailable|unknown|*)
      die "Mac sleep protection is unavailable; open Detach and approve its power helper"
      ;;
  esac
}

power_protection_label() {
  case "$1" in
    protected) printf 'MAC AWAKE' ;;
    allowed) printf 'MAC CAN SLEEP' ;;
    transitioning) printf 'POWER…' ;;
    low_battery) printf 'LOW BATTERY' ;;
    unavailable|unknown|*) printf 'POWER UNAVAILABLE' ;;
  esac
}

power_refresh_session_status() {
  local session="$1"
  local state
  local previous
  local status

  tmux_has_session "$session" || return 0
  state="$(power_protection_state)"
  previous="$(tmux_option "$session" '@detach_power_state')"
  [ "$state" = "$previous" ] && return 0
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_power_state "$state" || return 1
  status="$(tmux_option "$session" '@detach_status')"
  [ -n "$status" ] || status='unknown'
  tmux_apply_session_style "$session" "$status"
}

power_status_loop() {
  local session="$1"
  local run_token="$2"
  local worker_pid="$3"
  local sleep_pid=""

  power_status_loop_cleanup() {
    if [ -n "$sleep_pid" ]; then
      kill "$sleep_pid" 2>/dev/null || true
      wait "$sleep_pid" 2>/dev/null || true
    fi
  }
  trap power_status_loop_cleanup EXIT
  trap 'exit 0' HUP INT TERM
  while kill -0 "$worker_pid" 2>/dev/null && \
        [ "$(tmux_option "$session" '@detach_run_token')" = "$run_token" ]; do
    power_refresh_session_status "$session" 2>/dev/null || true
    sleep 10 &
    sleep_pid=$!
    wait "$sleep_pid" || exit 0
    sleep_pid=""
  done
}

worker_main() {
  local session="$1"
  local cwd="$2"
  local start_ms="$3"
  local run_token="$4"
  local agent_bin="$5"
  shift 5
  local checkpoint_pid=""
  local power_monitor_pid=""
  local cleanup_done=0
  local exit_status=1
  local status_label="failed"
  local arg
  local has_approval=0
  local has_sandbox=0
  local has_cd=0
  local has_no_alt=0
  local codex_args=()
  local claude_args=()
  local agent_session_id=""
  local claude_resume=0
  local has_claude_permission=0
  local power_ready_file

  power_ready_file="$(session_dir "$session")/power-ready-$run_token"

  worker_cleanup() {
    local cleanup_status=$?
    [ "$cleanup_done" -eq 0 ] || return 0
    cleanup_done=1
    trap - EXIT HUP INT TERM

    if [ -n "$checkpoint_pid" ]; then
      kill "$checkpoint_pid" 2>/dev/null || true
      wait "$checkpoint_pid" 2>/dev/null || true
    fi
    if [ -n "$power_monitor_pid" ]; then
      kill "$power_monitor_pid" 2>/dev/null || true
      wait "$power_monitor_pid" 2>/dev/null || true
    fi
    checkpoint_once "$session" "$run_token" || true

    if [ "$exit_status" -eq 0 ]; then
      status_label="completed"
    elif [ "$cleanup_status" -ge 128 ]; then
      status_label="interrupted"
      exit_status="$cleanup_status"
    fi

    state_update_meta_for_run "$session" "$run_token" \
      --string status "$status_label" \
      --integer exit_status "$exit_status" \
      --string finished_at "$(now_iso)" || true
    printf '%s\n' "$exit_status" >"$(session_dir "$session")/exit-status"
    if [ "$(tmux_option "$session" '@detach_run_token')" = "$run_token" ]; then
      "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_running 0 2>/dev/null || true
      power_refresh_session_status "$session" 2>/dev/null || true
      tmux_update_session_status "$session" "$status_label" 2>/dev/null || true
    fi
  }

  trap worker_cleanup EXIT
  trap 'exit 129' HUP
  trap 'exit 130' INT
  trap 'exit 143' TERM

  # tmux can retain an unlinked cwd after a project volume is unmounted. On
  # macOS, a pane created by that server may inherit the dead directory even
  # when new-session/respawn-pane receive an absolute -c path. Re-enter the
  # project in the worker so the provider and checkpoint loop never inherit it.
  cd -P "$cwd" >/dev/null 2>&1 || die "could not enter project directory: $cwd"

  state_update_meta_for_run "$session" "$run_token" \
    --string status running --string worker_started_at "$(now_iso)" || true
  if [ "$(tmux_option "$session" '@detach_run_token')" = "$run_token" ]; then
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_running 1 2>/dev/null || true
    tmux_update_session_status "$session" running 2>/dev/null || true
  fi

  if [ "$PROVIDER" = "claude" ]; then
    agent_session_id="$(read_meta_field "$session" agent_session_id)"
    [ -n "$agent_session_id" ] || die "Claude session UUID is missing from metadata"
    if [ "${1:-}" = "resume" ]; then
      [ "$#" -ge 2 ] || die "internal Claude resume UUID is missing"
      [ "$2" = "$agent_session_id" ] || die "internal Claude resume UUID does not match metadata"
      claude_resume=1
      shift 2
    fi
    for arg in "$@"; do
      case "$arg" in
        --session-id|--session-id=*|-r|--resume|--resume=*|-c|--continue|\
        --fork-session|--bg|--background|--background=*|--tmux|--tmux=*|\
        -w|--worktree|--worktree=*)
          die "the harness owns Claude session and background flags; use '$PROGRAM resume SESSION_ID'"
          ;;
        --permission-mode|--permission-mode=*|--dangerously-skip-permissions)
          has_claude_permission=1
          ;;
      esac
    done
    [ "$has_claude_permission" -eq 1 ] || claude_args+=( --permission-mode auto )
    if [ "$claude_resume" -eq 1 ]; then
      claude_args+=( --resume "$agent_session_id" )
    else
      claude_args+=( --session-id "$agent_session_id" )
    fi
    claude_args+=( "$@" )
    export CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN=1
  else
    for arg in "$@"; do
      case "$arg" in
        -a|--ask-for-approval|--ask-for-approval=*) has_approval=1 ;;
        -s|--sandbox|--sandbox=*) has_sandbox=1 ;;
        --dangerously-bypass-approvals-and-sandbox)
          has_sandbox=1
          has_approval=1
          ;;
        -C|--cd|--cd=*) has_cd=1 ;;
        --no-alt-screen) has_no_alt=1 ;;
      esac
    done

    [ "$has_cd" -eq 0 ] || die "do not pass -C/--cd; start $PROGRAM from the target project"
    if [ "$has_approval" -eq 0 ]; then
      if managed_policy_disallows_never; then
        error "managed policy disallows approval=never; inheriting its approval policy and auto-reviewer"
      else
        codex_args+=( --ask-for-approval never )
      fi
    fi
    [ "$has_sandbox" -eq 1 ] || codex_args+=( --sandbox workspace-write )
    [ "$has_no_alt" -eq 1 ] || codex_args+=( --no-alt-screen )
    codex_args+=( -C "$cwd" )
    codex_args+=( "$@" )
    export CODEX_INTERNAL_ORIGINATOR_OVERRIDE="detach_$run_token"
  fi

  "$SELF" __checkpoint_loop "$session" "$run_token" "$$" &
  checkpoint_pid=$!
  power_status_loop "$session" "$run_token" "$$" &
  power_monitor_pid=$!

  set +e
  if [ "$PROVIDER" = "claude" ]; then
    "$POWER_BIN" run --session "$session" --run-token "$run_token" \
      --ready-file "$power_ready_file" -- \
      "$agent_bin" "${claude_args[@]}"
  else
    "$POWER_BIN" run --session "$session" --run-token "$run_token" \
      --ready-file "$power_ready_file" -- \
      "$agent_bin" "${codex_args[@]}"
  fi
  exit_status=$?

  printf '\n[%s] %s exited with status %s.\n' "$PROGRAM" "$PROVIDER_LABEL" "$exit_status"
  exit "$exit_status"
}

tmux_environment_args() {
  local name
  local value

  for name in PATH HOME USER LOGNAME SHELL TMPDIR LANG LC_ALL LC_CTYPE \
              XDG_CONFIG_HOME XDG_STATE_HOME \
              NODE_EXTRA_CA_CERTS HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY \
              http_proxy https_proxy all_proxy no_proxy OPENAI_API_KEY ANTHROPIC_API_KEY \
              SSL_CERT_FILE SSL_CERT_DIR CODEX_HOME CLAUDE_CONFIG_DIR \
              DETACH_CORE_ENTRYPOINT DETACH_PROVIDER DETACH_PROGRAM DETACH_LOCKS_ROOT \
              DETACH_STATE_ROOT DETACH_INSTALL_STATE_ROOT \
              DETACH_CONFIG_ROOT DETACH_TMUX_SOCKET_PATH DETACH_TMUX_CONFIG \
              DETACH_TMUX_BIN DETACH_TMUX_STYLE DETACH_TMUX_MOUSE DETACH_STATE_BIN DETACH_POWER_BIN \
              DETACH_SQLITE_BIN DETACH_TAR_BIN DETACH_ENV_BIN DETACH_LOCKF_BIN \
              DETACH_CODEX_STATE_ROOT DETACH_CODEX_CHECKPOINT_INTERVAL \
              DETACH_CODEX_HISTORY_LIMIT DETACH_CODEX_REQUIREMENTS_FILE \
              DETACH_CODEX_SYNC DETACH_CODEX_BIN \
              DETACH_CLAUDE_STATE_ROOT DETACH_CLAUDE_CHECKPOINT_INTERVAL \
              DETACH_CLAUDE_HISTORY_LIMIT DETACH_CLAUDE_SYNC DETACH_CLAUDE_BIN \
              CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN; do
    value="${!name-}"
    [ -n "$value" ] || continue
    printf '%s\0%s=%s\0' '-e' "$name" "$value"
  done
}

start_tmux_session() {
  local session="$1"
  local cwd="$2"
  local detach="$3"
  local recovery_id="$4"
  local recovery_rollout="$5"
  local preserve_checkpoint="$6"
  shift 6
  local start_ms
  local agent_bin="$AGENT_BIN_DEFAULT"
  local run_token
  local created=0
  local started=0
  local pane_id=""
  local env_file
  local env_args=()
  local session_color
  local power_ready_file
  local readiness_attempts=0

  start_ms="$(now_ms)"
  run_token="$(new_run_token)"
  power_ready_file="$(session_dir "$session")/power-ready-$run_token"
  if [ "$PROVIDER" = "claude" ] && [ -z "$recovery_id" ]; then
    recovery_id="$(new_run_token)"
  fi
  ensure_state_dirs

  if tmux_has_session "$session"; then
    die "tmux session '$session' appeared while starting"
  fi

  partial_cleanup() {
    local cleanup_status=$?
    trap - EXIT HUP INT TERM
    if [ "$started" -eq 0 ]; then
      [ "$created" -eq 0 ] || "${TMUX_CMD[@]}" kill-session -t "=$session" 2>/dev/null || true
      "$POWER_BIN" release --session "$session" --run-token "$run_token" \
        >/dev/null 2>&1 || true
      rm -f "$power_ready_file"
      state_update_meta_for_run "$session" "$run_token" \
        --string status start_failed --string finished_at "$(now_iso)" || true
    fi
    exit "$cleanup_status"
  }
  trap partial_cleanup EXIT HUP INT TERM

  # A newly daemonized tmux server inherits the client's cwd for its lifetime.
  # Anchor it in persistent Detach state instead of a removable project mount.
  pane_id="$(
    cd -P "$INSTALL_STATE_ROOT" >/dev/null 2>&1 &&
      "${TMUX_CMD[@]}" new-session -d -P -F '#{pane_id}' -s "$session" -c "$cwd" -n "$PROVIDER"
  )" || \
    die "could not create tmux session"
  [ -n "$pane_id" ] || die "tmux did not return a pane id"
  created=1
  "$LOCKF_BIN" -k -t 30 "$(checkpoint_lock_path "$session")" \
    "$SELF" __write_initial_meta "$session" "$cwd" "$start_ms" "$agent_bin" \
      "$recovery_id" "$recovery_rollout" "$run_token" "$preserve_checkpoint" || \
    die "could not initialize session metadata"
  snapshot_known_threads "$session" "$cwd" || die "could not snapshot existing $PROVIDER_LABEL sessions"
  write_resume_args "$session" "$@" || die "could not save $PROVIDER_LABEL resume options"
  rm -f "$power_ready_file"
  session_color="$(read_meta_field "$session" session_color)"
  [[ "$session_color" =~ ^#[0-9A-Fa-f]{6}$ ]] || \
    session_color="$(session_color_for "$PROVIDER" "$cwd")" || die "could not derive session color"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach 1
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_provider "$PROVIDER"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_cwd "$cwd"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_running 0
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_pane_id "$pane_id"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_run_token "$run_token"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_color "$session_color"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_tmux_style "$TMUX_STYLE_ENABLED"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_status starting
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_power_state "$(power_protection_state)"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_cli_version "$(release_version 2>/dev/null || printf 'unknown')"
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_core_path "$SELF"
  "${TMUX_CMD[@]}" set-option -q -w -t "$pane_id" remain-on-exit on
  "${TMUX_CMD[@]}" set-option -q -t "=$session:" history-limit "$HISTORY_LIMIT"
  tmux_apply_mouse_input "$session" || \
    error "warning: could not configure Detach mouse input for this session"
  if ! tmux_apply_session_style "$session" starting; then
    "${TMUX_CMD[@]}" set-option -q -t "=$session:" @detach_tmux_style 0 2>/dev/null || true
    tmux_restore_session_style "$session" 2>/dev/null || true
    error "warning: could not apply Detach tmux styling; inheriting the tmux theme for this session"
  fi

  env_file="$(session_dir "$session")/tmux-environment.bin"
  tmux_environment_args >"$env_file"
  while IFS= read -r -d '' arg; do
    env_args+=( "$arg" )
  done <"$env_file"
  rm -f "$env_file"

  "${TMUX_CMD[@]}" respawn-pane -k \
    -t "$pane_id" \
    -c "$cwd" \
    "${env_args[@]}" \
    "$ENV_BIN" -C "$INSTALL_STATE_ROOT" \
      "$SELF" __worker "$session" "$cwd" "$start_ms" "$run_token" "$agent_bin" "$@" || \
      die "could not start $PROVIDER_LABEL in tmux"

  while [ ! -f "$power_ready_file" ] && [ "$readiness_attempts" -lt 350 ]; do
    [ "$(tmux_pane_dead "$session")" = "0" ] || break
    readiness_attempts=$((readiness_attempts + 1))
    sleep 0.1
  done
  [ -f "$power_ready_file" ] || \
    die "Mac sleep protection could not be confirmed; the session was not started"
  rm -f "$power_ready_file"

  started=1
  trap - EXIT HUP INT TERM
  printf 'Started %s in %s\n' "$session" "$cwd"
  printf 'Checkpoint interval: %s seconds\n' "$CHECKPOINT_INTERVAL"

  if [ "$detach" -eq 0 ]; then
    attach_session "$session"
  fi
}

running_session_for_project() {
  local cwd="$1"
  local excluded_session="${2:-}"
  local candidate

  while IFS= read -r candidate; do
    [ -n "$candidate" ] || continue
    [ "$candidate" = "$excluded_session" ] && continue
    tmux_is_any_managed "$candidate" || continue
    tmux_session_running "$candidate" || continue
    [ "$(tmux_option "$candidate" '@detach_cwd')" = "$cwd" ] || continue
    printf '%s\n' "$candidate"
    return 0
  done < <("${TMUX_CMD[@]}" list-sessions -F '#{session_name}' 2>/dev/null || true)
  return 1
}

start_tmux_session_locked() {
  local session="$1"
  local cwd="$2"
  local recovery_id="$3"
  local recovery_rollout="$4"
  local preserve_checkpoint="$5"
  shift 5
  local existing
  if tmux_has_session "$session"; then
    tmux_is_managed "$session" || die "refusing to use unmanaged tmux session '$session'"
    tmux_session_running "$session" && \
      die "a detached task is already running; use '$PROGRAM attach $session' or '$PROGRAM stop $session' first"
    "${TMUX_CMD[@]}" kill-session -t "=$session" || die "could not remove completed tmux session '$session'"
  fi
  existing="$(running_session_for_project "$cwd" "$session" || true)"
  [ -z "$existing" ] || die "project already has a running detached session: $existing"
  start_tmux_session "$session" "$cwd" 1 "$recovery_id" "$recovery_rollout" "$preserve_checkpoint" "$@"
}

start_under_install_lock() {
  local session="$1"
  local cwd="$2"
  local recovery_id="$3"
  local recovery_rollout="$4"
  local preserve_checkpoint="$5"
  shift 5
  local lock

  lock="$(project_lock_path "$cwd")"
  "$LOCKF_BIN" -k -t 30 "$lock" "$SELF" __start_tmux_session_locked \
    "$session" "$cwd" "$recovery_id" "$recovery_rollout" "$preserve_checkpoint" "$@"
}

start_under_project_lock() {
  mkdir -p "$INSTALL_STATE_ROOT" || die "cannot create install lock directory"
  "$LOCKF_BIN" -k -t 30 "$INSTALL_LOCK" "$SELF" __start_under_install_lock "$@"
}

read_meta_field() {
  local session="$1"
  shift
  local meta

  meta="$(usable_meta_path "$session")" || return 1
  "$STATE_BIN" meta get "$meta" "$@"
}

provider_has_session_id() {
  local id="$1"
  local dir
  local candidate
  local db
  local id_sql
  local found

  [[ "$id" =~ ^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$ ]] || return 1
  id="$(printf '%s' "$id" | tr '[:upper:]' '[:lower:]')"

  for dir in "$SESSIONS_ROOT"/*; do
    [ -d "$dir" ] || continue
    for candidate in "$dir/meta.json" "$dir/checkpoint/meta.json"; do
      [ -f "$candidate" ] || continue
      "$STATE_BIN" meta matches "$candidate" "$PROVIDER" "$id" >/dev/null 2>&1 && return 0
    done
  done

  if [ "$PROVIDER" = "claude" ]; then
    candidate="$(claude_transcript_for_id "$id" 2>/dev/null)" && [ -n "$candidate" ] && return 0
    # Multiple independently valid transcripts are still evidence that the
    # UUID belongs to Claude; the context resolver will report their ambiguity.
    [ "$?" -eq 2 ] && return 0
    return 1
  fi

  db="$(codex_state_db)"
  [ -n "$db" ] && [ -f "$db" ] && [ -x "$SQLITE_BIN" ] || return 1
  id_sql="$(sql_escape "$id")"
  found="$($SQLITE_BIN -noheader -cmd '.timeout 5000' "$db" \
    "SELECT 1 FROM threads WHERE lower(id) = '$id_sql' LIMIT 1;" 2>/dev/null || true)"
  [ "$found" = "1" ]
}

provider_session_context() {
  local id="$1"
  local dir
  local meta
  local session=""
  local project=""
  local live=false
  local db
  local id_sql
  local transcript
  local transcript_status
  local fallback_session=""
  local fallback_project=""
  local fallback_created=0
  local created

  ensure_state_dirs
  [[ "$id" =~ ^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$ ]] || return 1
  id="$(printf '%s' "$id" | tr '[:upper:]' '[:lower:]')"

  for dir in "$SESSIONS_ROOT"/*; do
    [ -d "$dir" ] || continue
    session="$(basename "$dir")"
    meta="$(usable_meta_path "$session" 2>/dev/null || true)"
    [ -n "$meta" ] || continue
    "$STATE_BIN" meta matches "$meta" "$PROVIDER" "$id" >/dev/null 2>&1 || continue
    project="$("$STATE_BIN" meta get "$meta" project_dir)"
    live=false
    if tmux_has_session "$session" && tmux_is_managed "$session" && tmux_session_running "$session"; then
      live=true
    fi
    if [ "$live" = "true" ]; then
      "$STATE_BIN" emit context "$session" "$project" true
      return 0
    fi
    created="$("$STATE_BIN" meta get "$meta" created_at_ms 2>/dev/null || true)"
    case "$created" in ''|*[!0-9]*) created=0 ;; esac
    if [ -z "$fallback_session" ] || [ "$created" -gt "$fallback_created" ]; then
      fallback_session="$session"
      fallback_project="$project"
      fallback_created="$created"
    fi
  done

  if [ -n "$fallback_session" ]; then
    "$STATE_BIN" emit context "$fallback_session" "$fallback_project" false
    return 0
  fi

  session=""
  if [ "$PROVIDER" = "claude" ]; then
    transcript="$(claude_transcript_for_id "$id" 2>/dev/null)"
    transcript_status=$?
    if [ "$transcript_status" -eq 2 ]; then
      error "multiple valid Claude transcripts were found for session '$id'"
      return 2
    fi
    [ "$transcript_status" -eq 0 ] && [ -n "$transcript" ] || return 1
    project="$("$STATE_BIN" jsonl first "$transcript" cwd 2>/dev/null || true)"
  else
    db="$(codex_state_db)"
    [ -n "$db" ] && [ -f "$db" ] || return 1
    id_sql="$(sql_escape "$id")"
    project="$($SQLITE_BIN -noheader -cmd '.timeout 5000' "$db" \
      "SELECT cwd FROM threads WHERE lower(id) = '$id_sql' LIMIT 1;" 2>/dev/null || true)"
  fi
  [ -n "$project" ] || return 1
  "$STATE_BIN" emit context "" "$project" false
}

resume_agent_session() {
  local session="$1"
  local cwd="$2"
  local detach="$3"
  local id="$4"
  shift 4
  local db
  local id_sql
  local rows
  local rollout

  [[ "$id" =~ ^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$ ]] || \
    die "resume requires an exact session UUID"
  id="$(printf '%s' "$id" | tr '[:upper:]' '[:lower:]')"
  if [ "$PROVIDER" = "claude" ]; then
    local saved_id
    local resolved_status
    saved_id="$(read_meta_field "$session" agent_session_id 2>/dev/null || true)"
    saved_id="$(printf '%s' "$saved_id" | tr '[:upper:]' '[:lower:]')"
    if [ "$saved_id" = "$id" ]; then
      rollout="$(read_meta_field "$session" transcript_path 2>/dev/null || true)"
    fi
    if [ -z "$rollout" ] || \
       ! safe_claude_transcript_path "$rollout" "$id" || \
       ! valid_claude_transcript "$rollout" "$id"; then
      local saved_rollout="$rollout"
      rollout="$(claude_transcript_for_id "$id" 2>/dev/null)"
      resolved_status=$?
      if [ "$resolved_status" -eq 2 ]; then
        die "multiple valid Claude transcripts were found for session '$id'"
      fi
      if [ "$resolved_status" -ne 0 ]; then
        rollout="$saved_rollout"
      fi
    fi
    [ -n "$rollout" ] || die "Claude session '$id' was not found"
    restore_matching_claude_checkpoint "$session" "$id" "$rollout" || \
      die "could not restore the matching Claude checkpoint"
    valid_claude_transcript "$rollout" "$id" || die "Claude transcript for '$id' is missing or invalid"
    start_under_project_lock "$session" "$cwd" "$id" "$rollout" 0 resume "$id" "$@" || \
      die "could not start Claude resume session"
    [ "$detach" -eq 1 ] || attach_session "$session"
    return
  fi
  db="$(codex_state_db)"
  [ -n "$db" ] && [ -f "$db" ] || die "Codex state database was not found"
  id_sql="$(sql_escape "$id")"
  rows="$($SQLITE_BIN -noheader -cmd '.timeout 5000' "$db" \
    "SELECT rollout_path FROM threads WHERE id = '$id_sql' LIMIT 1;" 2>/dev/null)" || \
      die "could not query the Codex state database"
  [ -n "$rows" ] || die "Codex session '$id' was not found"
  rollout="$rows"
  [ -n "$rollout" ] || die "Codex session '$id' has no rollout path"
  restore_matching_rollout_checkpoint "$session" "$id" "$rollout" || \
    die "could not restore the matching rollout checkpoint"
  valid_jsonl "$rollout" "$id" || die "Codex rollout for '$id' is missing or invalid"

  start_under_project_lock "$session" "$cwd" "$id" "$rollout" 0 resume "$id" "$@" || \
    die "could not start Codex resume session"
  [ "$detach" -eq 1 ] || attach_session "$session"
}

transcript_model_context() {
  local transcript="$1"
  local field
  local value

  TRANSCRIPT_MODEL=""
  TRANSCRIPT_CTX_USED=""
  TRANSCRIPT_CTX_WINDOW=""
  TRANSCRIPT_AGENT_TURN_STATE=""
  TRANSCRIPT_AGENT_TURN_ID=""
  [ -n "$transcript" ] && [ -f "$transcript" ] || return 0
  while IFS=$'\t' read -r field value; do
    case "$field" in
      model) TRANSCRIPT_MODEL="$value" ;;
      context_used) TRANSCRIPT_CTX_USED="$value" ;;
      context_window) TRANSCRIPT_CTX_WINDOW="$value" ;;
      agent_turn_state) TRANSCRIPT_AGENT_TURN_STATE="$value" ;;
      agent_turn_id) TRANSCRIPT_AGENT_TURN_ID="$value" ;;
    esac
  done < <("$STATE_BIN" jsonl summary "$PROVIDER" "$transcript" --tsv 2>/dev/null)

  case "$TRANSCRIPT_AGENT_TURN_STATE" in
    working|waiting|interrupted) ;;
    *) TRANSCRIPT_AGENT_TURN_STATE=""; TRANSCRIPT_AGENT_TURN_ID="" ;;
  esac
  [ -n "$TRANSCRIPT_AGENT_TURN_ID" ] || TRANSCRIPT_AGENT_TURN_STATE=""
}

emit_list_json() {
  local session="$1" effective="$2" meta_status="$3" id="$4" checkpoint="$5"
  local cwd="$6" created="$7" exit_json="$8" finished="$9"
  local model="${10:-}" ctx_used="${11:-}" ctx_window="${12:-}"
  local agent_turn_state="${13:-}" agent_turn_id="${14:-}"
  local session_color="${15:-}"
  local power_state="${16:-unavailable}"
  local emit_args

  [[ "$session_color" =~ ^#[0-9A-Fa-f]{6}$ ]] || session_color=''
  emit_args=(
    emit session "$PROVIDER" "$session" "$effective"
    --meta-status "$meta_status"
    --agent-session-id "$id"
    --project-dir "$cwd"
    --created-at "$created"
    --last-checkpoint-at "$checkpoint"
    --finished-at "$finished"
    --model "$model"
    --agent-turn-state "$agent_turn_state"
    --agent-turn-id "$agent_turn_id"
    --session-color "$session_color"
    --power-state "$power_state"
  )
  [[ "$exit_json" =~ ^-?[0-9]+$ ]] && emit_args+=( --exit-status "$exit_json" )
  [[ "$ctx_used" =~ ^-?[0-9]+$ ]] && emit_args+=( --context-used "$ctx_used" )
  [[ "$ctx_window" =~ ^-?[0-9]+$ ]] && emit_args+=( --context-window "$ctx_window" )
  "$STATE_BIN" "${emit_args[@]}"
}

list_sessions() {
  local json_mode="${1:-0}"
  local dir
  local session
  local status
  local cwd
  local checkpoint
  local live
  local id
  local meta
  local recoverable=0
  local transcript_path
  local created
  local finished
  local exit_json
  local session_color
  local power_status
  local reported_power_state
  local power_state="unavailable"

  ensure_state_dirs
  if [ "$json_mode" = "1" ] && [ -x "$POWER_BIN" ]; then
    power_status="$("$POWER_BIN" status --json 2>/dev/null || true)"
    if [ -n "$power_status" ]; then
      reported_power_state="$(printf '%s' "$power_status" | \
        "$STATE_BIN" meta get /dev/stdin state 2>/dev/null || true)"
      case "$reported_power_state" in
        allowed|transitioning|protected|low_battery|unavailable|unknown)
          power_state="$reported_power_state"
          ;;
      esac
    fi
  fi
  if [ "$json_mode" != "1" ]; then
    if [ "${DETACH_LIST_HEADER:-1}" != "0" ]; then
      printf '%-9s %-48s %-12s %-36s %-20s %s\n' \
        'PROVIDER' 'SESSION' 'STATUS' 'AGENT_ID' 'CHECKPOINT' 'PROJECT'
    fi
  fi
  for dir in "$SESSIONS_ROOT"/*; do
    [ -d "$dir" ] || continue
    session="$(basename "$dir")"
    meta="$(usable_meta_path "$session" 2>/dev/null || true)"
    if [ -z "$meta" ]; then
      cwd="?"
      live="corrupt"
      session_color=""
      if tmux_has_session "$session"; then
        if tmux_is_managed "$session"; then
          cwd="$(tmux_option "$session" '@detach_cwd')"
          session_color="$(tmux_option "$session" '@detach_color')"
          if tmux_session_running "$session"; then
            live="running"
          else
            live="corrupt"
          fi
        else
          live="collision"
        fi
      fi
      if [ "$json_mode" = "1" ]; then
        emit_list_json "$session" "$live" "" "-" "-" "${cwd:-?}" "" "null" "" \
          "" "null" "null" "" "" "$session_color" "$power_state"
      else
        printf '%-9s %-48s %-12s %-36s %-20s %s\n' \
          "$PROVIDER" "$session" "$live" '-' '-' "${cwd:-?}"
      fi
      continue
    fi
    status="$(read_meta_field "$session" status 2>/dev/null || true)"
    cwd="$(read_meta_field "$session" project_dir 2>/dev/null || true)"
    checkpoint="$(read_meta_field "$session" last_checkpoint_at 2>/dev/null || true)"
    id="$(read_meta_field "$session" agent_session_id codex_session_id 2>/dev/null || true)"
    [ -n "$status" ] || status="unknown"
    [ -n "$cwd" ] || cwd="?"
    [ -n "$checkpoint" ] || checkpoint="-"
    [ -n "$id" ] || id="-"
    created="$(read_meta_field "$session" created_at 2>/dev/null || true)"
    finished="$(read_meta_field "$session" finished_at 2>/dev/null || true)"
    exit_json="$(read_meta_field "$session" exit_status 2>/dev/null || true)"
    session_color="$(read_meta_field "$session" session_color 2>/dev/null || true)"
    if [ -z "$session_color" ] && [ -n "$cwd" ] && [ "$cwd" != "?" ]; then
      session_color="$(session_color_for "$PROVIDER" "$cwd")" || session_color=''
    fi
    transcript_model_context "$(read_meta_field "$session" transcript_path rollout_path 2>/dev/null || true)"
    live=""
    if tmux_has_session "$session"; then
      if ! tmux_is_managed "$session"; then
        live="collision"
        # Do not present Detach identity for a foreign tmux session that only
        # happens to reuse a saved managed session name.
        session_color=""
      elif tmux_session_running "$session"; then
        live="running"
      else
        live="$status"
      fi
    elif [ "$status" = "running" ] || [ "$status" = "starting" ] || [ "$status" = "recovering" ]; then
      recoverable=0
      if [ "$id" != "-" ]; then
        transcript_path="$(read_meta_field "$session" transcript_path rollout_path 2>/dev/null || true)"
        if [ "$PROVIDER" = "claude" ] && \
           safe_claude_transcript_path "$transcript_path" "$id"; then
          if valid_claude_checkpoint_archive "$dir/checkpoint/claude-session.tar" "$id" || \
             valid_claude_transcript "$dir/checkpoint/transcript.jsonl" "$id"; then
            recoverable=1
          fi
        elif [ "$PROVIDER" = "codex" ] && \
             safe_codex_rollout_path "$transcript_path" && \
             valid_jsonl "$dir/checkpoint/rollout.jsonl" "$id"; then
          recoverable=1
        fi
      fi
      if [ "$recoverable" -eq 1 ]; then
        live="recoverable"
      else
        live="orphaned"
      fi
    else
      live="$status"
    fi
    if [ "$json_mode" = "1" ]; then
      emit_list_json "$session" "$live" "$status" "$id" "$checkpoint" "$cwd" "$created" "$exit_json" "$finished" \
        "$TRANSCRIPT_MODEL" "$TRANSCRIPT_CTX_USED" "$TRANSCRIPT_CTX_WINDOW" \
        "$TRANSCRIPT_AGENT_TURN_STATE" "$TRANSCRIPT_AGENT_TURN_ID" "$session_color" "$power_state"
    else
      printf '%-9s %-48s %-12s %-36s %-20s %s\n' \
        "$PROVIDER" "$session" "$live" "$id" "$checkpoint" "$cwd"
    fi
  done
}

show_status() {
  local session="$1"
  local meta
  local tmux_state="not running"
  local power_state
  local provider
  local saved_session
  local project
  local agent_session
  local status
  local checkpoint
  local exit_status

  meta="$(usable_meta_path "$session")" || die "no valid saved state for '$session'"
  if tmux_has_session "$session"; then
    if tmux_session_running "$session"; then
      tmux_state="running"
    else
      tmux_state="completed (pane retained)"
    fi
  fi
  power_state="$(power_protection_state)"

  provider="$("$STATE_BIN" meta get "$meta" provider 2>/dev/null || true)"
  saved_session="$("$STATE_BIN" meta get "$meta" session_name 2>/dev/null || true)"
  project="$("$STATE_BIN" meta get "$meta" project_dir 2>/dev/null || true)"
  agent_session="$("$STATE_BIN" meta get "$meta" agent_session_id codex_session_id 2>/dev/null || true)"
  status="$("$STATE_BIN" meta get "$meta" status 2>/dev/null || true)"
  checkpoint="$("$STATE_BIN" meta get "$meta" last_checkpoint_at 2>/dev/null || true)"
  exit_status="$("$STATE_BIN" meta get "$meta" exit_status 2>/dev/null || true)"
  [ -n "$provider" ] || provider="codex"
  [ -n "$agent_session" ] || agent_session="not discovered"
  [ -n "$checkpoint" ] || checkpoint=" none"
  [ -n "$exit_status" ] || exit_status="-"
  printf 'Provider:       %s\n' "$provider"
  printf 'Session:        %s\n' "$saved_session"
  printf 'Project:        %s\n' "$project"
  printf 'Agent session:  %s\n' "$agent_session"
  printf 'Status:         %s\n' "$status"
  printf 'Last checkpoint:%s\n' "$checkpoint"
  printf 'Exit status:    %s\n' "$exit_status"
  printf 'tmux:          %s\n' "$tmux_state"
  printf 'Power:         %s (%s)\n' "$(power_protection_label "$power_state")" "$power_state"
  printf 'State:         %s\n' "$(session_dir "$session")"
}

show_logs() {
  local session="$1"
  local ansi="${2:-0}"
  local pane_file
  local ansi_file
  local pane
  local capture_args=( -p -J )

  [ "$ansi" != "1" ] || capture_args=( -p -e -J )
  if tmux_has_session "$session"; then
    tmux_is_managed "$session" || die "refusing to read unmanaged tmux session '$session'"
    pane="$(tmux_pane_id "$session")"
    "${TMUX_CMD[@]}" capture-pane "${capture_args[@]}" -S "-$HISTORY_LIMIT" -t "$pane"
    return
  fi
  pane_file="$(session_dir "$session")/checkpoint/pane.txt"
  ansi_file="$(session_dir "$session")/checkpoint/pane-ansi.txt"
  if [ "$ansi" = "1" ] && [ -f "$ansi_file" ]; then
    pane_file="$ansi_file"
  fi
  [ -f "$pane_file" ] || die "no logs found for '$session'"
  cat "$pane_file"
}

stop_session() {
  local session="$1"
  local attempts=0
  local pane
  local pane_pid
  local pgid
  local run_token

  run_token=""
  if tmux_has_session "$session"; then
    run_token="$(tmux_option "$session" '@detach_run_token')"
  fi
  [ -n "$run_token" ] || run_token="$(read_meta_field "$session" run_token 2>/dev/null || true)"

  if tmux_has_session "$session"; then
    tmux_is_managed "$session" || die "refusing to stop unmanaged tmux session '$session'"
    pane="$(tmux_pane_id "$session" 2>/dev/null || true)"
    pane_pid=""
    pgid=""
    if [ -n "$pane" ] && [ "$(tmux_pane_dead "$session")" = "0" ]; then
      pane_pid="$("${TMUX_CMD[@]}" display-message -p -t "$pane" '#{pane_pid}' 2>/dev/null || true)"
      if [ -n "$pane_pid" ]; then
        pgid="$(ps -o pgid= -p "$pane_pid" 2>/dev/null | tr -d '[:space:]')"
      fi
      if [ -n "$pgid" ]; then
        kill -TERM -- "-$pgid" 2>/dev/null || true
      elif [ -n "$pane_pid" ]; then
        kill -TERM "$pane_pid" 2>/dev/null || true
      fi

      while [ "$(tmux_pane_dead "$session")" = "0" ] && [ "$attempts" -lt 60 ]; do
        attempts=$((attempts + 1))
        sleep 0.25
      done
      if [ "$(tmux_pane_dead "$session")" = "0" ]; then
        error "$PROVIDER_LABEL did not stop after 15 seconds; sending KILL"
        if [ -n "$pgid" ]; then
          kill -KILL -- "-$pgid" 2>/dev/null || true
        elif [ -n "$pane_pid" ]; then
          kill -KILL "$pane_pid" 2>/dev/null || true
        fi
      fi
    fi

    "${TMUX_CMD[@]}" kill-session -t "=$session" || die "could not remove tmux session '$session'"
  fi
  if [ -n "$run_token" ] && [ -n "$POWER_BIN" ] && [ -x "$POWER_BIN" ]; then
    "$POWER_BIN" release --session "$session" --run-token "$run_token" >/dev/null 2>&1 || \
      error "warning: could not immediately release Mac sleep protection; the safety lease will expire automatically"
  fi
  state_update_meta "$session" \
    --string status stopped --string stopped_at "$(now_iso)" || \
      die "tmux was stopped, but session metadata could not be updated"
  printf 'Stopped %s\n' "$session"
}

delete_session() {
  local session="$1"
  local force="${2:-0}"
  local dir
  local answer

  dir="$(session_dir "$session")"
  if ! tmux_has_session "$session" && [ ! -d "$dir" ]; then
    die "no saved state for '$session'"
  fi
  if tmux_has_session "$session"; then
    tmux_is_managed "$session" || die "refusing to delete unmanaged tmux session '$session'"
    if [ "$(tmux_pane_dead "$session")" = "0" ]; then
      die "session '$session' is still running; stop it first"
    fi
  fi
  if [ "$force" -ne 1 ]; then
    [ -t 0 ] || die "refusing to delete without --force when stdin is not a terminal"
    printf 'Delete saved state for %s? [y/N] ' "$session"
    read -r answer || die "aborted"
    case "$answer" in
      y|Y|yes|YES) ;;
      *) die "aborted" ;;
    esac
  fi
  "$LOCKF_BIN" -k -t 10 "$(checkpoint_lock_path "$session")" \
    "$SELF" __delete_locked "$session"
}

delete_locked() {
  local session="$1"
  local dir
  local owner_uid

  dir="$(session_dir "$session")"
  owner_uid="$(/usr/bin/id -u)" || die "could not determine the current user"
  [ -d "$STATE_ROOT" ] && [ ! -L "$STATE_ROOT" ] && \
    [ "$(/usr/bin/stat -f '%u' "$STATE_ROOT" 2>/dev/null || true)" = "$owner_uid" ] || \
    die "refusing unsafe provider state root: $STATE_ROOT"
  [ -d "$SESSIONS_ROOT" ] && [ ! -L "$SESSIONS_ROOT" ] && \
    [ "$(/usr/bin/stat -f '%u' "$SESSIONS_ROOT" 2>/dev/null || true)" = "$owner_uid" ] || \
    die "refusing unsafe sessions root: $SESSIONS_ROOT"
  [ -d "$dir" ] && [ ! -L "$dir" ] && \
    [ "$(/usr/bin/stat -f '%u' "$dir" 2>/dev/null || true)" = "$owner_uid" ] || \
    die "refusing unsafe session directory: $dir"
  # Re-check under the lock: a concurrent start may have revived the session.
  if tmux_has_session "$session"; then
    tmux_is_managed "$session" || die "refusing to delete unmanaged tmux session '$session'"
    if [ "$(tmux_pane_dead "$session")" = "0" ]; then
      die "session '$session' is running again; aborting delete"
    fi
  fi
  if tmux_has_session "$session"; then
    "${TMUX_CMD[@]}" kill-session -t "=$session" || die "could not remove tmux session '$session'"
  fi
  rm -rf -- "$dir"
  printf 'Deleted %s\n' "$session"
}

restore_rollout_if_needed() {
  local session="$1"
  local meta
  local rollout
  local backup
  local id
  local restore=0
  local tmp

  meta="$(usable_meta_path "$session")" || die "no valid saved state for '$session'"
  rollout="$("$STATE_BIN" meta get "$meta" transcript_path rollout_path)"
  id="$("$STATE_BIN" meta get "$meta" agent_session_id codex_session_id)"
  if [ "$PROVIDER" = "claude" ]; then
    [ -n "$id" ] || die "no Claude session UUID was checkpointed"
    if [ -z "$rollout" ]; then
      rollout="$(claude_transcript_for_id "$id" 2>/dev/null || true)"
    fi
    [ -n "$rollout" ] || die "no Claude transcript path was checkpointed"
    restore_matching_claude_checkpoint "$session" "$id" "$rollout" 1 || \
      die "could not restore Claude session artifacts"
    valid_claude_transcript "$rollout" "$id" || die "Claude transcript is missing or invalid"
    return
  fi
  backup="$(session_dir "$session")/checkpoint/rollout.jsonl"
  safe_codex_rollout_path "$rollout" || die "refusing unsafe Codex rollout path"
  [ -n "$rollout" ] && [ -n "$id" ] && [ -f "$backup" ] || return 0
  valid_jsonl "$backup" "$id" || die "saved rollout checkpoint is invalid"

  if ! valid_jsonl "$rollout" "$id"; then
    restore=1
  elif [ "$(stat -f '%z' "$rollout")" -lt "$(stat -f '%z' "$backup")" ]; then
    restore=1
  fi

  if [ "$restore" -eq 1 ]; then
    mkdir -p "$(dirname "$rollout")"
    tmp="$rollout.detach.tmp.$$"
    cp -p "$backup" "$tmp" || die "could not copy rollout checkpoint"
    valid_jsonl "$tmp" "$id" || {
      rm -f "$tmp"
      die "copied rollout checkpoint failed validation"
    }
    mv -f "$tmp" "$rollout" || die "could not restore rollout from checkpoint"
    [ "$SYNC_ENABLED" = "0" ] || /bin/sync
    error "restored damaged Codex rollout from the last checkpoint"
  fi
}

recover_session() {
  local session="$1"
  local detach="$2"
  local meta
  local cwd
  local id
  local rollout
  local backup
  local db
  local id_sql
  local primary
  local tmp
  local resume_args=()
  local arg

  meta="$(usable_meta_path "$session")" || die "no valid saved state for '$session'"
  primary="$(session_meta "$session")"
  if [ "$meta" != "$primary" ]; then
    tmp="$primary.recover.tmp.$$"
    cp -p "$meta" "$tmp" && mv -f "$tmp" "$primary" || die "could not restore checkpoint metadata"
    meta="$primary"
  fi

  if tmux_has_session "$session"; then
    tmux_is_managed "$session" || die "refusing to recover over unmanaged tmux session '$session'"
    if tmux_session_running "$session"; then
      [ "$detach" -eq 1 ] && return 0
      attach_session "$session"
    fi
    "${TMUX_CMD[@]}" kill-session -t "=$session" >/dev/null 2>&1 || true
  fi

  cwd="$("$STATE_BIN" meta get "$meta" project_dir)"
  id="$("$STATE_BIN" meta get "$meta" agent_session_id codex_session_id)"
  rollout="$("$STATE_BIN" meta get "$meta" transcript_path rollout_path)"

  if [ -z "$id" ]; then
    if [ "$PROVIDER" = "claude" ]; then
      backup="$(session_dir "$session")/checkpoint/transcript.jsonl"
    else
      backup="$(session_dir "$session")/checkpoint/rollout.jsonl"
    fi
    if [ -f "$backup" ]; then
      if [ "$PROVIDER" = "claude" ]; then
        id="$("$STATE_BIN" jsonl first "$backup" sessionId 2>/dev/null || true)"
      else
        id="$("$STATE_BIN" jsonl first "$backup" payload.id payload.session_id 2>/dev/null || true)"
        db="$(codex_state_db)"
        if [ -n "$id" ] && [ -n "$db" ] && [ -f "$db" ]; then
          id_sql="$(sql_escape "$id")"
          rollout="$($SQLITE_BIN -noheader -cmd '.timeout 5000' "$db" \
            "SELECT rollout_path FROM threads WHERE id = '$id_sql' LIMIT 1;" 2>/dev/null || true)"
        fi
      fi
    fi
  fi
  [ -n "$id" ] && [ -n "$rollout" ] || die "no unambiguous $PROVIDER_LABEL session UUID was checkpointed"
  if [ "$PROVIDER" = "claude" ]; then
    state_update_meta "$session" \
      --string agent_session_id "$id" --string transcript_path "$rollout" || \
      die "could not repair recovery metadata"
  else
    state_update_meta "$session" \
      --string agent_session_id "$id" --string transcript_path "$rollout" \
      --string codex_session_id "$id" --string rollout_path "$rollout" || \
      die "could not repair recovery metadata"
  fi
  restore_rollout_if_needed "$session"
  if [ -f "$(session_dir "$session")/resume-args.bin" ]; then
    while IFS= read -r -d '' arg; do
      resume_args+=( "$arg" )
    done <"$(session_dir "$session")/resume-args.bin"
  fi
  if [ "${#resume_args[@]}" -gt 0 ]; then
    start_under_project_lock "$session" "$cwd" "$id" "$rollout" 1 resume "$id" "${resume_args[@]}" || \
      die "could not start checkpoint recovery"
  else
    start_under_project_lock "$session" "$cwd" "$id" "$rollout" 1 resume "$id" || \
      die "could not start checkpoint recovery"
  fi
  [ "$detach" -eq 1 ] || attach_session "$session"
}

main() {
  local action="start"
  local custom_name=""
  local detach=0
  local positional_name=""
  local session
  local cwd
  local resume_id=""
  local list_json=0
  local force=0
  local ansi=0

  validate_runtime_config

  case "${1:-}" in
    start|resume|attach|list|config|status|logs|stop|recover|delete)
      action="$1"
      shift
      ;;
    help|-h|--help)
      usage
      exit 0
      ;;
  esac

  if [ "$action" = "config" ]; then
    case "${1:-}" in
      tmux-style)
        shift
        config_tmux_style "$@"
        ;;
      tmux-mouse)
        shift
        config_tmux_mouse "$@"
        ;;
      *) die "unknown config key: ${1:-missing}" ;;
    esac
    exit 0
  elif [ "$action" = "start" ] || [ "$action" = "resume" ]; then
    while [ "$#" -gt 0 ]; do
      case "$1" in
        -n|--name)
          [ "$#" -ge 2 ] || die "$1 requires a name"
          custom_name="$2"
          shift 2
          ;;
        --name=*)
          custom_name="${1#*=}"
          shift
          ;;
        -d|--detach)
          detach=1
          shift
          ;;
        --)
          shift
          break
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          break
          ;;
      esac
    done
    if [ "$action" = "resume" ]; then
      [ "$#" -gt 0 ] || die "resume requires a session UUID"
      resume_id="$1"
      shift
    fi
  elif [ "$action" = "list" ]; then
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --json)
          list_json=1
          shift
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          die "unknown list option: $1"
          ;;
      esac
    done
  else
    case "${1:-}" in
      -d|--detach)
        detach=1
        shift
        ;;
      -f|--force)
        [ "$action" = "delete" ] || die "unexpected option for $action: $1"
        force=1
        shift
        ;;
      --ansi)
        [ "$action" = "logs" ] || die "unexpected option for $action: $1"
        ansi=1
        shift
        ;;
    esac
    if [ "$#" -gt 0 ]; then
      positional_name="$1"
      shift
    fi
    [ "$#" -eq 0 ] || die "unexpected arguments for $action"
    custom_name="$positional_name"
  fi

  require_common_dependencies
  ensure_state_dirs

  if [ "$action" = "list" ]; then
    list_sessions "$list_json"
    exit 0
  fi

  session="$(normalize_session_name "$custom_name")" || exit 1
  cwd="$(canonical_project_dir)" || die "could not resolve the current project directory"

  case "$action" in
    start)
      require_start_dependencies
      start_under_project_lock "$session" "$cwd" "" "" 0 "$@" || \
        die "could not start a new detached $PROVIDER_LABEL session"
      [ "$detach" -eq 1 ] || attach_session "$session"
      ;;
    resume)
      require_start_dependencies
      resume_agent_session "$session" "$cwd" "$detach" "$resume_id" "$@"
      ;;
    attach)
      attach_session "$session"
      ;;
    status)
      show_status "$session"
      ;;
    logs)
      show_logs "$session" "$ansi"
      ;;
    stop)
      stop_session "$session"
      ;;
    recover)
      require_start_dependencies
      recover_session "$session" "$detach"
      ;;
    delete)
      require_file_or_command "$LOCKF_BIN" "lockf"
      delete_session "$session" "$force"
      ;;
  esac
}

case "${1:-}" in
  __version)
    shift
    [ "$#" -eq 0 ] || exit 1
    release_version || exit 1
    ;;
  __worker)
    shift
    worker_main "$@"
    ;;
  __checkpoint_loop)
    shift
    checkpoint_loop "$@"
    ;;
  __checkpoint_once)
    shift
    checkpoint_once "$@"
    ;;
  __checkpoint_once_locked)
    shift
    checkpoint_once_locked "$@"
    ;;
  __delete_locked)
    shift
    delete_locked "$@"
    ;;
  __write_initial_meta)
    shift
    write_initial_meta "$@"
    ;;
  __write_config_key_locked)
    shift
    [ "$#" -eq 2 ] || exit 1
    write_config_key_locked "$1" "$2"
    ;;
  __has_session_id)
    shift
    [ "$#" -eq 1 ] || exit 1
    provider_has_session_id "$1"
    ;;
  __session_context)
    shift
    [ "$#" -eq 1 ] || exit 1
    provider_session_context "$1"
    ;;
  __session_color)
    shift
    [ "$#" -eq 1 ] || exit 1
    session_color_for "$PROVIDER" "$1"
    ;;
  __start_tmux_session_locked)
    shift
    start_tmux_session_locked "$@"
    ;;
  __start_under_install_lock)
    shift
    start_under_install_lock "$@"
    ;;
  *)
    main "$@"
    ;;
esac
