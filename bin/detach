#!/bin/bash

set -u
set -o pipefail

PROGRAM="detach"

error() {
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
}

die() {
  error "$*"
  exit 1
}

usage() {
  printf '%s\n' \
    'Usage:' \
    '  detach codex [COMMAND] [ARGS...]' \
    '  detach claude [COMMAND] [ARGS...]' \
    '  detach list [--json]' \
    '  detach resume [--name NAME] [--detach] SESSION_ID [PROVIDER_ARGS...]' \
    '  detach config tmux-style [detach|inherit]' \
    '  detach doctor [--json]' \
    '  detach repair' \
    '  detach uninstall [--keep-state|--purge-state]' \
    '  detach --version' \
    '' \
    'Use an explicit provider to start or run provider-specific management commands.' \
    'The shared list includes both providers; resume detects the provider by UUID.' \
    'Run "detach codex --help" or "detach claude --help" for provider commands.'
}

resolve_self() {
  local source_path="${1:-$0}"
  local source_dir
  local link_target

  while [ -h "$source_path" ]; do
    source_dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)" || exit 1
    link_target="$(readlink "$source_path")" || exit 1
    case "$link_target" in
      /*) source_path="$link_target" ;;
      *) source_path="$source_dir/$link_target" ;;
    esac
  done

  source_dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)" || exit 1
  printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

SELF="$(resolve_self)"
CORE="$(dirname "$SELF")/detach-core"
SELF_DIR="$(dirname "$SELF")"
VERSION_FILE="$SELF_DIR/VERSION"
[ -f "$VERSION_FILE" ] || VERSION_FILE="$SELF_DIR/../VERSION"
INSTALLER="$SELF_DIR/detach-install"
[ -x "$INSTALLER" ] || INSTALLER="$SELF_DIR/../scripts/install.sh"
JQ_BIN="${DETACH_JQ_BIN:-$(command -v jq 2>/dev/null || true)}"
TMUX_BIN="${DETACH_TMUX_BIN:-$(command -v tmux 2>/dev/null || true)}"
SQLITE_BIN="${DETACH_SQLITE_BIN:-$(command -v sqlite3 2>/dev/null || true)}"
TAR_BIN="${DETACH_TAR_BIN:-/usr/bin/tar}"
CAFFEINATE_BIN="${DETACH_CAFFEINATE_BIN:-/usr/bin/caffeinate}"
ENV_BIN="${DETACH_ENV_BIN:-/usr/bin/env}"
LOCKF_BIN="${DETACH_LOCKF_BIN:-/usr/bin/lockf}"
CODEX_BIN="${DETACH_CODEX_BIN:-$(command -v codex 2>/dev/null || true)}"
CLAUDE_BIN="${DETACH_CLAUDE_BIN:-$(command -v claude 2>/dev/null || true)}"
SHASUM_BIN="${DETACH_SHASUM_BIN:-/usr/bin/shasum}"
PLUTIL_BIN="${DETACH_PLUTIL_BIN:-/usr/bin/plutil}"
LAUNCHCTL_BIN="${DETACH_LAUNCHCTL_BIN:-/bin/launchctl}"
INSTALL_BIN_DIR="${DETACH_INSTALL_BIN_DIR:-$HOME/.local/bin}"
STATE_ROOT="${DETACH_STATE_ROOT:-${XDG_STATE_HOME:-$HOME/.local/state}/detach}"
INSTALL_STATE_ROOT="${DETACH_INSTALL_STATE_ROOT:-$STATE_ROOT}"
CONFIG_ROOT="${DETACH_CONFIG_ROOT:-${XDG_CONFIG_HOME:-$HOME/.config}/detach}"
AMPHETAMINE_APP_PATH="${DETACH_AMPHETAMINE_APP_PATH:-/Applications/Amphetamine.app}"
AMPHETAMINE_POWER_PROTECT_PATH="${DETACH_AMPHETAMINE_POWER_PROTECT_PATH:-$HOME/Library/Application Scripts/com.if.Amphetamine/powerProtect.scpt}"
CLI_WATCHDOG_LABEL="${DETACH_CLI_WATCHDOG_LABEL:-dev.tsarev.detach.cli-watchdog}"
APP_WATCHDOG_LABEL="${DETACH_APP_WATCHDOG_LABEL:-dev.tsarev.detach.watchdog}"

release_version() {
  local version
  [ -f "$VERSION_FILE" ] || return 1
  IFS= read -r version <"$VERSION_FILE" || return 1
  [[ "$version" =~ ^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(-([0-9A-Za-z-]+\.)*[0-9A-Za-z-]+)?(\+[0-9A-Za-z.-]+)?$ ]] || return 1
  printf '%s\n' "$version"
}

show_version() {
  local frontend_version core_version
  frontend_version="$(release_version)" || die "version metadata is missing or invalid: $VERSION_FILE"
  require_core
  core_version="$(DETACH_CORE_ENTRYPOINT=1 DETACH_PROVIDER=codex DETACH_PROGRAM="$PROGRAM" "$CORE" __version 2>/dev/null)" || \
    die "could not read detach-core version"
  [ "$frontend_version" = "$core_version" ] || \
    die "frontend/core version mismatch: $frontend_version != $core_version"
  printf '%s\n' "$frontend_version"
}

json_escape() {
  local value="${1-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

DOCTOR_IDS=()
DOCTOR_SECTIONS=()
DOCTOR_LABELS=()
DOCTOR_REQUIRED=()
DOCTOR_STATUSES=()
DOCTOR_PATHS=()
DOCTOR_SUMMARIES=()
DOCTOR_OK=1

doctor_add() {
  DOCTOR_IDS+=("$1")
  DOCTOR_SECTIONS+=("$2")
  DOCTOR_LABELS+=("$3")
  DOCTOR_REQUIRED+=("$4")
  DOCTOR_STATUSES+=("$5")
  DOCTOR_PATHS+=("$6")
  DOCTOR_SUMMARIES+=("$7")
  if [ "$4" = "true" ] && [ "$5" = "error" ]; then
    DOCTOR_OK=0
  fi
}

doctor_command() {
  local id="$1" label="$2" command_name="$3" required="$4"
  local path
  path="$(command -v "$command_name" 2>/dev/null || true)"
  if [ -n "$path" ] && [ -x "$path" ]; then
    doctor_add "$id" base "$label" "$required" ok "$path" "Найден: $path"
  else
    doctor_add "$id" base "$label" "$required" error "" "$command_name не найден в PATH"
  fi
}

doctor_env() {
  if [ -x "$ENV_BIN" ] && "$ENV_BIN" -C / "$ENV_BIN" >/dev/null 2>&1; then
    doctor_add env base env true ok "$ENV_BIN" "Поддерживает безопасный запуск из заданного каталога"
  else
    doctor_add env base env true error "$ENV_BIN" "Требуется env с поддержкой -C"
  fi
}

doctor_report() {
  local json="$1" version build payload_id expected resolved path_command path_resolved
  local manifest_version manifest_build manifest_path manifest_payload payload_file
  local detach_hash core_hash installer_hash calculated_payload integrity_status
  local codex_path claude_path watchdog_label
  local index comma required path

  version="$(release_version 2>/dev/null || printf 'unknown')"
  build="$(head -n 1 "$SELF_DIR/BUILD" 2>/dev/null || true)"
  payload_id="$(head -n 1 "$SELF_DIR/PAYLOAD_ID" 2>/dev/null || true)"
  integrity_status=error
  if [[ "$build" =~ ^[1-9][0-9]*$ ]] && [ -x "$INSTALLER" ] && [ -x "$SHASUM_BIN" ]; then
    detach_hash="$("$SHASUM_BIN" -a 256 "$SELF" 2>/dev/null | awk '{print $1}')"
    core_hash="$("$SHASUM_BIN" -a 256 "$CORE" 2>/dev/null | awk '{print $1}')"
    installer_hash="$("$SHASUM_BIN" -a 256 "$INSTALLER" 2>/dev/null | awk '{print $1}')"
    calculated_payload="$(printf '%s\n%s\n%s\n%s\n%s\n' \
      "$version" "$build" "$detach_hash" "$core_hash" "$installer_hash" | \
      "$SHASUM_BIN" -a 256 | awk '{print $1}')"
    [ "$calculated_payload" != "$payload_id" ] || integrity_status=ok
  fi
  if [ "$integrity_status" = ok ]; then
    doctor_add integrity base "CLI integrity" true ok "$SELF_DIR" "Payload hashes согласованы"
  else
    doctor_add integrity base "CLI integrity" true error "$SELF_DIR" "Payload повреждён или metadata не согласованы"
  fi

  expected="$INSTALL_BIN_DIR/detach"
  resolved=""
  [ ! -e "$expected" ] || resolved="$(resolve_self "$expected" 2>/dev/null || true)"
  if [ -L "$expected" ] && [ "$resolved" = "$SELF" ]; then
    doctor_add cli base "detach CLI" true ok "$expected" "Установлена версия $version"
  else
    doctor_add cli base "detach CLI" true error "$expected" "Публичный CLI не указывает на текущую immutable-версию"
  fi
  path_command="$(command -v detach 2>/dev/null || true)"
  path_resolved=""
  [ -z "$path_command" ] || path_resolved="$(resolve_self "$path_command" 2>/dev/null || true)"
  if [ "$path_resolved" = "$SELF" ]; then
    doctor_add cli_path base "CLI в PATH" true ok "$path_command" "Terminal найдёт установленный detach"
  else
    doctor_add cli_path base "CLI в PATH" true error "$INSTALL_BIN_DIR" "Добавь $INSTALL_BIN_DIR в PATH"
  fi

  manifest_version=""
  manifest_build=""
  manifest_path=""
  manifest_payload=""
  if [ -f "$INSTALL_STATE_ROOT/install.json" ] && [ -x "$PLUTIL_BIN" ]; then
    manifest_version="$("$PLUTIL_BIN" -extract version raw -o - "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
    manifest_build="$("$PLUTIL_BIN" -extract build raw -o - "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
    manifest_path="$("$PLUTIL_BIN" -extract executable_path raw -o - "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
    manifest_payload="$("$PLUTIL_BIN" -extract payload_id raw -o - "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
  fi
  payload_file="$SELF_DIR/PAYLOAD_ID"
  if [ "$manifest_version" = "$version" ] && [ "$manifest_build" = "$build" ] && \
     [ "$manifest_path" = "$SELF" ] && [ -f "$payload_file" ] && \
     [ "$payload_id" = "$manifest_payload" ] && [ "$integrity_status" = ok ]; then
    doctor_add manifest base "Install manifest" true ok "$INSTALL_STATE_ROOT/install.json" "Manifest согласован с CLI"
  else
    doctor_add manifest base "Install manifest" true error "$INSTALL_STATE_ROOT/install.json" "Manifest отсутствует, повреждён или содержит другую версию"
  fi

  doctor_command tmux tmux "$TMUX_BIN" true
  doctor_command jq jq "$JQ_BIN" true

  codex_path="$CODEX_BIN"
  claude_path="$CLAUDE_BIN"
  [ -x "$codex_path" ] || codex_path=""
  [ -x "$claude_path" ] || claude_path=""
  if [ -n "$codex_path" ] || [ -n "$claude_path" ]; then
    path="${codex_path:-${claude_path:-}}"
    doctor_add provider base "Provider CLI" true ok "$path" "Доступны:${codex_path:+ Codex}${claude_path:+ Claude}"
  else
    doctor_add provider base "Provider CLI" true error "" "Не найден ни Codex CLI, ни Claude CLI"
  fi
  if [ -n "$codex_path" ]; then doctor_command sqlite sqlite3 "$SQLITE_BIN" true; fi
  if [ -n "$claude_path" ]; then doctor_command tar tar "$TAR_BIN" true; fi
  doctor_command caffeinate caffeinate "$CAFFEINATE_BIN" true
  doctor_env
  doctor_command lockf lockf "$LOCKF_BIN" true

  watchdog_label=""
  if [ -x "$LAUNCHCTL_BIN" ]; then
    for path in "$APP_WATCHDOG_LABEL" "$CLI_WATCHDOG_LABEL"; do
      if "$LAUNCHCTL_BIN" print "gui/$(id -u)/$path" >/dev/null 2>&1; then
        watchdog_label="$path"
        break
      fi
    done
  fi
  if [ -n "$watchdog_label" ]; then
    doctor_add watchdog base "Фоновая служба Detach" true ok \
      "$watchdog_label" "Фоновая проверка активна"
  else
    doctor_add watchdog base "Фоновая служба Detach" true error \
      "$APP_WATCHDOG_LABEL" "Обязательная фоновая проверка не зарегистрирована или требует разрешения"
  fi

  if [ -d "$AMPHETAMINE_APP_PATH" ]; then
    doctor_add amphetamine_app base "Amphetamine.app" true ok \
      "$AMPHETAMINE_APP_PATH" "Amphetamine установлен в Applications"
  else
    doctor_add amphetamine_app base "Amphetamine.app" true error \
      "$AMPHETAMINE_APP_PATH" "Установите Amphetamine из Mac App Store в Applications"
  fi
  if [ -f "$AMPHETAMINE_POWER_PROTECT_PATH" ]; then
    doctor_add amphetamine_power_protect base "Amphetamine Power Protect" true ok \
      "$AMPHETAMINE_POWER_PROTECT_PATH" "Power Protect установлен"
  else
    doctor_add amphetamine_power_protect base "Amphetamine Power Protect" true error \
      "$AMPHETAMINE_POWER_PROTECT_PATH" "Установите Power Protect с официального сайта Amphetamine"
  fi

  if [ "$json" -eq 1 ]; then
    printf '{"schema":1,"version":"%s","build":"%s","payload_id":"%s","ok":%s,"checks":[' \
      "$(json_escape "$version")" "$(json_escape "$build")" "$(json_escape "$payload_id")" \
      "$([ "$DOCTOR_OK" -eq 1 ] && printf true || printf false)"
    comma=""
    for index in "${!DOCTOR_IDS[@]}"; do
      printf '%s{"id":"%s","section":"%s","label":"%s","required":%s,"status":"%s","path":' \
        "$comma" "$(json_escape "${DOCTOR_IDS[$index]}")" \
        "$(json_escape "${DOCTOR_SECTIONS[$index]}")" \
        "$(json_escape "${DOCTOR_LABELS[$index]}")" \
        "${DOCTOR_REQUIRED[$index]}" "${DOCTOR_STATUSES[$index]}"
      if [ -n "${DOCTOR_PATHS[$index]}" ]; then
        printf '"%s"' "$(json_escape "${DOCTOR_PATHS[$index]}")"
      else
        printf 'null'
      fi
      printf ',"summary":"%s"}' "$(json_escape "${DOCTOR_SUMMARIES[$index]}")"
      comma=,
    done
    printf ']}\n'
  else
    printf 'Detach %s doctor\n' "$version"
    for index in "${!DOCTOR_IDS[@]}"; do
      case "${DOCTOR_STATUSES[$index]}" in ok) path='✓' ;; warning) path='!' ;; *) path='✗' ;; esac
      required=""
      [ "${DOCTOR_REQUIRED[$index]}" = true ] || required=" (optional)"
      printf '%s %s%s — %s\n' "$path" "${DOCTOR_LABELS[$index]}" "$required" "${DOCTOR_SUMMARIES[$index]}"
    done
  fi
  [ "$DOCTOR_OK" -eq 1 ]
}

require_installer() {
  [ -x "$INSTALLER" ] || die "distribution installer not found next to detach: $INSTALLER"
}

repair_source() {
  local source version_file installer_source fallback
  source="$("$PLUTIL_BIN" -extract payload_source_path raw -o - \
    "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
  version_file="$("$PLUTIL_BIN" -extract version_file_path raw -o - \
    "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
  installer_source="$("$PLUTIL_BIN" -extract installer_source_path raw -o - \
    "$INSTALL_STATE_ROOT/install.json" 2>/dev/null || true)"
  if [ -d "$source" ] && [ "$source" != "$SELF_DIR" ] && \
     [ -x "$source/detach" ] && [ -x "$source/detach-core" ] && \
     [ -f "$version_file" ] && [ -x "$installer_source" ]; then
    printf '%s\n%s\n%s\n' "$source" "$version_file" "$installer_source"
    return 0
  fi

  fallback="/Applications/Detach.app/Contents/Resources/DetachCLI"
  if [ -x "$fallback/detach" ] && [ -x "$fallback/detach-core" ] && \
     [ -x "$fallback/detach-install" ] && [ -f "$fallback/VERSION" ]; then
    printf '%s\n%s\n%s\n' "$fallback" "$fallback/VERSION" "$fallback/detach-install"
    return 0
  fi
  return 1
}

require_core() {
  [ -x "$CORE" ] || die "core executable not found: $CORE"
}

run_provider() {
  local provider="$1"
  shift

  require_core
  DETACH_CORE_ENTRYPOINT=1 \
    DETACH_PROVIDER="$provider" \
    DETACH_PROGRAM="$PROGRAM $provider" \
    "$CORE" "$@"
}

exec_provider() {
  local provider="$1"
  shift

  require_core
  DETACH_CORE_ENTRYPOINT=1 \
    DETACH_PROVIDER="$provider" \
    DETACH_PROGRAM="$PROGRAM $provider" \
    exec "$CORE" "$@"
}

list_all() {
  local status=0
  local provider_status

  DETACH_LIST_HEADER=1 run_provider codex list "$@" || status=$?
  DETACH_LIST_HEADER=0 run_provider claude list "$@" || {
    provider_status=$?
    [ "$status" -ne 0 ] || status="$provider_status"
  }
  return "$status"
}

resume_auto() {
  local session_id=""
  local codex_match=0
  local claude_match=0
  local arg
  local expect_name=0
  local after_options=0
  local has_name=0
  local detach_requested=0
  local provider=""
  local context
  local session_name
  local project_dir
  local live
  local resume_args=( "$@" )

  [ "$#" -gt 0 ] || die "resume requires a session UUID"

  for arg in "$@"; do
    if [ "$expect_name" -eq 1 ]; then
      expect_name=0
      continue
    fi
    if [ "$after_options" -eq 1 ]; then
      session_id="$arg"
      break
    fi

    case "$arg" in
      -n|--name)
        expect_name=1
        has_name=1
        ;;
      --name=*)
        has_name=1
        ;;
      -d|--detach)
        detach_requested=1
        ;;
      --)
        after_options=1
        ;;
      -h|--help)
        usage
        return 0
        ;;
      -*)
        die "unknown resume option: $arg"
        ;;
      *)
        session_id="$arg"
        break
        ;;
    esac
  done

  [ "$expect_name" -eq 0 ] || die "resume option requires a name"
  [ -n "$session_id" ] || die "resume requires a session UUID"

  if run_provider codex __has_session_id "$session_id" >/dev/null 2>&1; then
    codex_match=1
  fi
  if run_provider claude __has_session_id "$session_id" >/dev/null 2>&1; then
    claude_match=1
  fi

  if [ "$codex_match" -eq 1 ] && [ "$claude_match" -eq 1 ]; then
    die "session UUID is ambiguous across providers: $session_id"
  fi
  if [ "$codex_match" -eq 1 ]; then
    provider="codex"
  fi
  if [ "$claude_match" -eq 1 ]; then
    provider="claude"
  fi
  [ -n "$provider" ] || die "session UUID not found: $session_id"

  [ -x "$JQ_BIN" ] || die "jq is required to resolve the session context"
  context="$(run_provider "$provider" __session_context "$session_id")" || \
    die "could not resolve project context for session UUID: $session_id"
  session_name="$(printf '%s' "$context" | "$JQ_BIN" -r '.session_name // empty')"
  project_dir="$(printf '%s' "$context" | "$JQ_BIN" -r '.project_dir // empty')"
  live="$(printf '%s' "$context" | "$JQ_BIN" -r '.live // false')"

  if [ "$live" = "true" ] && [ -n "$session_name" ]; then
    if [ "$detach_requested" -eq 1 ]; then
      printf 'Already running: %s (%s)\n' "$session_name" "$provider"
      return 0
    fi
    exec_provider "$provider" attach "$session_name"
  fi

  [ -n "$project_dir" ] && [ -d "$project_dir" ] || \
    die "saved project directory is unavailable: ${project_dir:-unknown}"
  cd -P "$project_dir" >/dev/null 2>&1 || die "could not enter saved project directory: $project_dir"
  if [ "$has_name" -eq 0 ] && [ -n "$session_name" ]; then
    exec_provider "$provider" resume --name "$session_name" "${resume_args[@]}"
  fi
  exec_provider "$provider" resume "${resume_args[@]}"

  die "could not resume session UUID: $session_id"
}

main() {
  local command="${1:-}"
  local repair_metadata="" local_repair_source="" local_repair_version=""
  local local_repair_installer=""

  case "$command" in
    --version|version|__version)
      shift
      [ "$#" -eq 0 ] || die "$command does not accept arguments"
      show_version
      ;;
    doctor)
      shift
      case "${1:-}" in
        '') doctor_report 0 ;;
        --json)
          [ "$#" -eq 1 ] || die "doctor accepts only --json"
          doctor_report 1
          ;;
        *) die "unknown doctor option: $1" ;;
      esac
      ;;
    repair)
      shift
      [ "$#" -eq 0 ] || die "repair does not accept arguments"
      require_installer
      repair_metadata="$(repair_source)" || \
        die "pristine repair payload is unavailable; open Detach.app or rerun install.sh from its checkout"
      local_repair_source="$(printf '%s\n' "$repair_metadata" | sed -n '1p')"
      local_repair_version="$(printf '%s\n' "$repair_metadata" | sed -n '2p')"
      local_repair_installer="$(printf '%s\n' "$repair_metadata" | sed -n '3p')"
      exec "$local_repair_installer" install --source repair --payload-dir "$local_repair_source" \
        --version-file "$local_repair_version" --no-launch-agent --repair
      ;;
    uninstall)
      shift
      require_installer
      exec "$INSTALLER" uninstall "$@"
      ;;
    codex|claude)
      shift
      exec_provider "$command" "$@"
      ;;
    list)
      shift
      case "${1:-}" in
        '')
          list_all
          ;;
        --json)
          [ "$#" -eq 1 ] || die "list accepts only --json"
          list_all --json
          ;;
        *)
          die "unknown list option: $1"
          ;;
      esac
      ;;
    resume)
      shift
      resume_auto "$@"
      ;;
    config)
      shift
      exec_provider codex config "$@"
      ;;
    __reconcile_amphetamine)
      shift
      [ "$#" -eq 0 ] || die "__reconcile_amphetamine does not accept arguments"
      exec_provider codex __reconcile_amphetamine
      ;;
    help|-h|--help)
      shift
      [ "$#" -eq 0 ] || die "help does not accept arguments"
      usage
      ;;
    '')
      usage >&2
      exit 1
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
